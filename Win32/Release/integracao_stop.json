WITH tributacoes_atuais AS (
    SELECT DISTINCT ON (tp.cod_produto)
           tp.cod_produto,
           tp.tipo_tributacao,
           tp.aliquota,
           tp.cnr_pis_cofins,
           tpc.cst_pis,
           tpc.nome_resumido,
           tpc.aliq_pis,
           tpc.aliq_cofins               
    FROM public.tributacoes_produtos tp
    INNER JOIN public.tributacao_pis_cofins tpc on (tp.cod_pis_cofins = tpc.cod_pis_cofins)                                                                                                         
    ORDER BY tp.cod_produto, tp.data_inclusao DESC
)
SELECT p.cod_produto as codigo,
       (SELECT cnr_pis_cofins FROM public.tributacoes_produtos WHERE p.cod_produto=cod_produto and cod_empresa = 1 ORDER BY data_inclusao DESC LIMIT 1) as nome_reduzido, 
       p.nome as produto, 
       r.preco as pr_venda, 
       gr.id, 
       gr.nome as grupo, 
       tc.aliquota AS unidade,
       tc.tipo_tributacao AS descricao,
       p.ncm,
       tc.cst_pis,
       tc.nome_resumido,
       tc.aliq_pis,
       tc.aliq_cofins,                 
       (CASE WHEN tc.tipo_tributacao = '60' AND p.cest IS NULL THEN 'Verificar'
        ELSE p.cest END) AS cest,
        1 as ativo,                                 
       P.reg_desativado,           
       p.tipo,
        pm.preco_medio,
      
 CASE 
    WHEN tc.tipo_tributacao = '00' AND tc.cst_pis = '01' THEN
        ROUND(
            (r.preco 
             - (r.preco * ((tc.aliq_pis + tc.aliq_cofins + tc.aliquota)/100)) 
             - COALESCE(NULLIF(pm.preco_medio,0),0)
            ) / NULLIF(r.preco,0) * 100
        , 2 )

    WHEN tc.tipo_tributacao <> '00' AND tc.cst_pis = '01' THEN
        ROUND(
            (r.preco 
             - (r.preco * ((tc.aliq_pis + tc.aliq_cofins)/100)) 
             - COALESCE(NULLIF(pm.preco_medio,0),0)
            ) / NULLIF(r.preco,0) * 100
        , 2 )

    ELSE
        ROUND(
            (r.preco - COALESCE(NULLIF(pm.preco_medio,0),0)) / NULLIF(r.preco,0) * 100
        , 2 )
END AS margem
,  
             
       p.codigo_simp as cod_produto,
       (SELECT tpc.cst_pis 
               FROM public.tributacoes_produtos tpp        
               INNER JOIN public.tributacao_pis_cofins tpc ON (tpp.cod_pis_cofins=tpc.cod_pis_cofins)                                    
               WHERE p.cod_produto=tpp.cod_produto
               and data_inicio <= current_date
               and tpp.cod_empresa = 1                                                         
	       order by tpp.data_inicio desc,tpp.data_inclusao desc
               LIMIT 1) as cod_pis_cofins,
       (SELECT tpc.nome_resumido 
               FROM public.tributacoes_produtos tpp        
               INNER JOIN public.tributacao_pis_cofins tpc ON (tpp.cod_pis_cofins=tpc.cod_pis_cofins)                                    
               WHERE p.cod_produto=tpp.cod_produto
               and data_inicio <= current_date
               and tpp.cod_empresa = 1                                    
	       order by tpp.data_inicio desc,tpp.data_inclusao desc                   
               LIMIT 1) as cod_grupo,
       t.descricao as tabela,
       p.cod_barra as preco_ultima_compra,   
       p.id_externo   ,
        p.comissao_und          
FROM public.produtos p
    INNER JOIN public.grupos gr ON (p.cod_grupo=gr.cod_grupo)
    INNER JOIN public.unidades_medida un ON (p.cod_unidade=un.cod_unidade)
    INNER JOIN relatorios.func_preco_produtos(1,0,0,0,CURRENT_DATE) r ON (p.cod_produto=r.cod_produto)
    LEFT JOIN relatorios.saldos_produtos_com_preco_medio(1, 0, 0, 0, CURRENT_DATE) pm ON pm.cod_produto = p.cod_produto        
    INNER JOIN public.tabelas_precos t ON (r.cod_tabela=t.cod_tabela)
    LEFT JOIN tributacoes_atuais tc ON p.cod_produto = tc.cod_produto
              
                            
   -- where case when :ativo = 1 then P.reg_desativado = 'F' when :inativo = 1 then P.reg_desativado = 'T'  when :ativo = 0 and :inativo = 0 then P.reg_desativado in ('F','T') END                                                                                                        
order by gr.id, p.nome