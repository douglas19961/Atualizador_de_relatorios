          WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Processando resposta...');
          Application.ProcessMessages;
          WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Resposta completa da API: ' + Response.ContentAsString);
          Application.ProcessMessages;
          JSONResponse.Free;
          JSONResponse := TJSONObject.ParseJSONValue(Response.ContentAsString) as TJSONObject;
          if Assigned(JSONResponse) then
          begin
            TokenValue := JSONResponse.GetValue('access_token');
            if Assigned(TokenValue) then
            begin
              FToken := TokenValue.Value;
              WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Token extraído com sucesso!');
              Application.ProcessMessages;
              Result := True;
            end
            else
              WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Access Token não encontrado na resposta!');
          end
          else
            WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] JSON inválido na resposta!');
        end
        else
          WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Erro HTTP: ' +
            IntToStr(Response.StatusCode) + ' - ' + Response.ContentAsString);
      finally
        RequestBody.Free;
      end;
    finally
      JSONResponse.Free;
    end;
  except
    on E: Exception do
    begin
//      ShowMessage('Erro no login: ' + E.Message);
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Erro no login: ' + E.Message);
