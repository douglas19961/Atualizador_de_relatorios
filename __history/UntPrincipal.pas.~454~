procedure TFrmPrincipal.InserirOcorrenciaExterna(Empresa: integer; idModulo: Integer; ocorrencia: string; prioridade: integer);
var
  SQLInsert, SQLCheck: string;
  CurrentDate: TDateTime;
  FormattedDate, FormattedTime: string;
  StatusQuery: TUniQuery;
begin
  try
    // Verifica se o módulo está ativo antes de inserir a ocorrência
    SQLCheck := 'SELECT ativo FROM cadastro_modulos_ocorrencias WHERE id_modulo_ocorrencia = :id_modulo_ocorrencia';
    StatusQuery := TUniQuery.Create(nil);
    try
      StatusQuery.Connection := ConexaoModulo;
      StatusQuery.SQL.Text := SQLCheck;
      StatusQuery.ParamByName('id_modulo_ocorrencia').AsInteger := idModulo;
      StatusQuery.Open;
      if StatusQuery.IsEmpty  then
      begin
        // Se o módulo estiver inativo ou não existir, não insere a ocorrência
        Exit;
      end;
    finally
      StatusQuery.Free;
    end;
    // Pega a data e hora atual
    CurrentDate := Now;
    FormattedDate := FormatDateTime('yyyy-mm-dd', CurrentDate);
    FormattedTime := FormatDateTime('hh:nn:ss', CurrentDate);
    // Monta o SQL de inserção
    SQLInsert := 'INSERT INTO monitor_ocorrencias (id_empresa_help, id_modulo_ocorrencia, ocorrencia, id_prioridade, Data_ocorrencia, Hora) ' +
                 'VALUES (:id_empresa_help, :modulo, :ocorrencia, :id_prioridade, :Data, :Hora)';
    ConexaoModulo.StartTransaction;
    ConexaoModulo.ExecSQL(SQLInsert, [
      Empresa,
      idModulo,
      ocorrencia,
      prioridade,
      FormattedDate,
      FormattedTime
    ]);
    ConexaoModulo.Commit;
  except
    on E: Exception do
    begin
      ConexaoModulo.Rollback;
      FrmPrincipal.WriteLogFormatted('ERRO', '1', 'Ocorrências da empresa ' + inttostr(Empresa) +
        ' [MANDAR OCORRENCIA] Conexão não inicializada. ' + E.Message);
      MemoLogServer.Lines.Add('Ocorrências da empresa ' + inttostr(Empresa) +
        ' [MANDAR OCORRENCIA] Conexão não inicializada. ' + E.Message);
    end;
  end;
end;
