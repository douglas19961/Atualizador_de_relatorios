begin
  WriteLogFormatted('INFO', '109', 'Iniciando conexão com cliente');
  QueryOrigem := TUniQuery.Create(nil);
  Result := False; // Assume falha na conexão
  try
    // Define a conexão para a QueryOrigem (conexão principal)
    QueryOrigem.Connection := ConexaoModulo;
    QueryOrigem.SQL.Text := 'SELECT id_empresa, host, nome_banco, usuario, senha, porta FROM cadastro_bancos'+
        ' where id_empresa = :cod_empresa ';
