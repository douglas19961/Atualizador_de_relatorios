     end;
//    ConexaoModulo.SpecificOptions.Values['UseUnicode'] := 'True';
    ConexaoModulo.LoginPrompt := False;
    ConexaoModulo.Connected := True;  // Tenta conectar
    // Consulta para preencher os ComboBoxes de acordo com a seleção
    Query.Connection := ConexaoModulo;
    if Campo = 'cnpj' then
      Query.SQL.Text := 'SELECT id_empresa_help, nome_empresa, cnpj FROM cadastro_empresas WHERE cnpj = :valor'
    else if Campo = 'id' then
      Query.SQL.Text := 'SELECT id_empresa_help, nome_empresa, cnpj FROM cadastro_empresas WHERE id_empresa_help = :valor'
    else if Campo = 'nome' then
      Query.SQL.Text := 'SELECT id_empresa_help, nome_empresa, cnpj FROM cadastro_empresas WHERE nome_empresa = :valor';
    Query.ParamByName('valor').AsString := Valor;
    Query.Open;
    if not Query.IsEmpty then
    begin
        if ComboBox1.ItemIndex = 0 then
        begin
          // Preencher os ComboBoxes com os dados relacionados ao servidor
          ComboBoxIDServer.Text := Query.FieldByName('id_empresa_help').AsString;
          ComboBoxNomeServer.Text := Query.FieldByName('nome_empresa').AsString;
