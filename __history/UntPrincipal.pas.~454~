end;
function TFrmPrincipal.ValidarAutenticacaoAPI(const ARequestInfo: TIdHTTPRequestInfo): Boolean;
var
  AuthHeader: string;
  Username, Password: string;
  DecodedAuth: string;
  AuthParts: TArray<string>;
begin
  Result := False;
  
  try
    // Obter o header de autorização
    AuthHeader := ARequestInfo.RawHeaders.Values['Authorization'];
    
    if AuthHeader = '' then
    begin
      WriteLogFormatted('ERRO', '1', '[AUTH] Header de autorização não encontrado');
      Exit;
    end;
    
    // Verificar se é Basic Authentication
    if not AuthHeader.StartsWith('Basic ') then
    begin
      WriteLogFormatted('ERRO', '1', '[AUTH] Tipo de autenticação não suportado: ' + AuthHeader);
      Exit;
    end;
    
    // Extrair as credenciais (remover "Basic " do início)
    DecodedAuth := TNetEncoding.Base64.Decode(AuthHeader.Substring(6));
    
    // Separar usuário e senha
    AuthParts := DecodedAuth.Split([':']);
    if Length(AuthParts) <> 2 then
    begin
      WriteLogFormatted('ERRO', '1', '[AUTH] Formato de credenciais inválido');
      Exit;
    end;
    
    Username := AuthParts[0];
    Password := AuthParts[1];
    
    // Validar credenciais
    if (Username = API_USERNAME) and (Password = API_PASSWORD) then
    begin
      WriteLogFormatted('INFO', '1', '[AUTH] Autenticação bem-sucedida para usuário: ' + Username);
      Result := True;
    end
    else
    begin
      WriteLogFormatted('ERRO', '1', '[AUTH] Credenciais inválidas. Usuário: ' + Username);
    end;
    
  except
    on E: Exception do
    begin
      WriteLogFormatted('ERRO', '1', '[AUTH] Erro na validação de autenticação: ' + E.Message);
    end;
  end;
end;
