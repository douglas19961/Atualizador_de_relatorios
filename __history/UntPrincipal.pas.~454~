function TFrmPrincipal.BuscarClientesComPaginacao(const Token: string): Boolean;
var
  Response: IHTTPResponse;
  URL, URLApi, Usuario, Senha: string;
  SinceID: Integer;
  TotalProcessados: Integer;
  Continuar: Boolean;
  ClientesProcessados: Integer;
  IniFile: TIniFile;
  UltimoSinceID: string;
  QryLimpar: TUniQuery;
  CodClasseDestino, LimiteRegistros: Integer;
begin
  Result := False;
  
  // Carregar configurações da API
  if not CarregarConfiguracaoAPI(URLApi, Usuario, Senha, CodClasseDestino, LimiteRegistros) then
  begin
    WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Falha ao carregar configurações da API para paginação');
    Exit;
  end;
  
  // Carregar o último since_id processado automaticamente
  IniFile := TIniFile.Create(ExtractFilePath(ParamStr(0)) + 'UltimoSinceID.ini');
  try
    UltimoSinceID := IniFile.ReadString('Integracao', 'UltimoSinceID', '0');
    SinceID := StrToIntDef(UltimoSinceID, 0);
    
    // Verificar se a tabela está vazia
    QryLimpar := TUniQuery.Create(nil);
    try
      QryLimpar.Connection := CXClient;
      QryLimpar.SQL.Text := 'SELECT COUNT(*) as total FROM integracao.clientes_int_estrada';
      QryLimpar.Open;
      
      if QryLimpar.FieldByName('total').AsInteger = 0 then
      begin
        // Tabela está vazia, resetar para since_id=0
        SinceID := 0;
        WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Tabela vazia detectada. Resetando para since_id=0');
      end;
    finally
      QryLimpar.Free;
    end;
    
    if SinceID = 0 then
    begin
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Iniciando busca do início (since_id=0)');
      
      // Limpar a tabela antes de começar
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Limpando tabela antes de iniciar...');
      QryLimpar := TUniQuery.Create(nil);
      try
        QryLimpar.Connection := CXClient;
        QryLimpar.SQL.Text := 'DELETE FROM integracao.clientes_int_estrada';
        QryLimpar.ExecSQL;
        WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Tabela limpa com sucesso!');
      finally
        QryLimpar.Free;
      end;
    end
    else
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Continuando busca a partir do since_id: ' + IntToStr(SinceID));
  finally
    IniFile.Free;
  end;
  
  TotalProcessados := 0;
  Continuar := True;
  ClientesProcessados := 0;
  
  try
    WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Iniciando busca paginada de clientes...');
    Application.ProcessMessages;
    
    // Log das informações de conexão CXClient se disponível
    if Assigned(CXClient) then
    begin
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] CXClient - IP: ' + CXClient.Server + ', Porta: ' + IntToStr(CXClient.Port) + ', Banco: ' + CXClient.Database);
    end;
    // Loop de paginação
    while Continuar do
    begin
              URL := URLApi + '/user/sync-pdv?since_id=' + IntToStr(SinceID) + '&limit=' + IntToStr(LimiteRegistros) + '&status=ACTIVE';
      
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Buscando clientes com since_id=' + IntToStr(SinceID));
      Application.ProcessMessages;
      FHttpClient.CustomHeaders['Authorization'] := 'Bearer ' + Token;
      FHttpClient.CustomHeaders['Content-Type'] := 'application/json';
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Headers enviados: Authorization=Bearer ' + Token + ', Content-Type=' + FHttpClient.CustomHeaders['Content-Type']);
      Application.ProcessMessages;
      Response := FHttpClient.Get(URL);
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Resposta recebida. Status: ' + IntToStr(Response.StatusCode));
      Application.ProcessMessages;
      if (Response.StatusCode = 200) or (Response.StatusCode = 201) then
      begin
        WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Processando dados dos clientes...');
        Application.ProcessMessages;
        
        WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Resposta completa da API: ' + Response.ContentAsString);
        Application.ProcessMessages;
        
        // Processar JSON e obter o próximo ID
        if ParseJSONClientesComPaginacao(Response.ContentAsString, SinceID, ClientesProcessados) then
        begin
          Inc(TotalProcessados);
          WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Lote processado. Próximo since_id: ' + IntToStr(SinceID) + ', Clientes processados neste lote: ' + IntToStr(ClientesProcessados));
          Application.ProcessMessages;
          
                  // Se não processou nenhum cliente, verificar se deve resetar
        if ClientesProcessados = 0 then
        begin
          WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Nenhum cliente encontrado.');
          
          // Se estamos no since_id=0 e não há dados, parar
          if SinceID = 0 then
          begin
            WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Nenhum dado disponível na API. Parando busca automática.');
            Continuar := False;
          end
          else
          begin
            // Se não há dados mas since_id > 0, resetar para 0 e tentar novamente
            WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Resetando since_id para 0 e tentando novamente...');
            SinceID := 0;
            
            // Salvar o reset
            IniFile := TIniFile.Create(ExtractFilePath(ParamStr(0)) + 'UltimoSinceID.ini');
            try
              IniFile.WriteString('Integracao', 'UltimoSinceID', '0');
            finally
              IniFile.Free;
            end;
          end;
        end;
        end
        else
        begin
          WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Erro no processamento. Parando busca automática.');
          Continuar := False;
        end;
      end
      else
      begin
        WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Erro na requisição: ' + IntToStr(Response.StatusCode) + ' - Resposta: ' + Response.ContentAsString);
        Application.ProcessMessages;
        Continuar := False;
      end;
    end; // Fim do while
    
    // Salvar o último since_id processado
    IniFile := TIniFile.Create(ExtractFilePath(ParamStr(0)) + 'UltimoSinceID.ini');
    try
      IniFile.WriteString('Integracao', 'UltimoSinceID', IntToStr(SinceID));
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Último since_id salvo: ' + IntToStr(SinceID));
    finally
      IniFile.Free;
    end;
    
    WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Busca automática concluída. Total de lotes processados: ' + IntToStr(TotalProcessados));
    WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Sistema aguardando próximos dados automaticamente.');
    Result := True;
  except
    on E: Exception do
    begin
//      ShowMessage('Erro ao buscar clientes: ' + E.Message);
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Erro ao buscar clientes: ' + E.Message);
    end;
  end;
end;
function TFrmPrincipal.ParseJSONClientes(const JSONStr: string): Boolean;
var
  JSONArray: TJSONArray;
  Cliente: TJSONObject;
  i: Integer;
  JSONValue: TJSONValue;
  JSONObj: TJSONObject;
  DataArray: TJSONArray;
begin
  Result := False;
  
  try
    WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] JSON recebido: ' + JSONStr);
    
    JSONValue := TJSONObject.ParseJSONValue(JSONStr);
    if not Assigned(JSONValue) then
    begin
      WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] JSON inválido recebido');
      Exit;
    end;
    
    // Verificar se é um array direto
    if JSONValue is TJSONArray then
    begin
      JSONArray := JSONValue as TJSONArray;
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] JSON é um array direto');
    end
    // Verificar se é um objeto com propriedade 'data' que contém o array
    else if JSONValue is TJSONObject then
    begin
      JSONObj := JSONValue as TJSONObject;
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] JSON é um objeto');
      // Verificar se tem propriedade 'data'
      if Assigned(JSONObj.GetValue('data')) then
      begin
        DataArray := JSONObj.GetValue('data') as TJSONArray;
        if Assigned(DataArray) then
        begin
          JSONArray := DataArray;
          WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Array encontrado na propriedade "data"');
        end
        else
        begin
          WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Propriedade "data" não é um array');
          JSONValue.Free;
          Exit;
        end;
      end
      else
      begin
        WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Objeto não contém propriedade "data"');
        JSONValue.Free;
        Exit;
      end;
    end
    else
    begin
      WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] JSON não é um array nem um objeto válido');
      JSONValue.Free;
      Exit;
    end;
    WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Processando ' + IntToStr(JSONArray.Count) + ' clientes');
    WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] *** INICIANDO LOOP DE PROCESSAMENTO DE CLIENTES ***');
    
    for i := 0 to JSONArray.Count - 1 do
    begin
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] *** PROCESSANDO CLIENTE ' + IntToStr(i + 1) + ' DE ' + IntToStr(JSONArray.Count) + ' ***');
      try
        Cliente := JSONArray.Items[i] as TJSONObject;
        InserirClienteNoBanco(Cliente);
        WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] *** CLIENTE ' + IntToStr(i + 1) + ' PROCESSADO COM SUCESSO ***');
      except
        on E: Exception do
          WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Erro ao processar cliente ' + IntToStr(i) + ': ' + E.Message);
      end;
    end;
    Result := True;
  except
    on E: Exception do
    begin
      WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Erro ao processar JSON: ' + E.Message);
    end;
  end;
end;
procedure TFrmPrincipal.InserirClienteNoBanco(const Cliente: TJSONObject);
var
  QryPostgres: TUniQuery;
  CustomerID, CPF, Nome, Sobrenome, Email, Telefone, DataNascimento: string;
begin
  WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] *** ENTRANDO NA FUNÇÃO InserirClienteNoBanco ***');
  
  try
    // Log das informações de conexão
    if Assigned(CXClient) then
    begin
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Conexão CXClient - IP: ' + CXClient.Server + ', Porta: ' + IntToStr(CXClient.Port) + ', Banco: ' + CXClient.Database + ', Usuário: ' + CXClient.Username);
    end;
    
    // Verificar se a conexão está ativa
    if not Assigned(CXClient) or not CXClient.Connected then
    begin
      WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Conexão com banco não está ativa');
      Exit;
    end;
    // Extrair dados do JSON com verificação
    CustomerID := '';
    CPF := '';
    Nome := '';
    Sobrenome := '';
    Email := '';
    Telefone := '';
    DataNascimento := '';
    if Assigned(Cliente.GetValue('customer_id')) then
      CustomerID := Cliente.GetValue('customer_id').Value;
    if Assigned(Cliente.GetValue('cpf')) then
      CPF := Cliente.GetValue('cpf').Value;
    if Assigned(Cliente.GetValue('nome')) then
      Nome := Cliente.GetValue('nome').Value;
    if Assigned(Cliente.GetValue('sobrenome')) then
      Sobrenome := Cliente.GetValue('sobrenome').Value;
    if Assigned(Cliente.GetValue('email')) then
      Email := Cliente.GetValue('email').Value;
    if Assigned(Cliente.GetValue('telefone')) then
      Telefone := Cliente.GetValue('telefone').Value;
    if Assigned(Cliente.GetValue('data_nascimento')) then
      DataNascimento := Cliente.GetValue('data_nascimento').Value;
    QryPostgres := TUniQuery.Create(nil);
    try
      QryPostgres.Connection := CXClient;
      QryPostgres.SQL.Text :=
        'INSERT INTO integracao.clientes_int_estrada ' +
        '(customer_id, cpf, nome, sobrenome, email, telefone, data_nascimento, data_registro) ' +
        'VALUES (:customer_id, :cpf, :nome, :sobrenome, :email, :telefone, :data_nascimento, :data_registro)';
      QryPostgres.ParamByName('customer_id').AsString := CustomerID;
      QryPostgres.ParamByName('cpf').AsString := CPF;
      QryPostgres.ParamByName('nome').AsString := Nome;
      QryPostgres.ParamByName('sobrenome').AsString := Sobrenome;
      QryPostgres.ParamByName('email').AsString := Email;
      QryPostgres.ParamByName('telefone').AsString := Telefone;
      QryPostgres.ParamByName('data_nascimento').AsDate := StrToDateDef(DataNascimento, 0);
      QryPostgres.ParamByName('data_registro').AsDateTime := Now;
      QryPostgres.ExecSQL;
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Cliente inserido: ' + CustomerID);
      
      // Verificar e atualizar classe do cliente pelo CPF
      if Trim(CPF) <> '' then
      begin
        try
          VerificarEAtualizarClasse(CPF);
        except
          on E: Exception do
            WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Erro ao verificar classe do CPF ' + CPF + ': ' + E.Message);
        end;
      end;
    finally
      QryPostgres.Free;
    end;
  except
    on E: Exception do
    begin
      WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Erro ao inserir cliente: ' + E.Message);
    end;
  end;
end;
function TFrmPrincipal.ParseJSONClientesComPaginacao(const JSONStr: string; var ProximoID: Integer; var ClientesProcessados: Integer): Boolean;
var
  JSONArray: TJSONArray;
  Cliente: TJSONObject;
  i: Integer;
  JSONValue: TJSONValue;
  JSONObj: TJSONObject;
  DataArray: TJSONArray;
  MaiorID: Integer;
  IDValue: TJSONValue;
  IDAtual: Integer;
begin
  Result := False;
  ClientesProcessados := 0;
  MaiorID := ProximoID; // Inicializar com o ID atual
  
  try
    WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] JSON recebido: ' + JSONStr);
    
    // Log das informações de conexão CXCalient se disponível
    if Assigned(CXClient) then
    begin
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] CXClient - IP: ' + CXClient.Server + ', Porta: ' + IntToStr(CXClient.Port) + ', Banco: ' + CXClient.Database);
    end;
    
    JSONValue := TJSONObject.ParseJSONValue(JSONStr);
    if not Assigned(JSONValue) then
    begin
      WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] JSON inválido recebido');
      Exit;
    end;
    
    // Verificar se é um array direto
    if JSONValue is TJSONArray then
    begin
      JSONArray := JSONValue as TJSONArray;
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] JSON é um array direto');
    end
    // Verificar se é um objeto com propriedade 'data' que contém o array
    else if JSONValue is TJSONObject then
    begin
      JSONObj := JSONValue as TJSONObject;
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] JSON é um objeto');
      
      // Verificar se tem propriedade 'data'
      if Assigned(JSONObj.GetValue('data')) then
      begin
        DataArray := JSONObj.GetValue('data') as TJSONArray;
        if Assigned(DataArray) then
        begin
          JSONArray := DataArray;
          WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Array encontrado na propriedade "data"');
        end
        else
        begin
          WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Propriedade "data" não é um array');
          JSONValue.Free;
          Exit;
        end;
      end
      else
      begin
        WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Objeto não contém propriedade "data"');
        JSONValue.Free;
        Exit;
      end;
    end
    else
    begin
      WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] JSON não é um array nem um objeto válido');
      JSONValue.Free;
      Exit;
    end;
    // Verificar se há dados para processar
    if JSONArray.Count = 0 then
    begin
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Nenhum cliente encontrado no JSON');
      JSONValue.Free;
      Exit;
    end;
    WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Processando ' + IntToStr(JSONArray.Count) + ' clientes');
    
    // Processar cada cliente e encontrar o maior ID
    for i := 0 to JSONArray.Count - 1 do
    begin
      try
        Cliente := JSONArray.Items[i] as TJSONObject;
        
        // Extrair o customer_id do cliente para determinar o próximo since_id
        IDValue := Cliente.GetValue('customer_id');
        if Assigned(IDValue) then
        begin
          IDAtual := StrToIntDef(IDValue.Value, 0);
          if IDAtual > MaiorID then
            MaiorID := IDAtual;
        end;
        
        InserirClienteNoBanco(Cliente);
        Inc(ClientesProcessados);
      except
        on E: Exception do
          WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Erro ao processar cliente ' + IntToStr(i) + ': ' + E.Message);
      end;
    end;
    
    // Definir o próximo ID (maior customer_id encontrado + 1)
    if MaiorID > ProximoID then
    begin
      ProximoID := MaiorID + 1;
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Maior customer_id encontrado: ' + IntToStr(MaiorID) + ', Próximo since_id será: ' + IntToStr(ProximoID));
    end
    else
    begin
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Nenhum customer_id maior encontrado. Parando paginação.');
    end;
    
    Result := True;
  except
    on E: Exception do
    begin
      WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Erro ao processar JSON: ' + E.Message);
    end;
  end;
end;
