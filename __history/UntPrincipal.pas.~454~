procedure TFrmPrincipal.BuscarModulos;
var
  Query: TUniQuery;
  ClientDataSet: TClientDataSet;
begin
  Query := TUniQuery.Create(nil);
  ClientDataSet := TClientDataSet.Create(nil);
  try
    try
      FrmPrincipal.ConexaoModulo.Connected := True;
      if not FrmPrincipal.ConexaoModulo.Connected then
        raise Exception.Create('Erro ao conectar no banco de dados!');
      Query.Connection := FrmPrincipal.ConexaoModulo;
      Query.SQL.Text :=
        'SELECT ' +
        '   CASE WHEN c.id_empresa_help IS NOT NULL THEN ''Sim'' ELSE ''Não'' END AS Ativos, ' +
        '   m.nome_modulo ' +
        'FROM cadastro_modulos m ' +
        'LEFT JOIN controle_sistema c ON c.id_modulo = m.id_modulo AND c.id_empresa_help = :id ' +
        'ORDER BY m.nome_modulo';
      Query.ParamByName('id').AsString := ComboBoxIDClient.Text;
      Query.Open;
      ClientDataSet.FieldDefs.Add('Ativos', ftString, 6);
      ClientDataSet.FieldDefs.Add('nome_modulo', ftString, 60);
      ClientDataSet.CreateDataSet;
      while not Query.Eof do
      begin
        ClientDataSet.Append;
        ClientDataSet.FieldByName('Ativos').AsString := Query.FieldByName('Ativos').AsString;
        ClientDataSet.FieldByName('nome_modulo').AsString := Query.FieldByName('nome_modulo').AsString;
        ClientDataSet.Post;
        Query.Next;
      end;
      UniDataSource2.DataSet := ClientDataSet;
    except
      on E: Exception do
        FrmPrincipal.WriteLogFormatted('ERRO', '800', 'Buscar módulos: ' + E.Message);
    end;
  finally
    Query.Free;
    ClientDataSet.Free;
    // NÃO liberar FrmPrincipal.ConexaoModulo aqui!
  end;
end;
procedure TFrmPrincipal.BuscarModulosRotina;
var
  QOrigem, QDestino: TUniQuery;
  NomeTabela: string;
  IdModulo: Integer;
  NomeModulo: string;
begin
  QOrigem := TUniQuery.Create(nil);
  QDestino := TUniQuery.Create(nil);
  try
    try
      // Conectar origem (conexão módulos)
      conexaomodulos;
      if not ConexaoModulo.Connected then
        raise Exception.Create('Erro ao conectar no banco de dados de módulos!');
      // Buscar módulos ativos para o id_empresa_help informado
      QOrigem.Connection := ConexaoModulo;
      QOrigem.SQL.Text :=
        'SELECT m.id_modulo, m.nome_modulo ' +
        'FROM cadastro_modulos m ' +
        'INNER JOIN controle_sistema c ON c.id_modulo = m.id_modulo ' +
        'WHERE c.id_empresa_help = :id AND c.ativo IS TRUE ' +
        'ORDER BY m.nome_modulo';
      QOrigem.ParamByName('id').AsString := EdtEmpresaTodos.Text;
      QOrigem.Open;
      // Conectar destino (cliente)
      if not CXClient.Connected then
      begin
        CXClient.Disconnect;
        Sleep(300);
        CXClient.Connect;
      end;
      QDestino.Connection := CXClient;
      NomeTabela := 'config_dtc';
      // Se não vier nada, apaga apenas as linhas de módulos e encerra
      if QOrigem.IsEmpty then
      begin
        QDestino.SQL.Text :=
          'DELETE FROM ' + NomeTabela + ' ' +
          'WHERE id_empresa = :id_empresa ' +
          '  AND (id_client IS NULL OR TRIM(id_client) = '''')';
        QDestino.ParamByName('id_empresa').AsString := EdtEmpresaTodos.Text;
        QDestino.ExecSQL;
        WriteLogFormatted('INFO', '3', '[SINCRONIZAÇÃO MÓDULOS] Nenhum módulo ativo encontrado; módulos removidos.');
        Exit;
      end;
      // Remover módulos que não existem mais na origem (somente linhas de módulos)
      var IdsCSV: string := '';
      QOrigem.First;
      while not QOrigem.Eof do
      begin
        if not QOrigem.FieldByName('id_modulo').IsNull then
        begin
          if IdsCSV <> '' then
            IdsCSV := IdsCSV + ',';
          IdsCSV := IdsCSV + IntToStr(QOrigem.FieldByName('id_modulo').AsInteger);
        end;
        QOrigem.Next;
      end;
      if IdsCSV <> '' then
      begin
        QDestino.SQL.Text :=
          'DELETE FROM ' + NomeTabela + ' ' +
          'WHERE id_empresa = :id_empresa ' +
          '  AND (id_client IS NULL OR TRIM(id_client) = '''') ' +
          '  AND (id_modulo IS NULL OR id_modulo NOT IN (' + IdsCSV + '))';
        QDestino.ParamByName('id_empresa').AsString := EdtEmpresaTodos.Text;
        QDestino.ExecSQL;
      end;
      QOrigem.First;
      // Atualiza se existir; insere se não existir (sem apagar IDs existentes)
      while not QOrigem.Eof do
      begin
        if not QOrigem.FieldByName('id_modulo').IsNull then
          IdModulo := QOrigem.FieldByName('id_modulo').AsInteger
        else
          IdModulo := 0;
        NomeModulo := QOrigem.FieldByName('nome_modulo').AsString;
        // Tenta atualizar a linha do módulo (id_client vazio)
        QDestino.SQL.Text :=
          'UPDATE ' + NomeTabela + ' SET nome_modulo = :nome_modulo, id_empresa = :id_empresa ' +
          'WHERE (id_client IS NULL OR TRIM(id_client) = '''') ' +
          '  AND id_empresa = :id_empresa ' +
          '  AND id_modulo = :id_modulo';
        QDestino.ParamByName('nome_modulo').AsString := NomeModulo;
        QDestino.ParamByName('id_empresa').AsString := EdtEmpresaTodos.Text;
        QDestino.ParamByName('id_modulo').AsInteger := IdModulo;
        QDestino.ExecSQL;
        // Se não atualizou nenhuma linha, insere o módulo
        if QDestino.RowsAffected = 0 then
        begin
          QDestino.SQL.Text :=
            'INSERT INTO ' + NomeTabela + ' (id_modulo, nome_modulo, id_empresa) ' +
            'VALUES (:id_modulo, :nome_modulo, :id_empresa)';
          QDestino.ParamByName('id_modulo').AsInteger := IdModulo;
          QDestino.ParamByName('nome_modulo').AsString := NomeModulo;
          QDestino.ParamByName('id_empresa').AsString := EdtEmpresaTodos.Text;
          QDestino.ExecSQL;
        end;
        QOrigem.Next;
      end;
      WriteLogFormatted('INFO', '3', '[SINCRONIZAÇÃO MÓDULOS] Módulos sincronizados com sucesso no CLIENT.');
    except
      on E: Exception do
        FrmPrincipal.WriteLogFormatted('ERRO', '800', 'Buscar/Inserir módulos: ' + E.Message);
    end;
  finally
    QOrigem.Free;
    QDestino.Free;
    ConexaoModulo.Connected := False;
    // NÃO liberar FrmPrincipal.ConexaoModulo aqui!
  end;
end;
