{*
  Função para gerar logs formatados em arquivo txt
  Parâmetros:
  - Status: Status do log (ex: DEBG, INFO, ERRO, WARN)
  - Tipo: Tipo do log (ex: 1, 2, 3, etc.)
  - Mensagem: Mensagem do log
  
  Exemplo de uso:
  WriteLogFormatted('DEBG', '2', 'Remote function call: RTC_UPDATE_SyncData_PDVSyncServer(mensagem)');
  
  Resultado: [04/08/2025 08:10:00.19 DEBG(2)] Remote function call: RTC_UPDATE_SyncData_PDVSyncServer(mensagem)
*}
procedure TFrmPrincipal.WriteLogFormatted(const Status: string; const Tipo: string; const Mensagem: string);
var
  DataHora: string;
  LogEntry: string;
  LogFileName: string;
  LogsDir: string;
  BackupFileName: string;
  FileSize: Int64;
  FileStream: TFileStream;
  IniFile: TIniFile;
  LogLevel: string;
  NivelAtual: string;
begin
  // Validar pelo LogLevel do ConfigServer.ini: INFO = não grava DEBUG; DEBUG = grava tudo
  NivelAtual := UpperCase(Trim(Status));
  if (NivelAtual = 'DEBG') then
    NivelAtual := 'DEBUG';
  IniFile := TIniFile.Create(ExtractFilePath(ParamStr(0)) + 'ConfigServer.ini');
  try
    LogLevel := UpperCase(Trim(IniFile.ReadString('Logs', 'LogLevel', 'INFO')));
    if LogLevel = 'INFO' then
    begin
      // Em INFO: não gravar DEBUG/DEBG
      if (NivelAtual = 'DEBUG') then
        Exit;
    end;
    // LogLevel=DEBUG ou outro: grava tudo
  finally
    IniFile.Free;
  end;
  // Proteger acesso concorrente com Critical Section
  if Assigned(FLogCriticalSection) then
    FLogCriticalSection.Enter;
  try
    // Formata a data e hora no formato solicitado
    DataHora := FormatDateTime('dd/mm/yyyy', Now) + ' ' + FormatDateTime('hh:nn:ss.zz', Now);
    
    // Monta a entrada do log no formato solicitado
    // Exemplo: [04/08/2025 08:10:00.19 DEBG(2)] Remote function call: RTC_UPDATE_SyncData_PDVSyncServer(mensagem)
    LogEntry := '[' + DataHora + ' ' + Status + '(' + Tipo + ')] ' + Mensagem;
    
    // Define o nome do arquivo de log
    LogFileName := ExtractFilePath(ParamStr(0)) + 'Logs.txt';
    
    // Limpar logs antigos ocasionalmente (1 em cada 100 chamadas)
    if Random(100) = 0 then
      LimparLogsAntigos;
    
    // Verificar se o arquivo de log existe e seu tamanho
    if FileExists(LogFileName) then
    begin
      try
        FileStream := TFileStream.Create(LogFileName, fmOpenRead or fmShareDenyNone);
        try
          FileSize := FileStream.Size;
        finally
          FileStream.Free;
        end;
        
        // Se o arquivo ultrapassou MaxLogSize do ConfigServer.ini, fazer backup
        if FileSize > ObterMaxLogSizeBytes then
        begin
          try
            // Criar diretório de logs se não existir
            LogsDir := ExtractFilePath(ParamStr(0)) + 'logs\';
            if not DirectoryExists(LogsDir) then
              ForceDirectories(LogsDir);
            
            // Gerar nome do arquivo de backup com timestamp
            BackupFileName := LogsDir + 'Logs_' + FormatDateTime('yyyy-mm-dd_hh-nn-ss', Now) + '.txt';
            
            // Mover arquivo atual para backup
              TFile.Move(LogFileName, BackupFileName);
              
              // Criar novo arquivo de log vazio
              TFile.WriteAllText(LogFileName, '', TEncoding.UTF8);
              
              // Log do backup realizado
              LogEntry := '[' + DataHora + ' ' + Status + '(' + Tipo + ')] ' + Mensagem;
              TFile.AppendAllText(LogFileName, LogEntry + sLineBreak, TEncoding.UTF8);
              
              // Log adicional informando sobre o backup
              var BackupLogEntry := '[' + DataHora + ' INFO(1)] [GERENCIAMENTO DE LOG] Arquivo de log movido para backup: ' + BackupFileName;
              TFile.AppendAllText(LogFileName, BackupLogEntry + sLineBreak, TEncoding.UTF8);
          except
            on E: Exception do
            begin
              // Em caso de erro, apenas escrever no arquivo atual
              TFile.AppendAllText(LogFileName, LogEntry + sLineBreak, TEncoding.UTF8);
            end;
          end;
        end
        else
        begin
          // Arquivo não atingiu o limite, apenas escrever
          TFile.AppendAllText(LogFileName, LogEntry + sLineBreak, TEncoding.UTF8);
        end;
      except
        on E: Exception do
        begin
          // Em caso de erro, apenas escrever no arquivo atual
          TFile.AppendAllText(LogFileName, LogEntry + sLineBreak, TEncoding.UTF8);
        end;
      end;
    end
    else
    begin
      // Arquivo não existe, criar e escrever
      TFile.AppendAllText(LogFileName, LogEntry + sLineBreak, TEncoding.UTF8);
    end;
  finally
    if Assigned(FLogCriticalSection) then
      FLogCriticalSection.Leave;
  end;
end;
