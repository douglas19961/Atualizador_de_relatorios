procedure TFrmPrincipal.TimerAtualizadoAPPTimer(Sender: TObject);
var
  Destino: string;
  FTP: TIdFTP;
  NomeArquivoFTP, NomeArquivoLocal: string;
  ArquivoV: string;
  I: Integer;
  ArquivosFTP: TStringList;
  NovoPontoBRFile, NovoPontoBRVersion: string;
  IniFile: TIniFile;
  LogMessage: string;
  LogDir: string;
  HttpClient: TNetHTTPClient;
  Response: IHTTPResponse;
  JSONResponse: TJSONObject;
  VersaoAPI: string;
  SuccessAPI, AtualizadoAPI, atualizarrelatoriosAPI: Boolean;
  IdEmpresaStr: string;
  QUpdate: TUniQuery;
begin
LogDir := ExtractFilePath(Application.ExeName) + 'logs\';
 if not DirectoryExists(LogDir) then
  begin
    if not ForceDirectories(LogDir) then
    begin
      ShowMessage('Não foi possível criar a pasta de logs.');
      WriteLogFormatted('INFO', '1', '[EXECUTADOR DO MONITOR DE OCORRENCIA] Atualização concluída!');
      Exit;
    end;
  end;
 IniFile := TIniFile.Create(ExtractFilePath(Application.ExeName) + 'logs\Log_envio_Log_conexão.ini');
 
  // 1) Consultar API de versão antes de qualquer ação de FTP
  SuccessAPI := False;
  AtualizadoAPI := False;
  VersaoAPI := '';
  IdEmpresaStr := (EdtEmpresaTodos.Text);
  if IdEmpresaStr = '' then
  begin
    WriteLogFormatted('ERRO', '106', '[API CLIENTE] id_empresa (EdtEmpresaTodos) não informado');
    Exit;
  end;
  
  try
    HttpClient := TNetHTTPClient.Create(nil);
    try
      // Basic Auth
      var AuthString := API_USERNAME + ':' + API_PASSWORD;
      var EncodedAuth := TNetEncoding.Base64.Encode(AuthString);
      HttpClient.CustomHeaders['Authorization'] := 'Basic ' + EncodedAuth;
      var Url := 'http://'+IP_DB_Cliente.text + ':4450/api/versao-empresa?id_empresa=' + IdEmpresaStr;
      WriteLogFormatted('INFO', '106', '[API CLIENTE] Requisitando versão: ' + Url);
      Response := HttpClient.Get(Url);
      if Assigned(Response) then
      begin
        WriteLogFormatted('INFO', '106', '[API CLIENTE] Status: ' + IntToStr(Response.StatusCode));
        WriteLogFormatted('INFO', '106', '[API CLIENTE] Conteúdo: ' + Response.ContentAsString);
        try
          JSONResponse := TJSONObject.ParseJSONValue(Response.ContentAsString) as TJSONObject;
          if Assigned(JSONResponse) then
          begin
            JSONResponse.TryGetValue<Boolean>('success', SuccessAPI);
            JSONResponse.TryGetValue<Boolean>('atualizado', AtualizadoAPI);
            JSONResponse.TryGetValue<Boolean>('atualizar_relatorios', atualizarrelatoriosAPI);
            JSONResponse.TryGetValue<string>('versao', VersaoAPI);
          end;
        finally
          JSONResponse.Free;
        end;
      end;
    finally
      HttpClient.Free;
    end;
  except
    on E: Exception do
    begin
      WriteLogFormatted('ERRO', '106', '[API CLIENTE] Falha ao consultar versao-empresa: ' + E.Message);
    end;
  end;
  if atualizarrelatoriosAPI then
  begin
      if ModuloHabilitado(5) then
      begin
          TTransferenciaServerThread.Create(ConexaoModulo, CXClient, MemoLogServer);
           WriteLogFormatted('INFO', '1', '[EXECUTADOR DE RELATÓRIOS CLIENT] Execução MANUAL feita com sucesso!');
               if Assigned(ConexaoModulo) then
          begin
            QUpdate := TUniQuery.Create(nil);
            try
              QUpdate.Connection := ConexaoModulo;
              if not ConexaoModulo.Connected then
