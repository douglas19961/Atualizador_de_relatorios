function TFrmPrincipal.TentarConexaoSMTP(IdSMTP: TIdSMTP): Boolean;
var
  IOHandler: TIdSSLIOHandlerSocketOpenSSL;
  Tentativas: array of record
    UseTLS: TIdUseTLS;
    Descricao: string;
  end;
  i: Integer;
begin
  Result := False;
  
  // Definir tentativas em ordem de preferência
  SetLength(Tentativas, 4);
  Tentativas[0].UseTLS := utUseExplicitTLS;
  Tentativas[0].Descricao := 'TLS Explícito (STARTTLS)';
  Tentativas[1].UseTLS := utUseImplicitTLS;
  Tentativas[1].Descricao := 'TLS Implícito (SSL)';
  Tentativas[2].UseTLS := utNoTLSSupport;
  Tentativas[2].Descricao := 'Sem TLS/SSL';
  Tentativas[3].UseTLS := utUseRequireTLS;
  Tentativas[3].Descricao := 'TLS Obrigatório';
  
  for i := 0 to High(Tentativas) do
  begin
    try
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Tentativa ' + IntToStr(i+1) + ': ' + Tentativas[i].Descricao);
      
      // Limpar configuração anterior
      if Assigned(IdSMTP.IOHandler) then
      begin
        IdSMTP.IOHandler.Free;
        IdSMTP.IOHandler := nil;
      end;
      
      // Configurar nova tentativa
      IdSMTP.UseTLS := Tentativas[i].UseTLS;
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] UseTLS definido como: ' + IntToStr(Integer(IdSMTP.UseTLS)));
      
      // Criar IOHandler se necessário
      if (Tentativas[i].UseTLS = utUseExplicitTLS) or 
         (Tentativas[i].UseTLS = utUseImplicitTLS) or 
         (Tentativas[i].UseTLS = utUseRequireTLS) then
      begin
        if VerificarOpenSSLDLLs then
        begin
          try
            WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Criando IOHandler SSL...');
            IOHandler := TIdSSLIOHandlerSocketOpenSSL.Create(IdSMTP);
            IOHandler.SSLOptions.SSLVersions := [sslvTLSv1, sslvTLSv1_1, sslvTLSv1_2];
            IOHandler.SSLOptions.VerifyMode := [];
            IOHandler.SSLOptions.VerifyDepth := 0;
            IdSMTP.IOHandler := IOHandler;
            WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] IOHandler SSL criado e atribuído com sucesso');
            WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] IOHandler atribuído: ' + BoolToStr(Assigned(IdSMTP.IOHandler), True));
          except
            on E: Exception do
            begin
              WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Erro ao criar IOHandler: ' + E.Message);
              WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Tentando próxima configuração...');
              Continue; // Tentar próxima configuração
            end;
          end;
        end
        else
        begin
          WriteLogFormatted('AVISO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] DLLs do OpenSSL não disponíveis, pulando esta tentativa');
          Continue;
        end;
      end
      else
      begin
        WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Configuração sem SSL/TLS - não precisa de IOHandler');
      end;
      
      // Verificar status antes da conexão
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Status antes da conexão:');
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] - UseTLS: ' + IntToStr(Integer(IdSMTP.UseTLS)));
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] - IOHandler atribuído: ' + BoolToStr(Assigned(IdSMTP.IOHandler), True));
      
      // Tentar conectar
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Conectando ao servidor SMTP...');
      IdSMTP.Connect;
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Conexão SMTP estabelecida com sucesso usando: ' + Tentativas[i].Descricao);
      Result := True;
      Exit; // Sucesso!
      
    except
      on E: Exception do
      begin
        WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Falha na tentativa ' + IntToStr(i+1) + ': ' + E.Message);
        
        // Se for erro de STARTTLS, continuar para próxima tentativa
        if Pos('STARTTLS', UpperCase(E.Message)) > 0 then
        begin
          WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Erro de STARTTLS detectado, tentando próxima configuração...');
        end;
        
        // Se for erro de SSL/TLS, tentar sem criptografia
        if (Pos('SSL', UpperCase(E.Message)) > 0) or (Pos('TLS', UpperCase(E.Message)) > 0) then
        begin
          WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Erro de SSL/TLS detectado, tentando próxima configuração...');
        end;
      end;
    end;
  end;
  
  WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Todas as tentativas de conexão falharam');
end;
function TFrmPrincipal.EnviarEmailNotificacao(const CPF, NomeCliente: string; const CodClasseAnterior, CodClasseNovo: Integer): Boolean;
var
  QryConfig: TUniQuery;
  SMTP, Remetente, Destinatario, Assunto, CorpoEmail: string;
  Porta: Integer;
  SSL, TLS, EnviarNotificacao: Boolean;
  IdSMTP: TIdSMTP;
  IdMessage: TIdMessage;
  IdText: TIdText;
begin
  WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] *** ENTRANDO NA FUNÇÃO EnviarEmailNotificacao ***');
  WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Parâmetros recebidos:');
  WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] - CPF: ' + CPF);
  WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] - Nome: ' + NomeCliente);
  WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] - Classe Anterior: ' + IntToStr(CodClasseAnterior));
  WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] - Classe Nova: ' + IntToStr(CodClasseNovo));
  
  Result := False;
  try
    // Verificar se o CXClient está conectado
    if not CXClient.Connected then
    begin
      try
        CXClient.Connect;
        WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Conectando ao banco para configurações de email');
      except
        on E: Exception do
        begin
          WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Erro ao conectar com banco para email: ' + E.Message);
          Exit;
        end;
      end;
    end;
    // Buscar configurações de email
    QryConfig := TUniQuery.Create(nil);
    try
      QryConfig.Connection := CXClient;
      QryConfig.SQL.Text := 'SELECT smtp_servidor, smtp_porta, smtp_usuario, smtp_senha, smtp_ssl, smtp_tls, ' +
                           'email_remetente, email_destinatario, enviar_email_notificacao ' +
                           'FROM integracao.config_api WHERE ativo = true ORDER BY id DESC LIMIT 1';
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Carregando configurações de email...');
      QryConfig.Open;
      if not QryConfig.IsEmpty then
      begin
        SMTP := QryConfig.FieldByName('smtp_servidor').AsString;
        Porta := QryConfig.FieldByName('smtp_porta').AsInteger;
        Remetente := QryConfig.FieldByName('email_remetente').AsString;
        Destinatario := QryConfig.FieldByName('email_destinatario').AsString;
        SSL := QryConfig.FieldByName('smtp_ssl').AsBoolean;
        TLS := QryConfig.FieldByName('smtp_tls').AsBoolean;
        EnviarNotificacao := QryConfig.FieldByName('enviar_email_notificacao').AsBoolean;
        WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Configurações de email carregadas:');
        WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] - SMTP: ' + SMTP + ':' + IntToStr(Porta));
        WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] - Remetente: ' + Remetente);
        WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] - Destinatário: ' + Destinatario);
        WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] - Enviar notificação: ' + BoolToStr(EnviarNotificacao, True));
        // Verificar se deve enviar email
        if not EnviarNotificacao then
        begin
          WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Notificação por email desabilitada na configuração');
          Result := True; // Não é erro, apenas desabilitado
          Exit;
        end;
        // Verificar se tem configurações mínimas
        if (Trim(SMTP) = '') or (Trim(Remetente) = '') or (Trim(Destinatario) = '') then
        begin
          WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Configurações de email incompletas');
          Exit;
        end;
        // Configurar e enviar email usando a lógica que funcionou
        IdSMTP := TIdSMTP.Create(nil);
        IdMessage := TIdMessage.Create(nil);
        var LSocketSSL: TIdSSLIOHandlerSocketOpenSSL;
        try
          WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Configurações básicas do SMTP:');
          WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] - Host: ' + SMTP);
          WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] - Porta: ' + IntToStr(Porta));
          WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] - Username: ' + QryConfig.FieldByName('smtp_usuario').AsString);
          WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] - SSL: ' + BoolToStr(SSL, True));
          WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] - TLS: ' + BoolToStr(TLS, True));
          // Configurar SSL Handler (baseado no exemplo funcionando)
          LSocketSSL := TIdSSLIOHandlerSocketOpenSSL.Create(nil);
          try
            with LSocketSSL do
            begin
              with SSLOptions do
              begin
                Mode := sslmClient;
                Method := sslvTLSv1_2;
              end;
              Host := SMTP;
              Port := Porta;
            end;
            // Configurar SMTP (baseado no exemplo funcionando)
            with IdSMTP do
            begin
              IOHandler := LSocketSSL;
              Host := SMTP;
              Port := Porta;
              AuthType := satDefault;
              Username := QryConfig.FieldByName('smtp_usuario').AsString;
              Password := QryConfig.FieldByName('smtp_senha').AsString;
              UseTLS := utUseExplicitTLS;
            end;
            // Configurar mensagem
            IdMessage.From.Address := Remetente;
            IdMessage.From.Name := 'Sistema de Integração Estrada';
            IdMessage.Recipients.EMailAddresses := Destinatario;
            IdMessage.Subject := 'Notificação: Cliente com classe atualizada - ' + FormatDateTime('dd/mm/yyyy hh:nn:ss', Now);
            // Corpo do email
            CorpoEmail := 'Prezado,' + #13#10#13#10 +
                         'O cliente abaixo teve sua classe atualizada no sistema:' + #13#10#13#10 +
                         '**Dados do Cliente:**' + #13#10 +
                         '- CPF: ' + CPF + #13#10 +
                         '- Nome: ' + NomeCliente + #13#10 +
//                         '- Classe Anterior: ' + IntToStr(CodClasseAnterior) + #13#10 +
//                         '- Nova Classe: ' + IntToStr(CodClasseNovo) + #13#10 +
                         '- Data/Hora: ' + FormatDateTime('dd/mm/yyyy hh:nn:ss', Now) + #13#10#13#10 +
                         'Esta notificação foi gerada automaticamente pelo sistema de integração.' + #13#10#13#10 +
                         'Atenciosamente,' + #13#10 +
                         'Sistema de Integração Estrada';
            IdText := TIdText.Create(IdMessage.MessageParts);
            IdText.Body.Text := CorpoEmail;
                          IdText.ContentType := 'text/html;charset=utf-8';
            // Conectar e enviar
            WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Conectando ao servidor SMTP...');
            IdSMTP.Connect;
            IdSMTP.Authenticate;
            
            WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Enviando email de notificação...');
            IdSMTP.Send(IdMessage);
            WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Email enviado com sucesso para: ' + Destinatario);
            Result := True;
          finally
            LSocketSSL.Free;
          end;
        finally
          if IdSMTP.Connected then
            IdSMTP.Disconnect;
          IdSMTP.Free;
          IdMessage.Free;
        end;
      end
      else
      begin
        WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Nenhuma configuração ativa encontrada para email');
      end;
    finally
      QryConfig.Free;
    end;
  except
    on E: Exception do
    begin
      WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Erro ao enviar email de notificação: ' + E.Message);
      Result := False;
    end;
  end;
end;
