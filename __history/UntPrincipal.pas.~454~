        WriteLogFormatted('ERRO', '107', '[ATUALIZAR DATA EMPRESA] Nenhuma linha foi atualizada para empresa: ' + IntToStr(IdEmpresa));
        ConfigJSON.AddPair('success', TJSONBool.Create(False));
        ConfigJSON.AddPair('message', TJSONString.Create('Nenhuma linha foi atualizada'));
        ConfigJSON.AddPair('id_empresa', TJSONNumber.Create(IdEmpresa));
        ConfigJSON.AddPair('data_atualizada', TJSONString.Create(''));
      end;
    finally
      Query.Free;
    end;
    
  except
    on E: Exception do
    begin
      WriteLogFormatted('ERRO', '107', '[ATUALIZAR DATA EMPRESA] Erro ao atualizar data: ' + E.Message);
      ConfigJSON.AddPair('success', TJSONBool.Create(False));
