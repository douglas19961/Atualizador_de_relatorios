procedure TFrmPrincipal.integracaoentregapegoraro;
var
  QConsulta, QUpdate, QCaminho: TUniQuery;
  CaminhoArquivo: string;
  JSONRoot, JSONVenda, JSONProduto: TJSONObject;
  JSONVendas: TJSONArray;
  JSONString: string;
  CodLancFinanceiroAtual: Integer;
  CodLancFinanceiroAnterior: Integer;
  PrimeiraVenda: Boolean;
  JSONContent: string;
  DataInicio, DataFim: TDateTime;
begin
  try
    WriteLogFormatted('INFO', '1502', 'Iniciando geração do arquivo JSON');
    
    // Definir período de 1 mês atrás saté hoje
    DataFim := Now;
//    DataInicio := IncMonth(DataFim, -1); // 1 mês atráss
      DataInicio := DataFim - 7; // 7 dias atrás
    WriteLogFormatted('INFO', '1502', Format('Período: %s até %s',
      [FormatDateTime('yyyy-mm-dd', DataInicio), FormatDateTime('yyyy-mm-dd', DataFim)]));

    // Buscar caminho da tabela integracao.IntegracaoTXt (tipo VENDASPIT)
    QCaminho := TUniQuery.Create(nil);
    try
      QCaminho.Connection := CXClient;
      if not CXClient.Connected then CXClient.Connect;
      try
        QCaminho.SQL.Text := 'SELECT caminho_arquivo FROM integracao.IntegracaoTXt WHERE tipo_integracao = ''VENDASPIT'' AND COALESCE(ativo, true) = true LIMIT 1';
        QCaminho.Open;
        if not QCaminho.IsEmpty then
        begin
          CaminhoArquivo := Trim(QCaminho.FieldByName('caminho_arquivo').AsString);
          if CaminhoArquivo <> '' then
            WriteLogFormatted('DEBUG', '1502', Format('Caminho encontrado na tabela: %s', [CaminhoArquivo]))
          else
            CaminhoArquivo := ExtractFilePath(Application.ExeName) + 'entregas.json';
        end
        else
        begin
          CaminhoArquivo := ExtractFilePath(Application.ExeName) + 'entregas.json';
          WriteLogFormatted('DEBUG', '1502', 'Nenhum caminho configurado para VENDASPIT, usando padrão: ' + CaminhoArquivo);
        end;
      except
        on E: Exception do
        begin
          // Se a tabela não existir, criar e usar caminho padrão
          WriteLogFormatted('DEBUG', '1502', 'Tabela não existe, criando...');
          try
            try
              QCaminho.SQL.Text := 'CREATE SCHEMA integracao';
              QCaminho.Execute;
              WriteLogFormatted('DEBUG', '1502', 'Schema integracao criado');
            except
              on ESchema: Exception do
                if Pos('already exists', LowerCase(ESchema.Message)) > 0 then
                  WriteLogFormatted('DEBUG', '1502', 'Schema integracao já existe')
                else
                  raise;
            end;
            try
              QCaminho.SQL.Text := 'CREATE TABLE integracao.IntegracaoTXt (' +
                                  'id SERIAL PRIMARY KEY, ' +
                                  'tipo_integracao VARCHAR(50) NOT NULL, ' +
                                  'caminho_arquivo VARCHAR(500) NOT NULL, ' +
                                  'ativo BOOLEAN DEFAULT true, ' +
                                  'data_criacao TIMESTAMP DEFAULT CURRENT_TIMESTAMP, ' +
                                  'data_atualizacao TIMESTAMP DEFAULT CURRENT_TIMESTAMP' +
                                  ')';
              QCaminho.Execute;
              WriteLogFormatted('DEBUG', '1502', 'Tabela IntegracaoTXt criada');
            except
              on ETable: Exception do
                if Pos('already exists', LowerCase(ETable.Message)) > 0 then
                  WriteLogFormatted('DEBUG', '1502', 'Tabela IntegracaoTXt já existe')
                else
                  raise;
            end;
            QCaminho.SQL.Text := 'INSERT INTO integracao.IntegracaoTXt (tipo_integracao, caminho_arquivo) SELECT ''VENDASPIT'', ''C:\Program Files\Datacom\DtcSync\entregas.json'' WHERE NOT EXISTS (SELECT 1 FROM integracao.IntegracaoTXt WHERE tipo_integracao = ''VENDASPIT'')';
            QCaminho.Execute;
            CaminhoArquivo := 'C:\Program Files\Datacom\DtcSync\entregas.json';
            WriteLogFormatted('INFO', '1502', 'Tabela criada e caminho padrão configurado');
          except
            on E2: Exception do
            begin
              WriteLogFormatted('ERRO', '1502', Format('Erro ao criar tabela: %s', [E2.Message]));
              CaminhoArquivo := 'C:\Program Files\Datacom\DtcSync\entregas.json';
            end;
          end;
        end;
      end;
    finally
      QCaminho.Free;
    end;
    WriteLogFormatted('INFO', '1502', Format('Arquivo será salvo em: %s', [CaminhoArquivo]));

    // Verificar se arquivo existe e carregar conteúdo existente e
    JSONContent := '';
    if FileExists(CaminhoArquivo) then
    begin
      try
        JSONContent := TFile.ReadAllText(CaminhoArquivo, TEncoding.UTF8);
        WriteLogFormatted('INFO', '1502', 'Arquivo JSON existente carregado');
      except
        on E: Exception do
        begin
          WriteLogFormatted('AVISO', '1502', Format('Erro ao ler arquivo existente: %s. Criando novo arquivo.', [E.Message]));
          JSONContent := '';
        end;
      end;
    end;
    
    // Criar query para consulta
    QConsulta := TUniQuery.Create(nil);
    QUpdate := TUniQuery.Create(nil);
    try
      QConsulta.Connection := CXClient;
      QUpdate.Connection := CXClient;
      
      // Garantir conexão ativa
      if not CXClient.Connected then
      begin
        WriteLogFormatted('INFO', '1502', 'Conectando ao banco...');
        CXClient.Connect;
      end;
      
      // Query SQL conforme especificado com fsiltro de data
      QConsulta.SQL.Text :=
        'SELECT emp.identificacao, lf.cod_lanc_financeiro, lf.chave_acesso, case when lf.cod_LANCAMENTO_PADRAO = 825 then lf.cod_vendedor else lf.cod_pessoa end as cod_pessoa, ' +
        '       lf.valor AS valor_lancamento, lf.numero_documento, lf.data_inclusao, ' +
        '       case when lf.cod_LANCAMENTO_PADRAO = 825 then lf.valor else lp.valor end as valor_produto, (COALESCE(lp.quantidade, 1)) AS quantidade, case when lf.cod_LANCAMENTO_PADRAO = 825 then 99999999 else lp.cod_produto end as cod_produto, ' +
        '       COALESCE(TO_CHAR(lf.vendas_pit_data, ''YYYY-MM-DD'') || '' '' || lf.vendas_pit_hora, ''0000-00-00 00:00:00'') AS data_hora_pit, '+
        '       LEFT(COALESCE(lf.vendas_pit_prioridade, ''0''), 1) AS prioridade, ' +
        '       LEFT(COALESCE(lf.vendas_pit_forma_pgto, ''0''), 1) AS id_forma_de_pagamento, '+
        '       SUBSTRING(COALESCE(lf.vendas_pit_forma_pgto, ''1'') FROM 5) AS descricao_forma_de_pagamento, '+
        '       COALESCE(lf.vendas_pit_valor_areceber, 0 ) as valor_a_receber, '+
        '       case when lf.cod_LANCAMENTO_PADRAO = 825 then ''Credito de vendas bebidas'' else p.nome end as nome_produto, p.cod_barra, ' +
        '       pe.nome AS nome_pessoa, pe.identificacao, pe.endereco, ' +
        '       pe.numero, pe.uf, pe.cep, pe.telefone_comercial, pe.telefone_residencial, ' +
        '       m.nome AS nome_cidade ' +
        'FROM lancamentos_financeiros lf ' +
        'LEFT JOIN lancamentos_produtos lp ON lp.cod_lanc_financeiro = lf.cod_lanc_financeiro ' +
        'LEFT JOIN produtos p ON p.cod_produto = lp.cod_produto ' +
        'INNER JOIN pessoas pe  ON pe.cod_pessoa = CASE  WHEN lf.cod_LANCAMENTO_PADRAO = 825 THEN lf.cod_vendedor ELSE lf.cod_pessoa END ' +
        'INNER JOIN pessoas emp ON emp.cod_pessoa = lf.cod_empresa ' +
        'LEFT JOIN municipios m ON pe.cidade = m.cod_municipio ' +
        'WHERE lf.vendas_pit_interno IS NOT TRUE and vendas_pit_pdv = true' +
        ' AND nome_LANCAMENTO_PADRAO ilike (''%Venda%'')  '+
        '  AND date(lf.data_inclusao) between :data_inicio and :data_fim  and lf.situacao = 2  ' + //lf.situacao = 2 and lp.cancelado = false and
        'ORDER BY lf.cod_lanc_financeiro, lp.cod_produto';
      
      // Definir parâmetros de dasta
      QConsulta.ParamByName('data_inicio').AsDateTime := DataInicio;
      QConsulta.ParamByName('data_fim').AsDateTime := DataFim;
      
      QConsulta.Open;
      
      if QConsulta.IsEmpty then
      begin
        WriteLogFormatted('INFO', '1502', 'Nenhum registro encontrado para processar');
        Exit;
      end;
      
      WriteLogFormatted('INFO', '1502', Format('Registros encontrados: %d', [QConsulta.RecordCount]));
      
      // Inicializar JSON root
      if (JSONContent <> '') and (Trim(JSONContent) <> '') then
      begin
        try
          JSONRoot := TJSONObject.ParseJSONValue(JSONContent) as TJSONObject;
          if not Assigned(JSONRoot) then
          begin
            JSONRoot := TJSONObject.Create;
            JSONVendas := TJSONArray.Create;
            JSONRoot.AddPair('vendas', JSONVendas);
          end
          else
          begin
            if not JSONRoot.TryGetValue<TJSONArray>('vendas', JSONVendas) then
            begin
              JSONVendas := TJSONArray.Create;
              JSONRoot.AddPair('vendas', JSONVendas);
            end;
          end;
        except
          on E: Exception do
          begin
            WriteLogFormatted('AVISO', '1502', Format('Erro ao parsear JSON existente: %s. Criando novo.', [E.Message]));
            JSONRoot := TJSONObject.Create;
            JSONVendas := TJSONArray.Create;
            JSONRoot.AddPair('vendas', JSONVendas);
          end;
        end;
      end
      else
      begin
        JSONRoot := TJSONObject.Create;
        JSONVendas := TJSONArray.Create;
        JSONRoot.AddPair('vendas', JSONVendas);
      end;
      
      try
        CodLancFinanceiroAnterior := -1;
        PrimeiraVenda := True;
        JSONVenda := nil;
        
        // Processar cada registro
        while not QConsulta.Eof do
        begin
          CodLancFinanceiroAtual := QConsulta.FieldByName('cod_lanc_financeiro').AsInteger;
          
          // Novo bloco de venda (novo cod_lanc_financeiro)
          if CodLancFinanceiroAtual <> CodLancFinanceiroAnterior then
          begin
            // Se não é a primeira venda, finalizar a anterior
            if not PrimeiraVenda then
            begin
              // Marcar vendas_pit_interno como true para o cod_lanc_financeiro anterior
              try
                QUpdate.SQL.Text := 'UPDATE lancamentos_financeiros SET vendas_pit_interno = TRUE WHERE cod_lanc_financeiro = :cod_lanc_financeiro';
                QUpdate.ParamByName('cod_lanc_financeiro').AsInteger := CodLancFinanceiroAnterior;
                QUpdate.ExecSQL;
                WriteLogFormatted('DEBUG', '1502', Format('vendas_pit_interno marcado como TRUE para cod_lanc_financeiro: %d', [CodLancFinanceiroAnterior]));
              except
                on E: Exception do
                begin
                  WriteLogFormatted('ERRO', '1502', Format('Erro ao atualizar vendas_pit_interno: %s', [E.Message]));
                end;
              end;
            end;
            
            // Criar novo objeto de venda
            JSONVenda := TJSONObject.Create;
            JSONVenda.AddPair('cod_lanc_financeiro', TJSONNumber.Create(CodLancFinanceiroAtual));
            JSONVenda.AddPair('estabelecimento', TJSONString.Create(QConsulta.FieldByName('identificacao').AsString));
            JSONVenda.AddPair('chave_acesso', TJSONString.Create(QConsulta.FieldByName('chave_acesso').AsString));
            JSONVenda.AddPair('valor', TJSONNumber.Create(QConsulta.FieldByName('valor_lancamento').AsFloat));
            JSONVenda.AddPair('numero_documento', TJSONString.Create(QConsulta.FieldByName('numero_documento').AsString));
            JSONVenda.AddPair('data_inclusao', TJSONString.Create(FormatDateTime('yyyy-mm-dd hh:nn:ss', QConsulta.FieldByName('data_inclusao').AsDateTime)));
            JSONVenda.AddPair('data_entrega', TJSONString.Create((QConsulta.FieldByName('data_hora_pit').AsString)));
            JSONVenda.AddPair('prioridade', TJSONNumber.Create(QConsulta.FieldByName('prioridade').AsInteger));
            JSONVenda.AddPair('id_forma_de_pagamento', TJSONNumber.Create(QConsulta.FieldByName('id_forma_de_pagamento').AsInteger));
            JSONVenda.AddPair('descricao_forma_de_pagamento', TJSONString.Create((QConsulta.FieldByName('descricao_forma_de_pagamento').AsString)));
            JSONVenda.AddPair('valor_a_receber', TJSONString.Create((QConsulta.FieldByName('valor_a_receber').AsString)));


            // Cabeçalho com dados da pessoa (cod_pessoa - sempre 1 por venda)
            var JSONPessoa := TJSONObject.Create;
            JSONPessoa.AddPair('cod_pessoa', TJSONNumber.Create(QConsulta.FieldByName('cod_pessoa').AsInteger));
            JSONPessoa.AddPair('nome', TJSONString.Create(QConsulta.FieldByName('nome_pessoa').AsString));
            JSONPessoa.AddPair('identificacao', TJSONString.Create(QConsulta.FieldByName('identificacao').AsString));
            JSONPessoa.AddPair('endereco', TJSONString.Create(QConsulta.FieldByName('endereco').AsString));
            JSONPessoa.AddPair('numero', TJSONString.Create(QConsulta.FieldByName('numero').AsString));
            JSONPessoa.AddPair('uf', TJSONString.Create(QConsulta.FieldByName('uf').AsString));
            JSONPessoa.AddPair('cep', TJSONString.Create(QConsulta.FieldByName('cep').AsString));
            JSONPessoa.AddPair('telefone_comercial', TJSONString.Create(QConsulta.FieldByName('telefone_comercial').AsString));
            JSONPessoa.AddPair('telefone_residencial', TJSONString.Create(QConsulta.FieldByName('telefone_residencial').AsString));
            JSONPessoa.AddPair('nome_cidade', TJSONString.Create(QConsulta.FieldByName('nome_cidade').AsString));
            JSONVenda.AddPair('pessoa', JSONPessoa);
            
            // Array de produtos
            var JSONProdutos := TJSONArray.Create;
            JSONVenda.AddPair('produtos', JSONProdutos);
            
            // Adicionar produto atual
            JSONProduto := TJSONObject.Create;
            JSONProduto.AddPair('cod_produto', TJSONNumber.Create(QConsulta.FieldByName('cod_produto').AsInteger));
            JSONProduto.AddPair('nome', TJSONString.Create(QConsulta.FieldByName('nome_produto').AsString));
            JSONProduto.AddPair('valor', TJSONNumber.Create(QConsulta.FieldByName('valor_produto').AsFloat));
            JSONProduto.AddPair('quantidade', TJSONNumber.Create(QConsulta.FieldByName('quantidade').AsFloat));
            JSONProduto.AddPair('cod_barra', TJSONString.Create(QConsulta.FieldByName('cod_barra').AsString));
            JSONProdutos.AddElement(JSONProduto);
            
            // Adicionar venda ao array
            JSONVendas.AddElement(JSONVenda);
            
            CodLancFinanceiroAnterior := CodLancFinanceiroAtual;
            PrimeiraVenda := False;
          end
          else
          begin
            // Mesmo cod_lanc_financeiro - adicionar produto ao array existente
            // JSONVenda ainda aponta para o último objeto criado
            if Assigned(JSONVenda) then
            begin
              var JSONProdutos := JSONVenda.GetValue<TJSONArray>('produtos');
              if Assigned(JSONProdutos) then
              begin
                JSONProduto := TJSONObject.Create;
                JSONProduto.AddPair('cod_produto', TJSONNumber.Create(QConsulta.FieldByName('cod_produto').AsInteger));
                JSONProduto.AddPair('nome', TJSONString.Create(QConsulta.FieldByName('nome_produto').AsString));
                JSONProduto.AddPair('valor', TJSONNumber.Create(QConsulta.FieldByName('valor_produto').AsFloat));
                JSONProduto.AddPair('quantidade', TJSONNumber.Create(QConsulta.FieldByName('quantidade').AsFloat));
                JSONProduto.AddPair('cod_barra', TJSONString.Create(QConsulta.FieldByName('cod_barra').AsString));
                JSONProdutos.AddElement(JSONProduto);
              end;
            end;
          end;
          
          QConsulta.Next;
        end;
        
        // Marcar vendas_pit_interno como true para o último cod_lanc_financeiro
        if not PrimeiraVenda then
        begin
          try
            QUpdate.SQL.Text := 'UPDATE lancamentos_financeiros SET vendas_pit_interno = TRUE WHERE cod_lanc_financeiro = :cod_lanc_financeiro';
            QUpdate.ParamByName('cod_lanc_financeiro').AsInteger := CodLancFinanceiroAnterior;
            QUpdate.ExecSQL;
            WriteLogFormatted('DEBUG', '1502', Format('vendas_pit_interno marcado como TRUE para cod_lanc_financeiro: %d', [CodLancFinanceiroAnterior]));
          except
            on E: Exception do
            begin
              WriteLogFormatted('ERRO', '1502', Format('Erro ao atualizar vendas_pit_interno: %s', [E.Message]));
            end;
          end;
        end;
        
        // Converter JSON para string formatada com indentação
        JSONString := FormatJSON(JSONRoot);
        
        // Salvar arquivo JSON (reescrever completo com novas vendas)
        try
          TFile.WriteAllText(CaminhoArquivo, JSONString, TEncoding.UTF8);
          WriteLogFormatted('INFO', '1502', Format('Arquivo JSON salvo com sucesso: %s', [CaminhoArquivo]));
          WriteLogFormatted('INFO', '1502', Format('Total de vendas no JSON: %d', [JSONVendas.Count]));
        except
          on E: Exception do
          begin
            WriteLogFormatted('ERRO', '1502', Format('Erro ao salvar arquivo JSON: %s', [E.Message]));
            raise;
          end;
        end;
        
      finally
        JSONRoot.Free;
      end;
      
    finally
      QConsulta.Free;
      QUpdate.Free;
    end;
    
    WriteLogFormatted('INFO', '1502', 'Processamento concluído com sucesso');
    
  except
    on E: Exception do
    begin
      WriteLogFormatted('ERRO', '1502', Format('Erro: %s', [E.Message]));
    end;
  end;
end;
function TFrmPrincipal.FormatJSON(const JSONValue: TJSONValue; const Indent: Integer = 0): string;
var
  IndentStr: string;
  i: Integer;
  JSONObj: TJSONObject;
  JSONArr: TJSONArray;
  JSONPair: TJSONPair;
  FirstItem: Boolean;
begin
  Result := '';
  IndentStr := StringOfChar(' ', Indent * 2);
  
  if JSONValue is TJSONObject then
  begin
    JSONObj := JSONValue as TJSONObject;
    Result := Result + IndentStr + '{' + sLineBreak;
    FirstItem := True;
    
    for i := 0 to JSONObj.Count - 1 do
    begin
      JSONPair := JSONObj.Pairs[i];
      
      if not FirstItem then
        Result := Result + ',' + sLineBreak;
      
      Result := Result + IndentStr + '  "' + JSONPair.JsonString.Value + '": ';
      
      if JSONPair.JsonValue is TJSONObject then
        Result := Result + sLineBreak + FormatJSON(JSONPair.JsonValue, Indent + 1)
      else if JSONPair.JsonValue is TJSONArray then
        Result := Result + sLineBreak + FormatJSON(JSONPair.JsonValue, Indent + 1)
      else if JSONPair.JsonValue is TJSONString then
      begin
        // Escapar caracteres especiais na string JSON
        var EscapedValue := TJSONString(JSONPair.JsonValue).Value;
        EscapedValue := StringReplace(EscapedValue, '\', '\\', [rfReplaceAll]);
        EscapedValue := StringReplace(EscapedValue, '"', '\"', [rfReplaceAll]);
        EscapedValue := StringReplace(EscapedValue, #13#10, '\n', [rfReplaceAll]);
        EscapedValue := StringReplace(EscapedValue, #13, '\n', [rfReplaceAll]);
        EscapedValue := StringReplace(EscapedValue, #10, '\n', [rfReplaceAll]);
        EscapedValue := StringReplace(EscapedValue, #9, '\t', [rfReplaceAll]);
        Result := Result + '"' + EscapedValue + '"';
      end
      else if JSONPair.JsonValue is TJSONNumber then
        Result := Result + TJSONNumber(JSONPair.JsonValue).ToString
      else if JSONPair.JsonValue is TJSONBool then
        Result := Result + LowerCase(BoolToStr(TJSONBool(JSONPair.JsonValue).AsBoolean, True))
      else if JSONPair.JsonValue is TJSONNull then
        Result := Result + 'null'
      else
        Result := Result + JSONPair.JsonValue.ToString;
      
      FirstItem := False;
    end;
    
    Result := Result + sLineBreak + IndentStr + '}';
  end
  else if JSONValue is TJSONArray then
  begin
    JSONArr := JSONValue as TJSONArray;
    Result := Result + IndentStr + '[' + sLineBreak;
    FirstItem := True;
    
    for i := 0 to JSONArr.Count - 1 do
    begin
      if not FirstItem then
        Result := Result + ',' + sLineBreak;
      
      if JSONArr.Items[i] is TJSONObject then
        Result := Result + FormatJSON(JSONArr.Items[i], Indent + 1)
      else if JSONArr.Items[i] is TJSONArray then
        Result := Result + FormatJSON(JSONArr.Items[i], Indent + 1)
      else if JSONArr.Items[i] is TJSONString then
      begin
        // Escapar caracteres especiais na string JSON
        var EscapedValue := TJSONString(JSONArr.Items[i]).Value;
        EscapedValue := StringReplace(EscapedValue, '\', '\\', [rfReplaceAll]);
        EscapedValue := StringReplace(EscapedValue, '"', '\"', [rfReplaceAll]);
        EscapedValue := StringReplace(EscapedValue, #13#10, '\n', [rfReplaceAll]);
        EscapedValue := StringReplace(EscapedValue, #13, '\n', [rfReplaceAll]);
        EscapedValue := StringReplace(EscapedValue, #10, '\n', [rfReplaceAll]);
        EscapedValue := StringReplace(EscapedValue, #9, '\t', [rfReplaceAll]);
        Result := Result + IndentStr + '  "' + EscapedValue + '"';
      end
      else if JSONArr.Items[i] is TJSONNumber then
        Result := Result + IndentStr + '  ' + TJSONNumber(JSONArr.Items[i]).ToString
      else if JSONArr.Items[i] is TJSONBool then
        Result := Result + IndentStr + '  ' + LowerCase(BoolToStr(TJSONBool(JSONArr.Items[i]).AsBoolean, True))
      else if JSONArr.Items[i] is TJSONNull then
        Result := Result + IndentStr + '  null'
      else
        Result := Result + IndentStr + '  ' + JSONArr.Items[i].ToString;
      
      FirstItem := False;
    end;
    
    Result := Result + sLineBreak + IndentStr + ']';
  end
  else
  begin
    Result := JSONValue.ToString;
  end;
end;
