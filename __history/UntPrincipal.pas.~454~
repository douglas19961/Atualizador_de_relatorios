    if not CarregarConfiguracaoAPI(URLApi, Usuario, Senha, CodClasseDestino, LimiteRegistros) then
    begin
      WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Falha ao carregar configurações da API');
      Exit;
    end;
    URL := URLApi + '/webhook/login';
