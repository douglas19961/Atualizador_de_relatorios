procedure TFrmPrincipal.CriarEstruturaIntegracaoBanco;
var
  Q: TUniQuery;
  SchemaExiste, TabelaExiste, ViewExiste: Boolean;
begin
try
  Q := TUniQuery.Create(nil);
  try
    Q.Connection := CXClient;
    WriteLogFormatted('INFO', '126', 'Iniciando verificação e criação da estrutura de integração');
    // 1) Verifica se schema integracao existe
    Q.SQL.Clear;
    Q.SQL.Add('SELECT EXISTS(SELECT 1 FROM information_schema.schemata WHERE schema_name = ''integracao'')');
    Q.Open;
    SchemaExiste := Q.Fields[0].AsBoolean;
    Q.Close;
    if not SchemaExiste then
    begin
      Q.SQL.Clear;
      Q.SQL.Add('CREATE SCHEMA integracao AUTHORIZATION moduladb;');
    Q.Execute;
      WriteLogFormatted('INFO', '126', ' Schema integracao criado');
    end
    else
    begin
      WriteLogFormatted('INFO', '126', 'Schema integracao já existe, pulando criação');
    end;
    // 2) Verifica se tabela logo_relatorios existe
    Q.SQL.Clear;
    Q.SQL.Add('SELECT EXISTS(SELECT 1 FROM information_schema.tables WHERE table_schema = ''integracao'' AND table_name = ''verificacao_limpar_var_relatorios'')');
    Q.Open;
    TabelaExiste := Q.Fields[0].AsBoolean;
    Q.Close;
    if not TabelaExiste then
    begin
      Q.SQL.Clear;
      Q.SQL.Add('CREATE TABLE integracao.verificacao_limpar_var_relatorios (');
      Q.SQL.Add('  id bigserial NOT NULL,');
      Q.SQL.Add('  limpar_var_relatorios boolean NOT NULL DEFAULT false,');  // 👈 aqui adiciona o default
      Q.SQL.Add('  data_criacao timestamp without time zone DEFAULT now(),');
      Q.SQL.Add('  data_alteracao timestamp without time zone DEFAULT now(),');
      Q.SQL.Add('  CONSTRAINT verificacao_limpar_var_relatorios_relatorios_pkey PRIMARY KEY (id)');
      Q.SQL.Add(') WITH (OIDS=FALSE);');
      Q.Execute;
      Q.SQL.Clear;
      Q.SQL.Add('INSERT INTO integracao.verificacao_limpar_var_relatorios (limpar_var_relatorios)');
      Q.SQL.Add('SELECT false');
      Q.SQL.Add('WHERE NOT EXISTS (SELECT 1 FROM integracao.verificacao_limpar_var_relatorios);');
    Q.Execute;
      WriteLogFormatted('INFO', '127', 'Registro padrão garantido na tabela verificacao_limpar_var_relatorios');
    end
    else
    begin
      WriteLogFormatted('INFO', '126', 'Tabela verificacao_limpar_var_relatorios já existe, pulando criação');
    Q.SQL.Clear;
      Q.SQL.Add('INSERT INTO integracao.verificacao_limpar_var_relatorios (limpar_var_relatorios)');
