procedure TFrmPrincipal.ExtrairVersao;
var
  Versao: string;
  PosMonitor, PosTxt: Integer;
begin
  // Obter o texto do LabelVersao
  Versao := LabelVersao.Caption;
  // Encontrar a posição do texto "monitor" para poder pegar a versão
  PosMonitor := Pos('monitor', Versao);
  // Verificar se "monitor" foi encontrado
  if PosMonitor > 0 then
  begin
    // Encontrar a posição de ".txt" para excluir essa parte
    PosTxt := Pos('.txt', Versao);
    // Caso ".txt" seja encontrado, extrair a versão sem ".txt"
    if PosTxt > 0 then
    begin
      // A versão começa 8 caracteres após "monitor" e termina antes de ".txt"
      LabelVers.Caption := 'Versão do sistema: ' + Copy(Versao, PosMonitor + 7, PosTxt - (PosMonitor + 7));
    end
    else
    begin
      // Se ".txt" não for encontrado, pegar o restante da string após "monitor"
      LabelVers.Caption := 'Versão do sistema: ' + Copy(Versao, PosMonitor + 7, Length(Versao) - PosMonitor - 6);
    end;
  end
  else
  begin
    // Caso "monitor" não seja encontrado, exiba uma mensagem padrão ou o que achar adequadoo
    LabelVers.Caption := 'Versão não encontrada';
  end;
end;
