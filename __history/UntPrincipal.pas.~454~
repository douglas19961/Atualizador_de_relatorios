        CurrentDate := Now; // Pega a data/hora atuais
        // Primeiro exclui registros antigos
        qexclusao.SQL.Text :=
          'DELETE FROM monitor_ocorrencias WHERE id_modulo_ocorrencia = 7';
        qexclusao.ExecSQL;
        // Depois busca as empresas
        QSelect.SQL.Text :=
          'SELECT id_empresa_help, ' +
          '  TO_CHAR(data_atual_dos, ''YYYY-MM-DD'') || ' + QuotedStr(';') + ' || ' +
          '  TO_CHAR(data_atual_dos, ''HH24:MI:SS'') || ' + QuotedStr(';') + ' || ' +
//          'data_atual_dos, ' +
          'id_empresa_help || '';;;;;;;;não sincronizando backup dos;;;;;;;;;;'' AS info_concatenada,'+
          'CASE ' +
          '  WHEN EXTRACT(EPOCH FROM (now() - data_atual_dos)) / 3600 >= 1 ' +
          '   AND EXTRACT(EPOCH FROM (now() - data_atual_dos)) / 3600 <= 5 THEN 1 ' +
          '  WHEN EXTRACT(EPOCH FROM (now() - data_atual_dos)) / 3600 >= 5 ' +
          '   AND EXTRACT(EPOCH FROM (now() - data_atual_dos)) / 3600 <= 9 THEN 2 ' +
          '  WHEN EXTRACT(EPOCH FROM (now() - data_atual_dos)) / 3600 > 9 ' +
          '   AND EXTRACT(EPOCH FROM (now() - data_atual_dos)) / 3600 <= 12 THEN 3 ' +
          '  WHEN EXTRACT(EPOCH FROM (now() - data_atual_dos)) / 3600 > 12  ' +
          '  THEN 4 else 1 ' +
          'END AS prioridade ' +
          'FROM public.cadastro_empresas ' +
          'WHERE ativo IS TRUE ' +
          'AND EXTRACT(EPOCH FROM (now() - data_atual_dos)) / 3600 >= 1 ' +
          'ORDER BY data_atual_dos DESC';
        QSelect.Open;
        // Agora insere um novo registro para cada empresa
        while not QSelect.Eof do
        begin
          QInsert.SQL.Clear;
          QInsert.SQL.Add('INSERT INTO monitor_ocorrencias ');
          QInsert.SQL.Add('(id_empresa_help, ocorrencia, id_prioridade, id_modulo_ocorrencia, data_ocorrencia, hora)');
          QInsert.SQL.Add('VALUES (:id_empresa_help, :ocorrencia, :id_prioridade, :id_modulo_ocorrencia, :data_ocorrencia, :hora)');
          QInsert.ParamByName('id_empresa_help').AsInteger := QSelect.FieldByName('id_empresa_help').AsInteger;
          QInsert.ParamByName('ocorrencia').AsString := QSelect.FieldByName('info_concatenada').AsString;
          QInsert.ParamByName('id_prioridade').AsInteger := QSelect.FieldByName('prioridade').AsInteger;
          QInsert.ParamByName('id_modulo_ocorrencia').AsInteger := 7;
          QInsert.ParamByName('data_ocorrencia').AsDateTime := DateOf(CurrentDate);
          QInsert.ParamByName('hora').AsTime := TimeOf(CurrentDate);         // Só a hora         // Só a hora
          QInsert.ExecSQL;
          QSelect.Next;
        end;
          WriteLogFormatted('DEBUG', '116', '[BACKUP-DOS NÃO SINCRONIZADOS] inserido dados com sucesso');
    except
      on E: Exception do
      begin
        // Só grava o erro no log, não mostra na tela
        WriteLogFormatted('ERRO', '116', '[BACKUP-DOS NÃO SINCRONIZADOS] erro: ' + E.Message);
      end;
    end;
  finally
    QSelect.Free;
    QInsert.Free;
    qexclusao.Free;
  end;
  executarVariosBancos;
end;
