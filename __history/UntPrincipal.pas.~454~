procedure TFrmPrincipal.RemoverDoStartup(NomeChave: string);
var
  Reg: TRegistry;
begin
  Reg := TRegistry.Create;
  try
    Reg.RootKey := HKEY_CURRENT_USER;
    if Reg.OpenKey('Software\Microsoft\Windows\CurrentVersion\Run', False) then
    begin
      if Reg.ValueExists(NomeChave) then
        Reg.DeleteValue(NomeChave);
      Reg.CloseKey;
    end;
  finally
    Reg.Free;
  end;
end;
function TFrmPrincipal.ExisteNoStartup(NomeChave: string): Boolean;
var
  Reg: TRegistry;
begin
  Result := False;
  Reg := TRegistry.Create;
  try
    Reg.RootKey := HKEY_CURRENT_USER;
    if Reg.OpenKeyReadOnly('Software\Microsoft\Windows\CurrentVersion\Run') then
    begin
      Result := Reg.ValueExists(NomeChave);
      Reg.CloseKey;
    end;
  finally
    Reg.Free;
  end;
end;
