procedure TFrmPrincipal.CriarColunasParaPessoas;
var
  QueryBusca, QueryAux: TUniQuery;
  ListaCodPessoa: TStringList;
  ColunaAtual, CodPessoa: string;
  I: Integer;
begin
  QueryBusca := TUniQuery.Create(nil);
  QueryAux := TUniQuery.Create(nil);
  ListaCodPessoa := TStringList.Create;
  try
    QueryBusca.Connection := Cxclient;
    QueryAux.Connection := Cxclient;
    if not Cxclient.Connected then
      Cxclient.Connect;
    // Passo 1: Buscar todas as cod_pessoa válidas
    QueryBusca.SQL.Text :=
      'SELECT cod_pessoa FROM public.pessoas ' +
      'WHERE empresa_sistema IS TRUE AND reg_desativado IS FALSE;';
    QueryBusca.Open;
    while not QueryBusca.Eof do
    begin
      ListaCodPessoa.Add(QueryBusca.FieldByName('cod_pessoa').AsString);
      QueryBusca.Next;
    end;
    // Passo 2: Verificar colunas existentes na tabela
    QueryAux.SQL.Text :=
      'SELECT column_name FROM information_schema.columns ' +
      'WHERE table_schema = ''integracao'' AND table_name = ''conversoes'' ' +
      'AND column_name LIKE ''cod_empresa_%'';';
    QueryAux.Open;
    // Passo 3: Remover colunas que não estão mais na lista
    while not QueryAux.Eof do
    begin
      ColunaAtual := QueryAux.FieldByName('column_name').AsString;
      CodPessoa := Copy(ColunaAtual, Length('cod_empresa_') + 1);
      if ListaCodPessoa.IndexOf(CodPessoa) = -1 then
      begin
        // Coluna não corresponde mais a nenhuma cod_pessoa válida → apagar
        Cxclient.ExecSQL(Format(
          'ALTER TABLE integracao.conversoes DROP COLUMN IF EXISTS %s;',
          [ColunaAtual]
        ));
        WriteLogFormatted('INFO', '1500', 'Coluna removida: ' + ColunaAtual);
      end;
      QueryAux.Next;
    end;
    // Passo 4: Criar colunas que ainda não existem
    for I := 0 to ListaCodPessoa.Count - 1 do
    begin
      ColunaAtual := 'cod_empresa_' + ListaCodPessoa[I];
      QueryAux.SQL.Text :=
        'SELECT 1 FROM information_schema.columns ' +
        'WHERE table_schema = ''integracao'' AND table_name = ''conversoes'' ' +
        'AND column_name = :coluna;';
      QueryAux.Params[0].AsString := ColunaAtual;
      QueryAux.Open;
      if QueryAux.IsEmpty then
      begin
        Cxclient.ExecSQL(Format(
          'ALTER TABLE integracao.conversoes ADD COLUMN %s INTEGER;',
          [ColunaAtual]
        ));
        WriteLogFormatted('INFO', '1500', 'Coluna criada: ' + ColunaAtual);
      end;
    end;
//    ShowMessage('Sincronização de colunas concluída.');
  except
    on E: Exception do
    begin
//      ShowMessage('Erro: ' + E.Message);
      WriteLogFormatted('ERRO', '1500', 'Erro: ' + E.Message);
    end;
  end;
  QueryBusca.Free;
  QueryAux.Free;
  ListaCodPessoa.Free;
  AlimentarTabelaConversoes;
end;
procedure TFrmPrincipal.AlimentarTabelaConversoes;
var
  QueryBusca, QueryInserir, QueryVerifica: TUniQuery;
begin
  QueryBusca := TUniQuery.Create(nil);
  QueryInserir := TUniQuery.Create(nil);
  QueryVerifica := TUniQuery.Create(nil);
  try
    QueryBusca.Connection := Cxclient;
    QueryInserir.Connection := Cxclient;
    QueryVerifica.Connection := Cxclient;
    if not Cxclient.Connected then
      Cxclient.Connect;
    // Buscar dados do plano_contas
    QueryBusca.SQL.Text :=
      'SELECT id, cod_plano, nome ' +
      'FROM plano_contas ' +
      'ORDER BY id;';
    QueryBusca.Open;
    // SQL de verificação se cod_plano já existe
    QueryVerifica.SQL.Text :=
      'SELECT 1 FROM integracao.conversoes WHERE cod_plano = :cod_plano;';
    // SQL para inserção
    QueryInserir.SQL.Text :=
      'INSERT INTO integracao.conversoes (cod_plano, nome, id_plano) ' +
      'VALUES (:cod_plano, :nome, :id_plano);';
    while not QueryBusca.Eof do
    begin
      // Verifica se já existe cod_plano
      QueryVerifica.Close;
      QueryVerifica.ParamByName('cod_plano').AsInteger := QueryBusca.FieldByName('cod_plano').AsInteger;
      QueryVerifica.Open;
      if QueryVerifica.IsEmpty then
      begin
        QueryInserir.ParamByName('cod_plano').AsInteger := QueryBusca.FieldByName('cod_plano').AsInteger;
        QueryInserir.ParamByName('nome').AsString := QueryBusca.FieldByName('nome').AsString;
        QueryInserir.ParamByName('id_plano').AsString := QueryBusca.FieldByName('id').AsString;
        QueryInserir.ExecSQL;
      end;
      QueryBusca.Next;
    end;
          WriteLogFormatted('INFO', '1500', 'Dados da tabela plano_contas inseridos na tabela integracao.conversoes com sucesso.');
  except
    on E: Exception do
    begin
//      ShowMessage('Erro ao alimentar a tabela: ' + E.Message);
              WriteLogFormatted('ERRO', '1500', 'Erro: ' + E.Message);
    end;
  end;
  QueryBusca.Free;
  QueryInserir.Free;
  QueryVerifica.Free;
end;
procedure TFrmPrincipal.InserirModulosClient;
var
  QueryOrigem: TUniQuery;
  QueryDestino: TUniQuery;
  IdModulo: Integer;
  NomeModulo, NomeTabela: string;
begin
  WriteLogFormatted('INFO', '3', 'Iniciando inserção de módulos client');
  QueryOrigem := TUniQuery.Create(nil);
  QueryDestino := TUniQuery.Create(nil);
     conexaomodulos;
  try
    // Conexão de origem
    try
      if not ConexaoModulo.Connected then
      begin
        ConexaoModulo.Disconnect;
        Sleep(300);
        ConexaoModulo.Connect;
      end;
    except
      on E: Exception do
      begin
        WriteLogFormatted('ERRO', '3', 'Erro ao conectar origem: ' + E.Message);
        Exit;
      end;
    end;
    // Conexão de destino
    try
      if EhModoServer(ComboBox1) then
      begin
        if not CXserver.Connected then
        begin
          CXserver.Disconnect;
          Sleep(300);
          CXserver.Connect;
        end;
      end
      else if EhModoCliente(ComboBox1) then
      begin
        if not CXClient.Connected then
        begin
          CXClient.Disconnect;
          Sleep(300);
          CXClient.Connect;
        end;
      end;
    except
      on E: Exception do
      begin
        WriteLogFormatted('ERRO', '3', 'Erro ao conectar destino: ' + E.Message);
        Exit;
      end;
    end;
    // Consulta na origem
    QueryOrigem.Connection := ConexaoModulo;
    QueryOrigem.SQL.Text :=
      'SELECT m.id_modulo, m.nome_modulo ' +
      'FROM cadastro_modulos m ' +
      'INNER JOIN controle_sistema c ON c.id_modulo = m.id_modulo ' +
      'WHERE c.id_empresa_help = :id AND c.ativo IS TRUE ' +
      'ORDER BY m.nome_modulo';
    QueryOrigem.ParamByName('id').AsString := EdtEmpresaTodos.Text;
    try
      QueryOrigem.Open;
    except
      on E: Exception do
      begin
        WriteLogFormatted('ERRO', '3', 'Erro ao abrir consulta origem: ' + E.Message);
        Exit;
      end;
    end;
    if QueryOrigem.IsEmpty then
    begin
      WriteLogFormatted('INFO', '3', 'Nenhum módulo encontrado para a empresa.');
      Exit;
    end;
    // Definição da conexão e tabela de destino
    if EhModoServer(ComboBox1) then
    begin
      QueryDestino.Connection := CXserver;
      NomeTabela := 'config_server_dtc';
    end
    else
    begin
      QueryDestino.Connection := CXClient;
      NomeTabela := 'config_dtc';
    end;
    // Deleta dados antigos
    QueryDestino.SQL.Text := 'DELETE FROM ' + NomeTabela + ' WHERE id_empresa = :id_empresa';
    QueryDestino.ParamByName('id_empresa').AsString := EdtEmpresaTodos.Text;
    try
      QueryDestino.ExecSQL;
    except
      on E: Exception do
      begin
        WriteLogFormatted('ERRO', '3', 'Erro ao deletar registros antigos: ' + E.Message);
        Exit;
      end;
    end;
    // Inserção dos novos registros
    while not QueryOrigem.Eof do
    begin
      if not QueryOrigem.FieldByName('id_modulo').IsNull then
        IdModulo := QueryOrigem.FieldByName('id_modulo').AsInteger
      else
        IdModulo := 0;
      NomeModulo := QueryOrigem.FieldByName('nome_modulo').AsString;
      QueryDestino.SQL.Text :=
        'INSERT INTO ' + NomeTabela + ' (id_modulo, nome_modulo, id_empresa) ' +
        'VALUES (:id_modulo, :nome_modulo, :id_empresa)';
      QueryDestino.ParamByName('id_modulo').AsInteger := IdModulo;
      QueryDestino.ParamByName('nome_modulo').AsString := NomeModulo;
      QueryDestino.ParamByName('id_empresa').AsString := EdtEmpresaTodos.Text;
      try
        QueryDestino.ExecSQL;
      except
        on E: Exception do
        begin
          WriteLogFormatted('ERRO', '3', '[INSERÇÃO MODULOS] Erro ao inserir módulo "' + NomeModulo + '": ' + E.Message);
        end;
      end;
      QueryOrigem.Next;
    end;
          WriteLogFormatted('INFO', '3', '[INSERÇÃO MODULOS] Módulos inseridos com sucesso!');
    MemoLogServer.Lines.Add('[INSERÇÃO MODULOS] Módulos inseridos com sucesso!');
  except
    on E: Exception do
    begin
      WriteLogFormatted('ERRO', '3', '[INSERÇÃO MODULOS] Erro inesperado: ' + E.Message);
      MemoLogServer.Lines.Add('[INSERÇÃO MODULOS] Erro inesperado: ' + E.Message);
    end;
  end;
  QueryOrigem.Free;
  QueryDestino.Free;
  ConexaoModulo.Connected:=false;
end;
procedure TFrmPrincipal.SalvarConfiguracao;
var
  CXClient, CXServer: TUniConnection;
  Query: TUniQuery;
  ExisteRegistro: Boolean;
begin
  begin
  if EhModoCliente(ComboBox1) then
      begin
      CXClient := TUniConnection.Create(nil);
      Query := TUniQuery.Create(nil);
      try
          // Configuração da conexão com o banco do CLIENT
          CXClient.ProviderName := 'PostgreSQL';
          CXClient.SpecificOptions.Values['CharSet'] := 'UTF8';
          CXClient.Server := IP_DB_Client_Cliente.text;
          CXClient.Database := Nome_DB_Client_cliente.Text;
          CXClient.Username := Usuario_DB_Client_Cliente.text;
          CXClient.Password := Senha_DB_Client_Cliente.text;
          if Porta_DB_Client_Cliente.text <> '' then
            CXClient.Port := StrToIntDef(Porta_DB_Client_Cliente.text, 5432)
          else
            CXClient.Port := 5432; // Porta padrão do PostgreSQL
          CXClient.LoginPrompt := False;
          CXClient.Connected := True;
          if not CXClient.Connected then
            raise Exception.Create('Erro ao conectar ao banco de dados do Client!');
          // Criar a tabela se não existir
          Query.Connection := CXClient;
          Query.SQL.Text :=
            'CREATE TABLE IF NOT EXISTS Config_DTC (' +
            '  ID SERIAL PRIMARY KEY, ' +
            '  Nome_DB_Cliente VARCHAR(255), ' +
            '  IP_DB_Cliente VARCHAR(255), ' +
            '  Usuario_DB_Cliente VARCHAR(255), ' +
            '  Porta_DB_Cliente VARCHAR(10), ' +
            '  Senha_DB_Cliente VARCHAR(255), ' +
            '  Nome_DB_Client VARCHAR(255), ' +
            '  IP_DB_Client VARCHAR(255), ' +
            '  Usuario_DB_Client VARCHAR(255), ' +
            '  Porta_DB_Client VARCHAR(10), ' +
            '  Senha_DB_Client VARCHAR(255), ' +
            '  ID_Client VARCHAR(50) UNIQUE, ' +
            '  CNPJ_Client VARCHAR(50), ' +
            '  id_modulo INTEGER, ' +
            '  nome_modulo VARCHAR(50), ' +
            '  id_empresa VARCHAR(255) ' +
            ');';
          Query.Execute;
          // Verificar se o ID_Client já existe na tabela
          Query.SQL.Text := 'SELECT COUNT(*) FROM Config_DTC WHERE ID_Client = :IDClient';
          Query.ParamByName('IDClient').AsString := EdtEmpresaTodos.text;
          Query.Open;
          ExisteRegistro := Query.Fields[0].AsInteger > 0;
          if ExisteRegistro then
          begin
            // Atualizar os dados se o ID já existir
            Query.SQL.Text :=
              'UPDATE Config_DTC SET ' +
              '  Nome_DB_Cliente = :NomeDBCliente, IP_DB_Cliente = :IPCliente, ' +
              '  Usuario_DB_Cliente = :UsuarioCliente, Porta_DB_Cliente = :PortaCliente, Senha_DB_Cliente = :SenhaCliente, ' +
              '  Nome_DB_Client = :NomeDBClient, IP_DB_Client = :IPClient, ' +
              '  Usuario_DB_Client = :UsuarioClient, Porta_DB_Client = :PortaClient, Senha_DB_Client = :SenhaClient, ' +
              '  CNPJ_Client = :CNPJClient ' +
              'WHERE ID_Client = :IDClient';
          end
          else
          begin
            // Inserir um novo registro se não existir
            Query.SQL.Text :=
              'INSERT INTO Config_DTC (' +
              '  Nome_DB_Cliente, IP_DB_Cliente, Usuario_DB_Cliente, Porta_DB_Cliente, Senha_DB_Cliente, ' +
              '  Nome_DB_Client, IP_DB_Client, Usuario_DB_Client, Porta_DB_Client, Senha_DB_Client, ' +
              '  ID_Client, CNPJ_Client ' +
              ') VALUES (' +
