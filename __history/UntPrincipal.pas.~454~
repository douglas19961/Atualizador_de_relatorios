          WriteLogFormatted('INFO', '1', '[HTTP SERVER] Info Hardware: ' + InfoHardware);
          
          // Estabelecer conexão
          conexaomodulos;
          
          // Validar conexão
          if not Assigned(ConexaoModulo) or not ConexaoModulo.Connected then
          begin
            WriteLogFormatted('ERRO', '1', '[HTTP SERVER] ConexaoModulo não está conectada após conexaomodulos');
            AResponseInfo.ContentType := 'application/json; charset=utf-8';
            AResponseInfo.ContentText := '{"success":false,"message":"Conexão com banco não está ativa"}';
            AResponseInfo.ResponseNo := 500;
            Exit;
          end;
          
          WriteLogFormatted('INFO', '1', '[HTTP SERVER] Conexão estabelecida. Atualizando hardware...');
          
          // Preparar query de atualização
          var QUpdate := TUniQuery.Create(nil);
          try
            QUpdate.Connection := ConexaoModulo;
            QUpdate.SQL.Text := 
              'UPDATE cadastro_empresas SET info_hardware = :info_hardware, data_atualizada = CURRENT_TIMESTAMP ' +
              'WHERE id_empresa_help = :id_empresa_help';
            QUpdate.ParamByName('info_hardware').AsString := InfoHardware;
            QUpdate.ParamByName('id_empresa_help').AsInteger := IdEmpresaHardware;
            
            QUpdate.ExecSQL;
            
            if QUpdate.RowsAffected > 0 then
            begin
              WriteLogFormatted('INFO', '1', '[HTTP SERVER] Hardware atualizado com sucesso. RowsAffected: ' + IntToStr(QUpdate.RowsAffected));
              AResponseInfo.ContentType := 'application/json; charset=utf-8';
              AResponseInfo.ContentText := '{"success":true,"message":"Hardware atualizado com sucesso","id_empresa":' + IntToStr(IdEmpresaHardware) + '}';
              AResponseInfo.ResponseNo := 200;
            end
            else
            begin
              WriteLogFormatted('WARN', '1', '[HTTP SERVER] Nenhuma empresa encontrada com id_empresa_help: ' + IntToStr(IdEmpresaHardware));
              AResponseInfo.ContentType := 'application/json; charset=utf-8';
              AResponseInfo.ContentText := '{"success":false,"message":"Empresa não encontrada","id_empresa":' + IntToStr(IdEmpresaHardware) + '}';
              AResponseInfo.ResponseNo := 404;
            end;
          finally
            QUpdate.Free;
          end;
          
        finally
          RequestJSON.Free;
        end;
        
      except
        on E: Exception do
        begin
          WriteLogFormatted('ERRO', '1', '[HTTP SERVER] Erro ao processar hardware-empresa: ' + E.Message);
          AResponseInfo.ContentType := 'application/json; charset=utf-8';
          AResponseInfo.ContentText := '{"success":false,"message":"Erro ao processar: ' + E.Message + '"}';
          AResponseInfo.ResponseNo := 500;
        end;
      end;
      Exit;
    end;
    
    // Verificar se é POST para /api/versao-sistema
    if (ARequestInfo.Command = 'POST') and (URI = '/api/versao-sistema') then
    begin
      WriteLogFormatted('INFO', '1', '[HTTP SERVER] Processando POST para versao-sistema');
      
      // Obter o corpo da requisição
      RequestBody := '';
      
      if Assigned(ARequestInfo.PostStream) and (ARequestInfo.PostStream.Size > 0) then
      begin
        try
          ARequestInfo.PostStream.Position := 0;
          var Bytes: TBytes;
          SetLength(Bytes, ARequestInfo.PostStream.Size);
          ARequestInfo.PostStream.ReadBuffer(Bytes[0], ARequestInfo.PostStream.Size);
          RequestBody := TEncoding.UTF8.GetString(Bytes);
        except
          on E: Exception do
          begin
            WriteLogFormatted('ERRO', '1', '[HTTP SERVER] Erro ao ler PostStream: ' + E.Message);
            RequestBody := '';
          end;
        end;
      end;
      
      if RequestBody = '' then
        RequestBody := ARequestInfo.FormParams;
        
      WriteLogFormatted('INFO', '1', '[HTTP SERVER] Corpo da requisição versao-sistema: ' + RequestBody);
      
      if RequestBody = '' then
      begin
        WriteLogFormatted('ERRO', '1', '[HTTP SERVER] Corpo da requisição vazio');
        AResponseInfo.ContentType := 'application/json; charset=utf-8';
        AResponseInfo.ContentText := '{"success":false,"message":"Corpo da requisição vazio"}';
        AResponseInfo.ResponseNo := 400;
        Exit;
      end;
      
      try
        RequestJSON := TJSONObject.ParseJSONValue(RequestBody) as TJSONObject;
        if not Assigned(RequestJSON) then
        begin
          WriteLogFormatted('ERRO', '1', '[HTTP SERVER] JSON inválido no corpo da requisição');
          AResponseInfo.ContentType := 'application/json; charset=utf-8';
          AResponseInfo.ContentText := '{"success":false,"message":"JSON inválido no corpo da requisição"}';
          AResponseInfo.ResponseNo := 400;
          Exit;
        end;
        
        try
          // Extrair campos obrigatórios
          var IdEmpresaVersao: Integer;
          var Versao: string;
          var Vencimentos: string;
          var VersaoDtcSync: string;
          
          if not RequestJSON.TryGetValue<Integer>('id_empresa_help', IdEmpresaVersao) then
          begin
            WriteLogFormatted('ERRO', '1', '[HTTP SERVER] Campo id_empresa_help não encontrado no JSON');
            AResponseInfo.ContentType := 'application/json; charset=utf-8';
            AResponseInfo.ContentText := '{"success":false,"message":"Campo id_empresa_help não encontrado no JSON"}';
            AResponseInfo.ResponseNo := 400;
            Exit;
          end;
          
          // Campos opcionais - usar valores padrão se não fornecidos
          if not RequestJSON.TryGetValue<string>('versao', Versao) then
            Versao := '';
          if not RequestJSON.TryGetValue<string>('vencimentos', Vencimentos) then
            Vencimentos := '';
          if not RequestJSON.TryGetValue<string>('versaodtcsync', VersaoDtcSync) then
            VersaoDtcSync := '';
          
          WriteLogFormatted('INFO', '1', '[HTTP SERVER] ID Empresa: ' + IntToStr(IdEmpresaVersao));
          WriteLogFormatted('INFO', '1', '[HTTP SERVER] Versão: ' + Versao);
          WriteLogFormatted('INFO', '1', '[HTTP SERVER] Vencimentos: ' + Vencimentos);
          WriteLogFormatted('INFO', '1', '[HTTP SERVER] Versão DTC Sync: ' + VersaoDtcSync);
          
          // Estabelecer conexão
          conexaomodulos;
          
          // Validar conexão
          if not Assigned(ConexaoModulo) or not ConexaoModulo.Connected then
          begin
            WriteLogFormatted('ERRO', '1', '[HTTP SERVER] ConexaoModulo não está conectada após conexaomodulos');
            AResponseInfo.ContentType := 'application/json; charset=utf-8';
            AResponseInfo.ContentText := '{"success":false,"message":"Conexão com banco não está ativa"}';
            AResponseInfo.ResponseNo := 500;
            Exit;
          end;
          
          WriteLogFormatted('INFO', '1', '[HTTP SERVER] Conexão estabelecida. Processando versão...');
          
          // Preparar queries
          var QSelect := TUniQuery.Create(nil);
          var QExec := TUniQuery.Create(nil);
          try
            QSelect.Connection := ConexaoModulo;
            QExec.Connection := ConexaoModulo;
            
            // Verificar se já existe registro para a empresa
            QSelect.SQL.Text := 'SELECT id_versao_sist FROM versao_sistema WHERE id_empresa_help = :id_empresa_help';
            QSelect.ParamByName('id_empresa_help').AsInteger := IdEmpresaVersao;
            QSelect.Open;
            
            if QSelect.IsEmpty then
            begin
              // INSERT - novo registro
              WriteLogFormatted('INFO', '1', '[HTTP SERVER] Inserindo nova versão para empresa: ' + IntToStr(IdEmpresaVersao));
              QExec.SQL.Text := 
                'INSERT INTO versao_sistema (id_empresa_help, versao, vencimentos, versaodtcsync) ' +
                'VALUES (:id_empresa_help, :versao, :vencimentos, :versaodtcsync)';
            end
            else
            begin
              // UPDATE - registro existente
              WriteLogFormatted('INFO', '1', '[HTTP SERVER] Atualizando versão para empresa: ' + IntToStr(IdEmpresaVersao));
              QExec.SQL.Text := 
                'UPDATE versao_sistema SET versao = :versao, vencimentos = :vencimentos, versaodtcsync = :versaodtcsync ' +
                'WHERE id_empresa_help = :id_empresa_help';
            end;
            
            // Configurar parâmetros
            QExec.ParamByName('id_empresa_help').AsInteger := IdEmpresaVersao;
            QExec.ParamByName('versao').AsString := Versao;
            QExec.ParamByName('vencimentos').AsString := Vencimentos;
            QExec.ParamByName('versaodtcsync').AsString := VersaoDtcSync;
            
            QExec.ExecSQL;
            
            WriteLogFormatted('INFO', '1', '[HTTP SERVER] Versão processada com sucesso. RowsAffected: ' + IntToStr(QExec.RowsAffected));
            
            // Responder sucesso
            AResponseInfo.ContentType := 'application/json; charset=utf-8';
            AResponseInfo.ContentText := '{"success":true,"message":"Versão processada com sucesso","id_empresa_help":' + IntToStr(IdEmpresaVersao) + '}';
            AResponseInfo.ResponseNo := 200;
            
          finally
            QSelect.Free;
            QExec.Free;
          end;
          
        finally
          RequestJSON.Free;
        end;
        
      except
        on E: Exception do
        begin
          WriteLogFormatted('ERRO', '1', '[HTTP SERVER] Erro ao processar versao-sistema: ' + E.Message);
          AResponseInfo.ContentType := 'application/json; charset=utf-8';
          AResponseInfo.ContentText := '{"success":false,"message":"Erro ao processar: ' + E.Message + '"}';
          AResponseInfo.ResponseNo := 500;
        end;
      end;
      Exit;
    end;
    
    // Verificar se é GET para /api/versao-empresa?id_empresa={id}
    if (ARequestInfo.Command = 'GET') and (URI = '/api/versao-empresa') then
    begin
      var IdParam := ARequestInfo.Params.Values['id_empresa'];
      if (IdParam = '') or (not TryStrToInt(IdParam, IdEmpresa)) then
      begin
        WriteLogFormatted('ERRO', '1', '[HTTP SERVER] Parâmetro id_empresa inválido ou ausente');
        AResponseInfo.ContentType := 'application/json; charset=utf-8';
        AResponseInfo.ContentText := '{"success":false,"message":"Parâmetro id_empresa inválido ou ausente"}';
        AResponseInfo.ResponseNo := 400;
        Exit;
      end;
      
      WriteLogFormatted('INFO', '1', '[HTTP SERVER] Processando GET /api/versao-empresa para id_empresa: ' + IntToStr(IdEmpresa));
      ConfigJSON := ConsultarVersaoEmpresa(IdEmpresa);
      if not Assigned(ConfigJSON) then
        raise Exception.Create('ConsultarVersaoEmpresa retornou nil');
      
      JSONString := ConfigJSON.ToJSON;
      AResponseInfo.ContentType := 'application/json; charset=utf-8';
      AResponseInfo.ContentText := JSONString;
      AResponseInfo.ResponseNo := 200;
      Exit;
    end;

    // GET /api/modulos?id_modulo=0 (todos) ou id_modulo=N (um módulo) — fn_buscar_modulos_usuarios_db
    if (ARequestInfo.Command = 'GET') and
       ((URI = '/api/modulos') or URI.StartsWith('/api/modulos?')) then
    begin
      var IdModuloParam := ARequestInfo.Params.Values['id_modulo'];
      if IdModuloParam = '' then
        IdModuloParam := '0';
      if not TryStrToInt(IdModuloParam, IdModuloQuery) then
      begin
        WriteLogFormatted('ERRO', '1', '[HTTP SERVER] Parâmetro id_modulo inválido');
        AResponseInfo.ContentType := 'application/json; charset=utf-8';
        AResponseInfo.ContentText := '{"success":false,"message":"Parâmetro id_modulo inválido"}';
        AResponseInfo.ResponseNo := 400;
        Exit;
      end;
      WriteLogFormatted('INFO', '1', '[HTTP SERVER] GET /api/modulos id_modulo=' + IntToStr(IdModuloQuery));
      ConfigJSON := BuscarModulosUsuariosDB(IdModuloQuery);
      if not Assigned(ConfigJSON) then
        raise Exception.Create('BuscarModulosUsuariosDB retornou nil');
      JSONString := ConfigJSON.ToJSON;
      AResponseInfo.ContentType := 'application/json; charset=utf-8';
      AResponseInfo.ContentText := JSONString;
      AResponseInfo.ResponseNo := 200;
      Exit;
    end;
    
    // Verificar se é GET para /api/config/{numero}
    if (ARequestInfo.Command = 'GET') and URI.StartsWith('/api/config/') then
    begin
      // Extrair o número da empresa módulo da URL
      PathParts := URI.Split(['/']);
      if Length(PathParts) >= 4 then
      begin
        if TryStrToInt(PathParts[3], NumeroEmpresaModuloDTC) then
        begin
          WriteLogFormatted('INFO', '1', '[HTTP SERVER] Extraído NumeroEmpresaModuloDTC: ' + IntToStr(NumeroEmpresaModuloDTC));
          
          // Chamar a função serverApiDTC
          WriteLogFormatted('INFO', '1', '[HTTP SERVER] Chamando serverApiDTC...');
          ConfigJSON := serverApiDTC(NumeroEmpresaModuloDTC);
          
          WriteLogFormatted('INFO', '1', '[HTTP SERVER] serverApiDTC retornou. Verificando ConfigJSON...');
          if not Assigned(ConfigJSON) then
          begin
            WriteLogFormatted('ERRO', '1', '[HTTP SERVER] ConfigJSON é nil!');
            raise Exception.Create('ConfigJSON retornou nil');
          end;
          
          // Converter para string JSON
          WriteLogFormatted('INFO', '1', '[HTTP SERVER] Convertendo ConfigJSON para string...');
          JSONString := ConfigJSON.ToJSON;
          WriteLogFormatted('INFO', '1', '[HTTP SERVER] JSONString gerada. Tamanho: ' + IntToStr(Length(JSONString)));
          WriteLogFormatted('INFO', '1', '[HTTP SERVER] JSONString: ' + JSONString);
          
          // Configurar resposta
          AResponseInfo.ContentType := 'application/json; charset=utf-8';
          AResponseInfo.ContentText := JSONString;
          AResponseInfo.ResponseNo := 200;
          
          WriteLogFormatted('INFO', '1', '[HTTP SERVER] Resposta enviada com sucesso para NumeroEmpresaModuloDTC: ' + IntToStr(NumeroEmpresaModuloDTC));
        end
        else
        begin
          // Parâmetro inválido
          AResponseInfo.ContentType := 'application/json; charset=utf-8';
          AResponseInfo.ContentText := '{"success":false,"message":"Parâmetro inválido","data":[],"total":0,"numeroempresamodulo":0}';
          AResponseInfo.ResponseNo := 400;
          WriteLogFormatted('ERRO', '1', '[HTTP SERVER] Parâmetro inválido na URL: ' + PathParts[3]);
        end;
      end
      else
      begin
        // URL malformada
        AResponseInfo.ContentType := 'application/json; charset=utf-8';
        AResponseInfo.ContentText := '{"success":false,"message":"URL malformada","data":[],"total":0,"numeroempresamodulo":0}';
        AResponseInfo.ResponseNo := 404;
        WriteLogFormatted('ERRO', '1', '[HTTP SERVER] URL malformada: ' + URI);
      end;
    end
    else
    begin
      // Rota não encontrada
      AResponseInfo.ContentType := 'application/json; charset=utf-8';
      AResponseInfo.ContentText := '{"success":false,"message":"Rota não encontrada","data":[],"total":0,"numeroempresamodulo":0}';
      AResponseInfo.ResponseNo := 404;
      WriteLogFormatted('ERRO', '1', '[HTTP SERVER] Rota não encontrada: ' + URI);
    end;
    
  except
    on E: Exception do
    begin
      WriteLogFormatted('ERRO', '1', '[HTTP SERVER] Erro interno: ' + E.Message);
      AResponseInfo.ContentType := 'application/json; charset=utf-8';
      AResponseInfo.ContentText := '{"success":false,"message":"Erro interno do servidor","data":[],"total":0,"numeroempresamodulo":0}';
      AResponseInfo.ResponseNo := 500;
    end;
  end;
  ConexaoModulo.Connected := false;
end;
procedure TFrmPrincipal.ChamarAPIAtualizarEmpresa;
var
  IniFile: TIniFile;
  IdClient: string;
  HttpClient: TNetHTTPClient;
  RequestBody: TStringStream;
  Response: IHTTPResponse;
  JSONResponse: TJSONObject;
  ConfigPath: string;
begin
  try
    // Carregar ID_Client do arquivo de configuração
    ConfigPath := ExtractFilePath(ParamStr(0)) + 'ConfigServer.ini';
    
    if not FileExists(ConfigPath) then
    begin
      WriteLogFormatted('ERRO', '106', '[API CLIENTE] Arquivo de configuração não encontrado: ' + ConfigPath);
      Exit;
    end;
    
    IniFile := TIniFile.Create(ConfigPath);
    try
      IdClient := IniFile.ReadString('Config', 'ID_Client', '');
      
      if IdClient = '' then
      begin
        WriteLogFormatted('ERRO', '106', '[API CLIENTE] ID_Client não encontrado no arquivo de configuração');
        Exit;
      end;
      
      WriteLogFormatted('INFO', '106', '[API CLIENTE] ID_Client carregado: ' + IdClient);
      
    finally
      IniFile.Free;
    end;
    
    // Criar cliente HTTP
    HttpClient := TNetHTTPClient.Create(nil);
    try
      // Configurar autenticação Basic
      var AuthString := API_USERNAME + ':' + API_PASSWORD;
      var EncodedAuth := TNetEncoding.Base64.Encode(AuthString);
      
      // Preparar corpo da requisição
      var JSONBody := '{"id_empresa":' + IdClient + '}';
      RequestBody := TStringStream.Create(JSONBody, TEncoding.UTF8);
      
      try
        // Configurar headers
        HttpClient.CustomHeaders['Authorization'] := 'Basic ' + EncodedAuth;
        HttpClient.CustomHeaders['Content-Type'] := 'application/json';
        
        WriteLogFormatted('INFO', '106', '[API CLIENTE] Enviando requisição para: ' + GetAPIServerURL(ComboBox1) + '/api/atualizar-empresa');
        WriteLogFormatted('INFO', '106', '[API CLIENTE] Corpo da requisição: ' + JSONBody);
        
        // Fazer a requisição POST
        Response := HttpClient.Post(GetAPIServerURL(ComboBox1) + '/api/atualizar-empresa', RequestBody);
        
        if Assigned(Response) then
        begin
          WriteLogFormatted('INFO', '106', '[API CLIENTE] Resposta recebida. Status: ' + IntToStr(Response.StatusCode));
          WriteLogFormatted('INFO', '106', '[API CLIENTE] Conteúdo da resposta: ' + Response.ContentAsString);
          
          // Tentar fazer parse da resposta JSON
          try
            JSONResponse := TJSONObject.ParseJSONValue(Response.ContentAsString) as TJSONObject;
            if Assigned(JSONResponse) then
            begin
              var Success: Boolean;
              var Message: string;
              
              if JSONResponse.TryGetValue<Boolean>('success', Success) then
              begin
                if Success then
                  WriteLogFormatted('INFO', '106', '[API CLIENTE] API executada com sucesso para empresa ID: ' + IdClient)
                else
                  WriteLogFormatted('ERRO', '106', '[API CLIENTE] API retornou erro para empresa ID: ' + IdClient);
              end;
              
              if JSONResponse.TryGetValue<string>('message', Message) then
                WriteLogFormatted('INFO', '106', '[API CLIENTE] Mensagem: ' + Message);
              
              JSONResponse.Free;
            end;
          except
            on E: Exception do
              WriteLogFormatted('ERRO', '106', '[API CLIENTE] Erro ao fazer parse da resposta JSON: ' + E.Message);
          end;
        end
        else
        begin
          WriteLogFormatted('ERRO', '106', '[API CLIENTE] Nenhuma resposta recebida do servidor');
        end;
        
      finally
        RequestBody.Free;
      end;
      
    finally
      HttpClient.Free;
//      Versaosigilo;
    end;
  except
    on E: Exception do
    begin
      WriteLogFormatted('ERRO', '106', '[API CLIENTE] Erro ao chamar API: ' + E.Message);
    end;
  end;
end;
function TFrmPrincipal.ObterMaxLogSizeBytes: Int64;
var
  IniFile: TIniFile;
  ValorStr: string;
  Numero: Int64;
  Unidade: string;
begin
  Result := 5 * 1024 * 1024; // default 5MB
  IniFile := TIniFile.Create(ExtractFilePath(ParamStr(0)) + 'ConfigServer.ini');
  try
    ValorStr := UpperCase(Trim(IniFile.ReadString('Logs', 'MaxLogSize', '5MB')));
    if ValorStr = '' then Exit;
    Unidade := '';
    Numero := 0;
    if (Length(ValorStr) >= 2) and CharInSet(ValorStr[Length(ValorStr)], ['B', 'K', 'M', 'G']) then
    begin
      if (Length(ValorStr) >= 3) and (ValorStr[Length(ValorStr)] = 'B') and (ValorStr[Length(ValorStr)-1] in ['K', 'M', 'G']) then
        Unidade := Copy(ValorStr, Length(ValorStr) - 1, 2)
      else
        Unidade := ValorStr[Length(ValorStr)];
      Numero := StrToInt64Def(Trim(Copy(ValorStr, 1, Length(ValorStr) - Length(Unidade))), 5);
    end
    else
      Numero := StrToInt64Def(ValorStr, 5);
    if Numero <= 0 then Numero := 5;
    if Unidade = 'KB' then Result := Numero * 1024
    else if Unidade = 'MB' then Result := Numero * 1024 * 1024
    else if Unidade = 'GB' then Result := Numero * 1024 * 1024 * 1024
    else if Unidade = 'K' then Result := Numero * 1024
    else if Unidade = 'M' then Result := Numero * 1024 * 1024
    else if Unidade = 'G' then Result := Numero * 1024 * 1024 * 1024
    else Result := Numero * 1024 * 1024; // assume MB se não reconhecido
  finally
    IniFile.Free;
  end;
end;
procedure TFrmPrincipal.LimparLogsAntigos;
var
  LogsDir: string;
  FilePath: string;
  FileDate: TDateTime;
  DaysOld: Integer;
  FileList: TArray<string>;
  FileName: string;
  TotalFiles: Integer;
  RemovedFiles: Integer;
  IniFile: TIniFile;
  LogRetentionDias: Integer;
begin
  TotalFiles := 0;
  RemovedFiles := 0;
  try
    LogRetentionDias := 30;
    IniFile := TIniFile.Create(ExtractFilePath(ParamStr(0)) + 'ConfigServer.ini');
    try
      LogRetentionDias := IniFile.ReadInteger('Logs', 'LogRetention', 30);
      if LogRetentionDias < 1 then LogRetentionDias := 30;
    finally
      IniFile.Free;
    end;
    LogsDir := ExtractFilePath(ParamStr(0)) + 'logs\';
    
    if not DirectoryExists(LogsDir) then
      Exit;
    
    // Obter lista de arquivos de log usando TDirectory
    try
      FileList := TDirectory.GetFiles(LogsDir, 'Logs_*.txt');
      TotalFiles := Length(FileList);
      
      if TotalFiles > 0 then
        WriteLogFormatted('INFO', '1', '[GERENCIAMENTO DE LOG] Verificando ' + IntToStr(TotalFiles) + ' arquivos de log na pasta de backup');
      
      for FileName in FileList do
      begin
        FilePath := FileName;
        
        // Obter data de modificação do arquivo usando FileAge
        try
          FileDate := FileDateToDateTime(FileAge(FilePath));
          DaysOld := Trunc(Now - FileDate);
          
          // Se o arquivo tem mais que LogRetention dias (ConfigServer.ini), deletar
          if DaysOld > LogRetentionDias then
          begin
            try
              if TFile.Exists(FilePath) then
              begin
                TFile.Delete(FilePath);
                Inc(RemovedFiles);
                WriteLogFormatted('INFO', '1', '[GERENCIAMENTO DE LOG] Arquivo de log antigo removido: ' + ExtractFileName(FilePath) + ' (idade: ' + IntToStr(DaysOld) + ' dias)');
              end;
            except
              on E: Exception do
              begin
                WriteLogFormatted('ERRO', '1', '[GERENCIAMENTO DE LOG] Erro ao remover arquivo antigo ' + ExtractFileName(FilePath) + ': ' + E.Message);
              end;
            end;
          end;
        except
          on E: Exception do
          begin
            WriteLogFormatted('ERRO', '1', '[GERENCIAMENTO DE LOG] Erro ao obter data do arquivo ' + ExtractFileName(FilePath) + ': ' + E.Message);
          end;
        end;
      end;
      
      // Log final com resumo
      if TotalFiles > 0 then
      begin
        if RemovedFiles > 0 then
          WriteLogFormatted('INFO', '1', '[GERENCIAMENTO DE LOG] Limpeza concluída: ' + IntToStr(RemovedFiles) + ' de ' + IntToStr(TotalFiles) + ' arquivos removidos (mais de ' + IntToStr(LogRetentionDias) + ' dias)')
        else
          WriteLogFormatted('INFO', '1', '[GERENCIAMENTO DE LOG] Limpeza concluída: Nenhum arquivo removido (todos com menos de ' + IntToStr(LogRetentionDias) + ' dias)');
      end;
    except
      on E: Exception do
      begin
        WriteLogFormatted('ERRO', '1', '[GERENCIAMENTO DE LOG] Erro ao listar arquivos de log: ' + E.Message);
      end;
    end;
  except
    on E: Exception do
    begin
      WriteLogFormatted('ERRO', '1', '[GERENCIAMENTO DE LOG] Erro ao limpar logs antigos: ' + E.Message);
    end;
  end;
end;
function TFrmPrincipal.GetAPIServerURL(ComboBox: TComboBox): string;
begin
  if EhModoCliente(ComboBox) then
    Result := API_SERVER_URL_CLIENTE
  else if EhModoServer(ComboBox) then
    Result := API_SERVER_URL_SERVER
  else
    Result := API_SERVER_URL_SERVER; // Default para servidor
end;
 procedure TFrmPrincipal.replicaslocal;
var
  ConexaoMonitor: TUniConnection;
  QSelect: TUniQuery;
  QInsert: TUniQuery;
  QVerificar: TUniQuery;
  data_hora: TDateTime;
  StatusAtual: string;
  OcorrenciaFormatada: string;
  RegistrosProcessados: Integer;
  RegistrosPulados: Integer;
  CodCliente: Integer;
begin
  RegistrosProcessados := 0;
  RegistrosPulados := 0;
  WriteLogFormatted('INFO', '500', '[REPLICAS LOCAL] Iniciando verificação de ocorrências no banco monitor');
  
  ConexaoMonitor := TUniConnection.Create(nil);
  QSelect := TUniQuery.Create(nil);
  QInsert := TUniQuery.Create(nil);
  
  try
    // Configurar conexão com banco monitor
    ConexaoMonitor.ProviderName := 'MySQL';
    ConexaoMonitor.Server := '192.168.0.240';
    ConexaoMonitor.Port := 3306;
    ConexaoMonitor.Database := 'monitor';
    ConexaoMonitor.Username := 'admin';
    ConexaoMonitor.Password := '9887653321';
    
    // Conectar ao banco monitor
    try
      ConexaoMonitor.Connect;
      WriteLogFormatted('INFO', '200', '[REPLICAS LOCAL] Conectado ao banco monitor com sucesso');
    except
      on E: Exception do
      begin
        WriteLogFormatted('ERRO', '200', '[REPLICAS LOCAL] Erro ao conectar ao banco monitor: ' + E.Message);
        Exit;
      end;
    end;
    
    // Verificar se ConexaoModulo está ativa
    if not Assigned(ConexaoModulo) or not ConexaoModulo.Connected then
    begin
      WriteLogFormatted('ERRO', '200', '[REPLICAS LOCAL] ConexaoModulo não está conectada');
      Exit;
    end;
    
    // Configurar query de seleção
    QSelect.Connection := ConexaoMonitor;
    
    WriteLogFormatted('INFO', '500', '[REPLICAS LOCAL] Verificando estrutura da tabela backup...');
    
    // Primeiro testar se a tabela backup existe
    try
      QSelect.SQL.Text := 'SHOW TABLES LIKE ''backup''';
      QSelect.Open;
      if QSelect.IsEmpty then
      begin
        WriteLogFormatted('ERRO', '500', '[REPLICAS LOCAL] Tabela backup não encontrada no banco monitor');
        Exit;
      end;
      QSelect.Close;
    except
      on E: Exception do
      begin
        WriteLogFormatted('ERRO', '500', '[REPLICAS LOCAL] Erro ao verificar tabela backup: ' + E.Message);
        Exit;
      end;
    end;
    
    
    // Agora executar a query principal
    QSelect.SQL.Text := 'SELECT cod_cliente, nome, ilha, end_pasta, ativo, status, mensagem, data_hora ' +
                       'FROM backup ' +
                       'WHERE (status <> :status_ok OR status IS NULL) AND status <> :status_vazio';
    QSelect.ParamByName('status_ok').AsString := 'OK';
    QSelect.ParamByName('status_vazio').AsString := '';
    
    // Configurar query de inserção
    QInsert.Connection := ConexaoModulo;
    QInsert.SQL.Clear;
    QInsert.SQL.Add('INSERT INTO monitor_ocorrencias ');
    QInsert.SQL.Add('(id_empresa_help, ocorrencia, id_prioridade, id_modulo_ocorrencia, data_ocorrencia, hora)');
    QInsert.SQL.Add('VALUES (:id_empresa_help, :ocorrencia, :id_prioridade, :id_modulo_ocorrencia, :data_ocorrencia, :hora)');
    
    try
      QSelect.Open;
      WriteLogFormatted('INFO', '500', '[REPLICAS LOCAL] Consulta executada. Registros encontrados: ' + IntToStr(QSelect.RecordCount));
      
      if not QSelect.IsEmpty then
      begin
        QSelect.First;
        while not QSelect.Eof do
        begin
          try
            StatusAtual := QSelect.FieldByName('status').AsString;
            CodCliente := QSelect.FieldByName('cod_cliente').AsInteger;
            
            // Verificar se o cod_cliente existe na tabela monitor_ocorrencias
            QVerificar := TUniQuery.Create(nil);
            try
              QVerificar.Connection := ConexaoModulo;
              QVerificar.SQL.Text := 'SELECT COUNT(*) as total FROM monitor_ocorrencias WHERE id_empresa_help = :cod_cliente';
              QVerificar.ParamByName('cod_cliente').AsInteger := CodCliente;
              QVerificar.Open;
              
                             if QVerificar.FieldByName('total').AsInteger = 0 then
               begin
                 Inc(RegistrosPulados);
                 WriteLogFormatted('INFO', '500', Format('[REPLICAS LOCAL] Cliente %d (%s) não encontrado na tabela monitor_ocorrencias - pulando registro', 
                   [CodCliente, QSelect.FieldByName('nome').AsString]));
                 QSelect.Next;
                 Continue;
               end;
              QVerificar.Close;
            finally
              QVerificar.Free;
            end;
            
            // Converter data_hora string para TDateTime
            try
              data_hora := StrToDateTime(QSelect.FieldByName('data_hora').AsString);
            except
              data_hora := Now; // Se não conseguir converter, usa data atual
            end;
            
            
            // Formatar ocorrência com campos separados por ponto e vírgula
            OcorrenciaFormatada := FormatDateTime('YYYY-MM-DD', data_hora) + ';' +
                                  FormatDateTime('HH:NN:SS', data_hora) + ';' +
                                  QSelect.FieldByName('cod_cliente').AsString+ ';' +
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                   ';' + // campo vazio
                                    QSelect.FieldByName('mensagem').AsString + ';' +
                                     QSelect.FieldByName('mensagem').AsString + ';' +
                                      QSelect.FieldByName('mensagem').AsString + ';' +
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                  QSelect.FieldByName('mensagem').AsString + ';' +
                                  QSelect.FieldByName('mensagem').AsString + ';' +
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                  ';'; // campo vazio
            
            // Inserir ocorrência no banco de módulos
            QInsert.ParamByName('id_empresa_help').AsInteger := CodCliente;
            QInsert.ParamByName('ocorrencia').AsString := OcorrenciaFormatada;
            QInsert.ParamByName('id_prioridade').AsInteger := 2;
            QInsert.ParamByName('id_modulo_ocorrencia').AsInteger := 7;
            QInsert.ParamByName('data_ocorrencia').AsDateTime := DateOf(data_hora);
            QInsert.ParamByName('hora').AsTime := TimeOf(data_hora);
            QInsert.ExecSQL;
            
            Inc(RegistrosProcessados);
            WriteLogFormatted('INFO', '500', Format('[REPLICAS LOCAL] Ocorrência inserida para cliente %d: %s (Status: %s)',
              [CodCliente, 
               QSelect.FieldByName('nome').AsString, 
               StatusAtual]));
            
          except
            on E: Exception do
            begin
              WriteLogFormatted('ERRO', '500', Format('[REPLICAS LOCAL] Erro ao processar registro do cliente %d: %s', 
                [QSelect.FieldByName('cod_cliente').AsInteger, E.Message]));
            end;
          end;
          
          QSelect.Next;
        end;
        
        WriteLogFormatted('INFO', '500', Format('[REPLICAS LOCAL] Processamento concluído. %d ocorrências inseridas, %d registros pulados', [RegistrosProcessados, RegistrosPulados]));
      end
      else
      begin
        WriteLogFormatted('INFO', '500', '[REPLICAS LOCAL] Nenhum registro com status diferente de OK encontrado');
      end;
    except
      on E: Exception do
      begin
        WriteLogFormatted('ERRO', '500', '[REPLICAS LOCAL] Erro ao executar consulta: ' + E.Message);
      end;
    end;
  finally
    QSelect.Free;
    QInsert.Free;
    ConexaoMonitor.Free;
    executarVariosBancosCorrigindoEncerrantes;
  end;
end;
procedure TFrmPrincipal.apagarocorrenciascomdatalimite;
var
  QSelect, QDelete: TUniQuery;
  IdEmpresaHelp: Integer;
  DataAtualizada: TDateTime;
  RegistrosRemovidos: Integer;
begin
  WriteLogFormatted('INFO', '1', '[LIMPEZA OCORRÊNCIAS] Iniciando limpeza de ocorrências antigas por data_atualizada');
  
  QSelect := TUniQuery.Create(nil);
  QDelete := TUniQuery.Create(nil);
  RegistrosRemovidos := 0;
  
  try
    // Verificar se ConexaoModulo está ativa
    if not Assigned(ConexaoModulo) or not ConexaoModulo.Connected then
    begin
      WriteLogFormatted('ERRO', '1', '[LIMPEZA OCORRÊNCIAS] ConexaoModulo não está conectada');
      Exit;
    end;
    
    QSelect.Connection := ConexaoModulo;
    QDelete.Connection := ConexaoModulo;
    
    // Buscar empresas com data_atualizada e suas ocorrências antigas
    QSelect.SQL.Text :=
      'SELECT DISTINCT ce.id_empresa_help, ce.data_atualizada, mo.ocorrencia ' +
      'FROM cadastro_empresas ce ' +
      'INNER JOIN monitor_ocorrencias mo ON mo.id_empresa_help = ce.id_empresa_help ' +
      'WHERE (mo.data_ocorrencia::timestamp + mo.hora::time) <= (CURRENT_TIMESTAMP - INTERVAL ''7 minutes'')and id_chamado = 0 and id_modulo_ocorrencia <> 6  ' +
      'ORDER BY ce.id_empresa_help';
    
    QSelect.Open;
    
    while not QSelect.Eof do
    begin
      IdEmpresaHelp := QSelect.FieldByName('id_empresa_help').AsInteger;
      DataAtualizada := QSelect.FieldByName('data_atualizada').AsDateTime;
      
      WriteLogFormatted('DEBUG', '1', Format('[LIMPEZA OCORRÊNCIAS] Processando empresa %d (data_atualizada: %s)', 
        [IdEmpresaHelp, DateTimeToStr(DataAtualizada)]));
      
      // Remover ocorrências antigas para esta empresa
      QDelete.SQL.Text :=
        'DELETE FROM monitor_ocorrencias ' +
        'WHERE id_empresa_help = :id_empresa_help ' +
        'and id_modulo_ocorrencia <> 6 and id_chamado = 0 AND (data_ocorrencia::timestamp + hora::time) <= (CURRENT_TIMESTAMP - INTERVAL ''7 minutes'')';
      
      QDelete.ParamByName('id_empresa_help').AsInteger := IdEmpresaHelp;
      QDelete.ExecSQL;
      
      Inc(RegistrosRemovidos, QDelete.RowsAffected);
      
      if QDelete.RowsAffected > 0 then
      begin
        WriteLogFormatted('DEBUG', '1', Format('[LIMPEZA OCORRÊNCIAS] Removidas %d ocorrências antigas da empresa %d', 
          [QDelete.RowsAffected, IdEmpresaHelp]));
      end;
      
      QSelect.Next;
    end;
    
    // Remover ocorrências vazias
    WriteLogFormatted('DEBUG', '1', '[LIMPEZA OCORRÊNCIAS] Removendo ocorrências vazias');
    QDelete.SQL.Text :=
      'DELETE FROM monitor_ocorrencias ' +
      'WHERE (ocorrencia IS NULL OR ocorrencia = '''') AND id_chamado = 0';
    
    QDelete.ExecSQL;
    
    Inc(RegistrosRemovidos, QDelete.RowsAffected);
    
    if QDelete.RowsAffected > 0 then
    begin
      WriteLogFormatted('DEBUG', '1', Format('[LIMPEZA OCORRÊNCIAS] Removidas %d ocorrências vazias',
        [QDelete.RowsAffected]));
    end;
    
    WriteLogFormatted('INFO', '1', Format('[LIMPEZA OCORRÊNCIAS] Limpeza concluída. Total de registros removidos: %d', [RegistrosRemovidos]));
    
  except
    on E: Exception do
    begin
      WriteLogFormatted('ERRO', '1', '[LIMPEZA OCORRÊNCIAS] Erro durante limpeza: ' + E.Message);
    end;
  end;
  
  QSelect.Free;
  QDelete.Free;
end;
procedure TFrmPrincipal.integracao_ararajuba;
var
  QConsulta, QCaminho: TUniQuery;
  ArquivoTXT: TextFile;
  DataInicio, DataFim: TDateTime;
  SQLConsulta: string;
  LinhaArquivo: string;
  CaminhoArquivo: string;
  FS: TFormatSettings;
begin
  try
    FrmPrincipal.WriteLogFormatted('INFO', '126', 'Iniciando geração do arquivo APPCLUBE.TXT');
    // Definir período de 3 dias atrás até hoje
    DataFim := Now;
    DataInicio := DataFim - 3;
    // Buscar caminho da tabela integracao.IntegracaoTXt
    QCaminho := TUniQuery.Create(nil);
    try
      QCaminho.Connection := FrmPrincipal.CXClient;
      // Verificar se a tabela existe e criar se necessário
      try
        QCaminho.SQL.Text := 'SELECT caminho_arquivo FROM integracao.IntegracaoTXt WHERE tipo_integracao = ''APPCLUBE'' LIMIT 1';
        QCaminho.Open;
        if QCaminho.RecordCount > 0 then
        begin
          CaminhoArquivo := QCaminho.FieldByName('caminho_arquivo').AsString;
          FrmPrincipal.WriteLogFormatted('DEBUG', '126', Format('Caminho encontrado na tabela: %s', [CaminhoArquivo]));
        end
        else
        begin
          // Se não existir registro, usar caminho padrão
          CaminhoArquivo := 'C:\NC_APP\APPCLUBE.TXT';
          FrmPrincipal.WriteLogFormatted('DEBUG', '126', 'Nenhum caminho configurado, usando padrão: ' + CaminhoArquivo);
        end;
      except
        on E: Exception do
        begin
          // Se a tabela não existir, criar e usar caminho padrão
          FrmPrincipal.WriteLogFormatted('DEBUG', '126', 'Tabela não existe, criando...');
          try
            // Criar schema se não existir
            try
              QCaminho.SQL.Text := 'CREATE SCHEMA integracao';
              QCaminho.Execute;
              FrmPrincipal.WriteLogFormatted('DEBUG', '126', 'Schema integracao criado');
            except
              on E: Exception do
              begin
                // Se já existir, ignora o erro
                if Pos('already exists', LowerCase(E.Message)) = 0 then
                  FrmPrincipal.WriteLogFormatted('DEBUG', '126', 'Schema integracao já existe');
              end;
            end;
            // Criar tabela se não existir
            try
              QCaminho.SQL.Text := 'CREATE TABLE integracao.IntegracaoTXt (' +
                                  'id SERIAL PRIMARY KEY, ' +
                                  'tipo_integracao VARCHAR(50) NOT NULL, ' +
                                  'caminho_arquivo VARCHAR(500) NOT NULL, ' +
                                  'ativo BOOLEAN DEFAULT true, ' +
                                  'data_criacao TIMESTAMP DEFAULT CURRENT_TIMESTAMP, ' +
                                  'data_atualizacao TIMESTAMP DEFAULT CURRENT_TIMESTAMP' +
                                  ')';
              QCaminho.Execute;
              FrmPrincipal.WriteLogFormatted('DEBUG', '126', 'Tabela IntegracaoTXt criada');
            except
              on E: Exception do
              begin
                // Se já existir, ignora o erro
                if Pos('already exists', LowerCase(E.Message)) = 0 then
                  FrmPrincipal.WriteLogFormatted('DEBUG', '126', 'Tabela IntegracaoTXt já existe');
              end;
            end;
            // Inserir registro padrão
            QCaminho.SQL.Text := 'INSERT INTO integracao.IntegracaoTXt (tipo_integracao, caminho_arquivo) VALUES (''APPCLUBE'', ''C:\NC_APP\APPCLUBE.TXT'')';
            QCaminho.Execute;
            CaminhoArquivo := 'C:\NC_APP\APPCLUBE.TXT';
            FrmPrincipal.WriteLogFormatted('INFO', '126', 'Tabela criada e caminho padrão configurado');
            except
              on E2: Exception do
              begin
                FrmPrincipal.WriteLogFormatted('ERRO', '126', Format('Erro ao criar tabela: %s', [E2.Message]));
                CaminhoArquivo := 'C:\NC_APP\APPCLUBE.TXT';
              end;
          end;
        end;
      end;
    finally
      QCaminho.Free;
    end;
    // Criar query para consulta
    QConsulta := TUniQuery.Create(nil);
    try
      QConsulta.Connection := FrmPrincipal.CXClient;
      // Garantir separador decimal com ponto para formatações numéricas
      FS := TFormatSettings.Create;
      FS.DecimalSeparator := '.';
      FS.ThousandSeparator := #0;
      // SQL da consulta com período dinâmico
      SQLConsulta := Format(
        'SELECT ' +
        '    CAST(lf.data_inclusao AS DATE) AS data, ' +
        '    CAST(lf.data_inclusao AS TIME) AS hora, ' +
        '    c.turno, ' +
        '    lf.cod_lanc_financeiro as sequencia, ' +
        '    pc.nome AS pdv, ' +
        '    lf.cpfclube as cpfclube, ' +
        '    Pe.NOME as cliente, ' +
        '    u.login as usuario_caixa, ' +
        '    lp.cod_produto, ' +
        '    p.nome as nome_produto, ' +
        '    lp.quantidade as litros, ' +
        '    lp.valor, ' +
        '    lf.chave_acesso as chave, ' +
        '    lf.numero_documento as documento, ' +
        '    lpp.nome AS forma_pagamento, ' +
        '    round(lp.quantidade) as pontos, ' +
       // '    RESGATE, '+
        '  ROUND( ' +
        ' (lp.valor / SUM(lp.valor) OVER (PARTITION BY lf.cod_lanc_financeiro)) * lf.resgate, ' +
        ' 2 ' +
        ' ) AS RESGATE, ' +
        '    lf.placa, ' +
        '    lf.km, ' +
        '    lp.preco as preco_litros, ' +
        '    ROUND(((lp.valor-(lp.quantidade*mpm.preco_medio))/lp.quantidade),2) as lucro_litro, ' +
        '    round(lp.valor-(lp.quantidade*mpm.preco_medio),2) as lucro_total, ' +
        '    round(lp.quantidade*mpm.preco_medio,2) as custo_litro, ' +
        '    round(mpm.preco_medio,2) as custo, ' +
        '    lf.cash_back_lanc ' +
        'FROM lancamentos_financeiros lf ' +
        'LEFT JOIN lancamentos_produtos lp ON lp.cod_lanc_financeiro = lf.cod_lanc_financeiro ' +
        'LEFT JOIN caixas c ON lf.cod_registro_caixa = c.cod_registro ' +
        'LEFT JOIN usuarios u ON u.cod_usuario = c.cod_usuario ' +
        'LEFT JOIN produtos p ON p.cod_produto = lp.cod_produto ' +
        'LEFT JOIN pessoas pe ON pe.cod_pessoa = lf.cod_pessoa ' +
        'LEFT JOIN plano_contas pc ON (c.cod_plano = pc.cod_plano) ' +
        'LEFT JOIN lancamentos_padrao LPP ON (lpp.cod_lancamento_padrao = lf.cod_lanc_padrao_pgto_principal) ' +
        'LEFT JOIN ( ' +
        '    SELECT DISTINCT ON (cod_empresa, cod_produto) ' +
        '           cod_empresa, cod_produto, preco_medio ' +
        '    FROM relatorios.movimentacao_produtos_com_preco_medio(0,0,0,0,''%s'',''%s'') AS m ' +
        '    ORDER BY cod_empresa, cod_produto, data_movimento DESC ' +
        ') AS mpm ON mpm.cod_empresa = lf.cod_empresa AND mpm.cod_produto = lp.cod_produto ' +
        'WHERE lf.data_movimento BETWEEN DATE ''%s'' AND DATE ''%s'' ' +
        '  AND lp.tipo_lancamento = ''V'' ' +
        '  AND lp.situacao = 2 ' +
        '  AND lp.cancelado = false ' +
        '  AND lf.cpfclube <> '''' ' +
        '  AND P.pontuar_cashback is true ' +
        'ORDER BY lf.cod_lanc_financeiro',
        [FormatDateTime('yyyy-mm-dd', DataInicio), FormatDateTime('yyyy-mm-dd', DataFim),
         FormatDateTime('yyyy-mm-dd', DataInicio), FormatDateTime('yyyy-mm-dd', DataFim)]
      );
      QConsulta.SQL.Text := SQLConsulta;
      QConsulta.Open;
      if QConsulta.RecordCount = 0 then
      begin
        FrmPrincipal.WriteLogFormatted('INFO', '126', 'Nenhum registro encontrado para o período');
        Exit;
      end;
      FrmPrincipal.WriteLogFormatted('DEBUG', '126', Format('Consulta executada. Registros encontrados: %d', [QConsulta.RecordCount]));
      // Criar pasta se não aexiastir
      try
        if not DirectoryExists(ExtractFilePath(CaminhoArquivo)) then
        begin
          ForceDirectories(ExtractFilePath(CaminhoArquivo));
          FrmPrincipal.WriteLogFormatted('DEBUG', '126', Format('Pasta criada: %s', [ExtractFilePath(CaminhoArquivo)]));
        end;
      except
        on E: Exception do
        begin
          FrmPrincipal.WriteLogFormatted('ERRO', '126', Format('Erro ao criar pasta: %s', [E.Message]));
          // Se falhar, usar caminho padrão do executável
          CaminhoArquivo := ExtractFilePath(ParamStr(0)) + 'APPCLUBE.TXT';
          FrmPrincipal.WriteLogFormatted('DEBUG', '126', Format('Usando caminho alternativo: %s', [CaminhoArquivo]));
        end;
      end;
      // Abrir arquivo para escrita (recriar arquivo completo)
      AssignFile(ArquivoTXT, CaminhoArquivo);
        Rewrite(ArquivoTXT);
      try
        // Processar cada registrso
          while not QConsulta.Eof do
          begin
            // Formatar linha conforme especificação
            LinhaArquivo := Format(
              'insert into abastec_tmp (data,hora,turno,sequencia,pdv,cpfclube,cliente,'+
              'usuario_caixa,cod_produto,nome_produto, litros,valor,chave,documento, forma_pagamento,'+
              'pontos,placa,km,preco_litros,lucro_litro,lucro_total,custo_litro,resgate) values (''%s'',''%s'',''%s'',''%s'',''%s'',''%s'',''%s'',''%s'',''%s'',''%s'',''%s'',''%s'',''%s'',''%s'',''%s'',''%s'',''%s'',''%s'',''%s'',''%s'',''%s'',''%s'',''%s'');',
              [FormatDateTime('yyyy-mm-dd', QConsulta.FieldByName('data').AsDateTime),
               FormatDateTime('hh:nn', QConsulta.FieldByName('hora').AsDateTime),
               QConsulta.FieldByName('turno').AsString,
               QConsulta.FieldByName('sequencia').AsString,
               UpperCase(QConsulta.FieldByName('pdv').AsString),
               QConsulta.FieldByName('cpfclube').AsString,
               QConsulta.FieldByName('cliente').AsString,
               QConsulta.FieldByName('usuario_caixa').AsString,
               QConsulta.FieldByName('cod_produto').AsString,
               UpperCase(QConsulta.FieldByName('nome_produto').AsString),
              FormatFloat('0000000000.000', QConsulta.FieldByName('litros').AsFloat, FS),
              FormatFloat('00000000000.00', QConsulta.FieldByName('valor').AsFloat, FS),
               QConsulta.FieldByName('chave').AsString,
               QConsulta.FieldByName('documento').AsString,
               UpperCase(QConsulta.FieldByName('forma_pagamento').AsString),
              FormatFloat('0000000000', QConsulta.FieldByName('pontos').AsFloat, FS),
               Format('%-7s', [QConsulta.FieldByName('placa').AsString]),
               QConsulta.FieldByName('km').AsString,
              FormatFloat('0000000.00', QConsulta.FieldByName('preco_litros').AsFloat, FS),
              FormatFloat('00000.00000', QConsulta.FieldByName('lucro_litro').AsFloat, FS),
              FormatFloat('000000000.00', QConsulta.FieldByName('lucro_total').AsFloat, FS),
              FormatFloat('000000000.00', QConsulta.FieldByName('custo_litro').AsFloat, FS),
              FormatFloat('00000000.00', QConsulta.FieldByName('resgate').AsFloat, FS)
              ]
            );
            WriteLn(ArquivoTXT, LinhaArquivo);
            FrmPrincipal.WriteLogFormatted('DEBUG', '126', Format('Linha adicionada - Sequência: %s', [QConsulta.FieldByName('sequencia').AsString]));
            QConsulta.Next;
        end;
      finally
        CloseFile(ArquivoTXT);
      end;
    finally
      QConsulta.Free;
    end;
    FrmPrincipal.WriteLogFormatted('INFO', '126', 'Arquivo APPCLUBE.TXT recriado com sucesso (últimos 3 dias)');
  except
    on E: Exception do
      FrmPrincipal.WriteLogFormatted('ERRO', '126', Format('[GERAR ARQUIVO APPCLUBE] Erro: %s', [E.Message]));
  end;
end;
procedure tFrmPrincipal.novoiniciarMonitorando;
var
  StartupPath, LinkPath, VbsPath: string;
  Shell, Shortcut: OleVariant;
  Reg: TRegistry;
  Arquivos: TArray<string>;
  ArquivoAtual: string;
  FTP: TIdFTP;
  PastaRaiz, NomeArquivoFTP1, NomeArquivoFTP2, NomeArquivoLocal1, NomeArquivoLocal2: string;
  NomeArquivoVbs, NomeArquivoBat: string;
  I: Integer;
  ArquivoEncontrado: Boolean;
