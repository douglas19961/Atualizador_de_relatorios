function TFrmPrincipal.VerificarEAtualizarClasse(const CPF: string): Boolean;
var
  QryVerificar, QryAtualizar, QryNome: TUniQuery;
  CodClasse: Integer;
  URLApi, Usuario, Senha, NomeCliente: string;
  CodClasseDestino, LimiteRegistros: Integer;
begin
  WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] *** ENTRANDO NA FUNÇÃO VerificarEAtualizarClasse ***');
  WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] CPF recebido: ' + CPF);
  
  Result := False;
  
  if Trim(CPF) = '' then
  begin
    WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] CPF vazio, pulando verificação de classe');
    Exit;
  end;
  
  // Carregar configurações para obter o código da classe destino
  if not CarregarConfiguracaoAPI(URLApi, Usuario, Senha, CodClasseDestino, LimiteRegistros) then
  begin
    WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Falha ao carregar configurações para verificar classe');
    Exit;
  end;
  
  try
    // Verificar se o CXClient está conectado
    if not CXClient.Connected then
    begin
      try
        CXClient.Connect;
        WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Conectando ao banco para verificar classe - IP: ' +
          CXClient.Server + ', Porta: ' + IntToStr(CXClient.Port) + ', Banco: ' + CXClient.Database);
      except
        on E: Exception do
        begin
          WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Erro ao conectar com banco para verificar classe: ' + E.Message);
          Exit;
        end;
      end;
    end;
    // Consulta com JOIN para verificar se existe nas duas tabelas e obter cod_classe
    QryVerificar := TUniQuery.Create(nil);
    try
      QryVerificar.Connection := CXClient;
      QryVerificar.SQL.Text := 'SELECT p.cod_classe ' +
                              'FROM integracao.clientes_int_estrada c ' +
                              'INNER JOIN public.pessoas p ON p.identificacao = c.cpf ' +
                              'WHERE c.cpf = :cpf ';
      QryVerificar.ParamByName('cpf').AsString := Trim(CPF);
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Verificando classe para CPF: ' + CPF + ' (JOIN entre integracao.clientes_int_estrada e public.pessoas)');
      QryVerificar.Open;
      if not QryVerificar.IsEmpty then
      begin
        CodClasse := QryVerificar.FieldByName('cod_classe').AsInteger;
        WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] CPF ' + CPF + ' encontrado nas duas tabelas com cod_classe: ' + IntToStr(CodClasse));
        // Se cod_classe não for o configurado, atualizar
        if CodClasse <> CodClasseDestino then
        begin
          QryAtualizar := TUniQuery.Create(nil);
          try
            QryAtualizar.Connection := CXClient;
            QryAtualizar.SQL.Text := 'UPDATE public.pessoas SET cod_classe = :cod_classe WHERE identificacao = :cpf';
            QryAtualizar.ParamByName('cod_classe').AsInteger := CodClasseDestino;
            QryAtualizar.ParamByName('cpf').AsString := Trim(CPF);
            QryAtualizar.ExecSQL;
            
            WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Classe atualizada para ' + IntToStr(CodClasseDestino) + ' na tabela public.pessoas para CPF: ' + CPF + ' (era: ' + IntToStr(CodClasse) + ')');
            WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] *** INICIANDO PROCESSO DE EMAIL PARA CPF: ' + CPF + ' ***');
            
            // Buscar nome do cliente para o email
            try
              QryNome := TUniQuery.Create(nil);
              try
                QryNome.Connection := CXClient;
                QryNome.SQL.Text := 'SELECT nome FROM public.pessoas WHERE identificacao = :cpf';
                QryNome.ParamByName('cpf').AsString := Trim(CPF);
                QryNome.Open;
                
                NomeCliente := '';
                if not QryNome.IsEmpty then
                  NomeCliente := QryNome.FieldByName('nome').AsString;
                
                if Trim(NomeCliente) = '' then
                  NomeCliente := 'Cliente não identificado';
                  
              finally
                QryNome.Free;
              end;
            except
              on E: Exception do
              begin
                WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Erro ao buscar nome do cliente: ' + E.Message);
                NomeCliente := 'Cliente não identificado';
              end;
            end;
            
            // Armazenar cliente para email em lote
            WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Armazenando cliente para email em lote - CPF: ' + CPF);
            if ArmazenarClienteAtualizado(CPF, NomeCliente, CodClasse, CodClasseDestino) then
              WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Cliente armazenado com sucesso para email em lote - CPF: ' + CPF)
            else
              WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Falha ao armazenar cliente para email em lote - CPF: ' + CPF);
            Result := True;
          finally
            QryAtualizar.Free;
          end;
        end
        else
        begin
          WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] CPF ' + CPF + ' já possui cod_classe = ' + IntToStr(CodClasseDestino));
        end;
      end
      else
      begin
        WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] CPF ' + CPF + ' não encontrado no JOIN entre integracao.clientes_int_estrada e public.pessoas');
      end;
    finally
      QryVerificar.Free;
    end;
  except
    on E: Exception do
    begin
      WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Erro ao verificar/atualizar classe do CPF ' + CPF + ': ' + E.Message);
      Result := False;
    end;
  end;
end;
procedure TFrmPrincipal.ProcessarTodosCPFs;
var
  QryBuscarCPFs: TUniQuery;
  TotalCPFs, CPFsProcessados, CPFsAtualizados: Integer;
  CPFAtual: string;
begin
  WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] ===== INICIANDO VERIFICAÇÃO DE CLASSE EM LOTE =====');
  
  // Limpar lista de clientes atualizados antes de iniciar
  LimparClientesAtualizados;
  
  TotalCPFs := 0;
  CPFsProcessados := 0;
  CPFsAtualizados := 0;
  try
    // Verificar se o CXClient está conectado
    if not CXClient.Connected then
    begin
      try
        CXClient.Connect;
        WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Conectando ao banco - IP: ' +
          CXClient.Server + ', Porta: ' + IntToStr(CXClient.Port) + ', Banco: ' + CXClient.Database);
      except
        on E: Exception do
        begin
                  WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Erro ao conectar com banco: ' + E.Message);
        Exit;
        end;
      end;
    end;
    // Buscar todos os CPFs da tabela de integração
    QryBuscarCPFs := TUniQuery.Create(nil);
    try
      QryBuscarCPFs.Connection := CXClient;
      QryBuscarCPFs.SQL.Text := 'SELECT DISTINCT cpf FROM integracao.clientes_int_estrada WHERE cpf IS NOT NULL AND TRIM(cpf) <> ''''';
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Buscando CPFs na tabela de integração...');
      QryBuscarCPFs.Open;
      TotalCPFs := QryBuscarCPFs.RecordCount;
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Encontrados ' + IntToStr(TotalCPFs) + ' CPFs únicos para verificar');
      if TotalCPFs = 0 then
      begin
        WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Nenhum CPF encontrado na tabela de integração');
        Exit;
      end;
      // Processar cada CPF
      QryBuscarCPFs.First;
      while not QryBuscarCPFs.Eof do
      begin
        CPFAtual := QryBuscarCPFs.FieldByName('cpf').AsString;
        Inc(CPFsProcessados);
        WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Processando CPF ' + IntToStr(CPFsProcessados) + '/' + IntToStr(TotalCPFs) + ': ' + CPFAtual);
        if Trim(CPFAtual) <> '' then
        begin
          try
            if VerificarEAtualizarClasse(CPFAtual) then
              Inc(CPFsAtualizados);
          except
            on E: Exception do
              WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Erro ao processar CPF ' + CPFAtual + ': ' + E.Message);
          end;
        end;
        QryBuscarCPFs.Next;
        Application.ProcessMessages; // Permitir que a interface responda
      end;
    finally
      QryBuscarCPFs.Free;
    end;
    WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] ===== VERIFICAÇÃO DE CLASSE CONCLUÍDA =====');
    WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Total de CPFs encontrados: ' + IntToStr(TotalCPFs));
    WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] CPFs processados: ' + IntToStr(CPFsProcessados));
    WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] CPFs atualizados: ' + IntToStr(CPFsAtualizados));
    WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Relatório final - Total: ' + IntToStr(TotalCPFs) + ', Processados: ' + IntToStr(CPFsProcessados) + ', Atualizados: ' + IntToStr(CPFsAtualizados));
  except
    on E: Exception do
    begin
      WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Erro geral na verificação em lote: ' + E.Message);
    end;
  end;
end;
procedure TFrmPrincipal.AtualizarRegrasVendas;
var
  QryBuscar, QryAtualizar: TUniQuery;
  TotalRegistros, RegistrosAtualizados: Integer;
  CodPessoa: Integer;
  NomePessoa: string;
  URLApi, Usuario, Senha: string;
  CodClasseDestino, LimiteRegistros: Integer;
begin
  WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] ===== INICIANDO ATUALIZAÇÃO DE REGRAS DE VENDAS =====');
  
  TotalRegistros := 0;
  RegistrosAtualizados := 0;
  
  // Carregar configurações para obter o código da classe
  if not CarregarConfiguracaoAPI(URLApi, Usuario, Senha, CodClasseDestino, LimiteRegistros) then
  begin
    WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Falha ao carregar configurações para regras de vendas');
    Exit;
  end;
  
  try
    // Verificar se o CXClient está conectado
    if not CXClient.Connected then
    begin
      try
        CXClient.Connect;
        WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Conectando ao banco para atualizar regras - IP: ' +
          CXClient.Server + ', Porta: ' + IntToStr(CXClient.Port) + ', Banco: ' + CXClient.Database);
      except
        on E: Exception do
        begin
          WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Erro ao conectar com banco para regras: ' + E.Message);
          Exit;
        end;
      end;
    end;
    // Buscar registros que precisam ser atualizados
    QryBuscar := TUniQuery.Create(nil);
    try
      QryBuscar.Connection := CXClient;
      QryBuscar.SQL.Text := 'SELECT p.cod_pessoa, p.nome ' +
                           'FROM integracao.clientes_int_estrada c ' +
                           'INNER JOIN public.pessoas p ON p.identificacao = c.cpf ' +
                           'INNER JOIN regras_vendas r ON p.cod_pessoa = r.cod_cliente ' +
                           'WHERE p.cod_classe = :cod_classe AND r.reg_desativado = false';
      QryBuscar.ParamByName('cod_classe').AsInteger := CodClasseDestino;
      
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Buscando regras de vendas para atualizar...');
      QryBuscar.Open;
      
      TotalRegistros := QryBuscar.RecordCount;
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Encontrados ' + IntToStr(TotalRegistros) + ' registros de regras_vendas para atualizar');
      
      if TotalRegistros = 0 then
      begin
        WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Nenhuma regra de venda encontrada para atualizar');
        Exit;
      end;
      
      // Processar cada registro
      QryBuscar.First;
      while not QryBuscar.Eof do
      begin
        CodPessoa := QryBuscar.FieldByName('cod_pessoa').AsInteger;
        NomePessoa := QryBuscar.FieldByName('nome').AsString;
        
        WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Atualizando regra para: ' + NomePessoa + ' (cod_pessoa: ' + IntToStr(CodPessoa) + ')');
        
        // Atualizar reg_desativado para true
        QryAtualizar := TUniQuery.Create(nil);
        try
          QryAtualizar.Connection := CXClient;
          QryAtualizar.SQL.Text := 'UPDATE regras_vendas SET reg_desativado = true WHERE cod_cliente = :cod_cliente';
          QryAtualizar.ParamByName('cod_cliente').AsInteger := CodPessoa;
          QryAtualizar.ExecSQL;
          
          Inc(RegistrosAtualizados);
          WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Regra desativada para: ' + NomePessoa + ' (cod_pessoa: ' + IntToStr(CodPessoa) + ')');
        finally
          QryAtualizar.Free;
        end;
        
        QryBuscar.Next;
        Application.ProcessMessages; // Permitir que a interface responda
      end;
      
    finally
      QryBuscar.Free;
    end;
    
    WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] ===== ATUALIZAÇÃO DE REGRAS DE VENDAS CONCLUÍDA =====');
    WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Total de registros encontrados: ' + IntToStr(TotalRegistros));
    WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Registros atualizados: ' + IntToStr(RegistrosAtualizados));
    
    WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Relatório final - Total encontrados: ' + IntToStr(TotalRegistros) + ', Registros atualizados: ' + IntToStr(RegistrosAtualizados));
  except
    on E: Exception do
    begin
      WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Erro geral na atualização de regras: ' + E.Message);
    end;
  end;
end;
function TFrmPrincipal.CarregarConfiguracaoAPI(var URLApi, Usuario, Senha: string; var CodClasseDestino, LimiteRegistros: Integer): Boolean;
var
  QryConfig: TUniQuery;
begin
  Result := False;
  
  try
    // Verificar se o CXClient está conectado
    if not CXClient.Connected then
    begin
      try
        CXClient.Connect;
        WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Conectando ao banco para carregar configurações - IP: ' +
          CXClient.Server + ', Porta: ' + IntToStr(CXClient.Port) + ', Banco: ' + CXClient.Database);
      except
        on E: Exception do
        begin
          WriteLogFormatted('ERRO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Erro ao conectar com banco para configurações: ' + E.Message);
          Exit;
        end;
      end;
