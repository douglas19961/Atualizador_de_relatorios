function TFrmPrincipal.conexaoModuloRotina: Boolean;
var
  NomeDB, Usuario, Senha, IP, PortaStr: string;
  Porta: Integer;
begin
  Result := False;  // Assume falha
  try
    // Seleciona origem dos dados com base no ComboBox
    if ComboBox1.ItemIndex = 1 then
    begin
      NomeDB := Nome_DB_Cliente.Text;
      Usuario := Usuario_DB_Cliente.Text;
      Senha := Senha_DB_Cliente.Text;
      IP := IP_DB_Cliente.Text;
      PortaStr := Porta_DB_Cliente.Text;
    end
    else if ComboBox1.ItemIndex = 0 then
    begin
      NomeDB := Nome_DB_Server.Text;
      Usuario := Usuario_DB_Server.Text;
      Senha := Senha_DB_Server.Text;
      IP := IP_DB_Server.Text;
      PortaStr := Porta_DB_Server.Text;
    end
    else
    begin
      WriteLogFormatted('ERRO', '2', 'Item do ComboBox1 inválido para conexão.');
      Exit;
    end;
    // Valida e converte porta
    if not TryStrToInt(PortaStr, Porta) then
      raise Exception.Create('Porta inválida: ' + PortaStr);
    // Desconecta caso esteja previamente conectado
    if ConexaoModulo.Connected then
      ConexaoModulo.Connected := False;
    // Atribui os parâmetros
    ConexaoModulo.Database := NomeDB;
    ConexaoModulo.UserName := Usuario;
    ConexaoModulo.Password := Senha;
    ConexaoModulo.Server := IP;
