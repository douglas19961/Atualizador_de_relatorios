            WriteLogFormatted('ERRO', '1',
              Format('[ERRO DE CONEXÃO] Banco %s: %s',
                [CxDTCFrota.Database, E.Message]));
        end;
      except
        on E: Exception do
          WriteLogFormatted('ERRO', '1',
            '[ERRO GERAL] Falha ao processar banco: ' + E.Message);
      end;
      // Desconecta antes de ir pro próximo banco
      CxDTCFrota.Connected := False;
      QueryOrigem.Next;
    end;
  finally
    QueryOrigem.Free;
  end;
  ConsultaValidade;
end;
procedure TFrmPrincipal.ConsultaValidade;
var
  extractedValue: string;
  QryPostgres, QryMySQL: TUniQuery;
  EmpresaExiste: Boolean;
  EmpresaID:integer;
begin
  WriteLogFormatted('INFO', '105', 'Iniciando consulta de validade');
  extractedValue := '';
  // Garantir que a conexão com PostgreSQL está ativa
    conexaomodulos;
    if EhModocliente(ComboBox1) then
  begin
  if not CxClient.Connected then
    CxClient.Connect;
  end;
  if EhModoserver(ComboBox1) then
  begin
  if not Cxserver.Connected then
    Cxserver.Connect;
  end;
      if EhModocliente(ComboBox1) then
    EmpresaID := StrToIntDef(EdtEmpresaTodos.Text, 0)
  else if EhModoserver(ComboBox1) then
    EmpresaID := StrToIntDef(EdtEmpresaTodosServer.Text, 0)
  else
    EmpresaID := 0; // Default de segurança
  // Criar query para PostgreSQL
  QryPostgres := TUniQuery.Create(nil);
  try
  if EhModocliente(ComboBox1) then
    begin
    QryPostgres.Connection := CxClient;
    end;
    if EhModoserver(ComboBox1) then
    begin
    QryPostgres.Connection := Cxserver;
    end;
    QryPostgres.SQL.Text :=
    'SELECT a.data_vencimento AS validade ' +
    'FROM autorizacoes a ' +
    'INNER JOIN pessoas p ON a.cod_pessoa = p.cod_pessoa ' +
    'WHERE p.reg_desativado IS FALSE ' +
    'AND a.data_vencimento IS NOT NULL ' +
    'ORDER BY a.data_vencimento DESC ' +
    'LIMIT 1;';
    QryPostgres.Open;
    if not QryPostgres.IsEmpty then
      extractedValue := QryPostgres.FieldByName('validade').AsString;
  finally
    QryPostgres.Free;
  end;
  if extractedValue = '' then
  begin
          WriteLogFormatted('ERRO', '105', '[ATUALIZA VALIDADE] Nenhuma validade encontrada no PostgreSQL.');
    Exit;
  end;
  // Garantir que a conexão com MySQL está ativa
  // Verificar se a empresa já existe na tabela Versao_Sistema
  EmpresaExiste := False;
  QryMySQL := TUniQuery.Create(nil);
  try
    QryMySQL.Connection := ConexaoModulo;
    QryMySQL.SQL.Text := 'SELECT COUNT(*) AS Existe FROM versao_sistema WHERE id_empresa_help = :Empresa';
    QryMySQL.ParamByName('Empresa').Asinteger := EmpresaID;
    QryMySQL.Open;
    EmpresaExiste := QryMySQL.FieldByName('Existe').AsInteger > 0;
  finally
    QryMySQL.Free;
  end;
  // Se a empresa já existir, atualizar a validade. Senão, inserir um novo registro.
  QryMySQL := TUniQuery.Create(nil);
  try
    QryMySQL.Connection := ConexaoModulo;
    if EmpresaExiste then
    begin
      QryMySQL.SQL.Text := 'UPDATE versao_sistema SET vencimentos = :Value WHERE id_empresa_help = :id_empresa_help';
      WriteLogFormatted('INFO', '105', 'validade atualizada para "' + extractedValue + '" na empresa: ' + EdtEmpresaTodos.text);
    end
    else
    begin
      QryMySQL.SQL.Text := 'INSERT INTO versao_sistema (vencimentos, id_empresa_help) VALUES (:Value, :id_empresa_help)';
      WriteLogFormatted('INFO', '105', 'validade "' + extractedValue + '" inserida no MySQL para Empresa: ' + EdtEmpresaTodos.text);
    end;
    QryMySQL.ParamByName('Value').AsString := extractedValue;
    QryMySQL.ParamByName('id_empresa_help').Asinteger := EmpresaID;
    QryMySQL.ExecSQL;
  finally
    QryMySQL.Free;
    apagarocorrenciascomdatalimite;
  end;
end;
procedure TFrmPrincipal.AjustarTamanhoPainel(Painel1, Painel2, PainelPai: TPanel);
var
  LarguraMetade, AlturaTotal: Integer;
begin
  // Calcula metade da largura e altura total do painel pai
  LarguraMetade := PainelPai.Width div 2;
  AlturaTotal := PainelPai.Height;
  // Ajusta altura e largura dos dois painéis
  Painel1.Width := LarguraMetade;
  Painel2.Width := PainelPai.Width - LarguraMetade; // para evitar pixel sobrando
  Painel1.Height := AlturaTotal;
  Painel2.Height := AlturaTotal;
  // Posiciona Painel1 à esquerda e Painel2 à direita
  Painel1.Left := 0;
  Painel2.Left := Painel1.Width;
  // Ambos no topo
  Painel1.Top := 0;
  Painel2.Top := 0;
end;
function TFrmPrincipal.FazerLogin: Boolean;
