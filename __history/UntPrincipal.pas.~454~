    try
      JSONResponse.AddPair('username', Usuario);
      JSONResponse.AddPair('password', Senha);
      WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] JSON enviado: ' + JSONResponse.ToString);
      Application.ProcessMessages;
      RequestBody := TStringStream.Create(JSONResponse.ToString, TEncoding.UTF8);
      try
        WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Enviando requisição de login...');
        Application.ProcessMessages;
        FHttpClient.CustomHeaders['Content-Type'] := 'application/json';
        FHttpClient.CustomHeaders['Accept'] := 'application/json';
        WriteLogFormatted('INFO', '108',
          '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Headers enviados: Content-Type=' +
          FHttpClient.CustomHeaders['Content-Type'] + ', Accept=' +
          FHttpClient.CustomHeaders['Accept']);
        Application.ProcessMessages;
        Response := FHttpClient.Post(URL, RequestBody);
        WriteLogFormatted('INFO', '108', '[EXECUTADOR DE INTEGRAÇÃO ESTRADA] Resposta recebida. Status: ' + IntToStr(Response.StatusCode));
        Application.ProcessMessages;
        if (Response.StatusCode = 200) or (Response.StatusCode = 201) then
