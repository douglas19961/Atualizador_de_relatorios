function GerarSenha(IDCliente, CNPJ: string): string;
var
  CNPJLimpo, DataStr, Salt, Concatenado, Hash: string;
begin
  CNPJLimpo := StringReplace(CNPJ, '.', '', [rfReplaceAll]);
  CNPJLimpo := StringReplace(CNPJLimpo, '/', '', [rfReplaceAll]);
  CNPJLimpo := StringReplace(CNPJLimpo, '-', '', [rfReplaceAll]);
  DataStr := FormatDateTime('yyyymmdd', Now);
  Salt := 'SALT' + IDCliente; // Salt fixo ou baseado no IDCliente
  Concatenado := 'PW-' + IDCliente + '-' + CNPJLimpo + '-' + DataStr + '-' + Salt;
  Hash := THashSHA2.GetHashString(Concatenado);
  if Length(Hash) < 10 then
    Exit('ErroHash');
  Result := Copy(Hash, 1, 10) + '@#';
end;
function ValidarSenha(SenhaDigitada, IDCliente, CNPJ: string): Boolean;
begin
  Result := SenhaDigitada = GerarSenha(IDCliente, CNPJ);
