// Função para obter informações do disco (serial, etc.) usando múltiplas abordagens
function GetDiskSerialInfo: string;
var
  WMI: Variant;
  WMIQuery: Variant;
  DiskSerial: string;
  DiskModel: string;
  i: Integer;
begin
  Result := 'disco-serial-desconhecido';
  
  try
    // Conectar ao WMI
    WMI := CreateOleObject('WbemScripting.SWbemLocator');
    WMI := WMI.ConnectServer('.', 'root\cimv2');
    
    // Tentativa 1: Win32_PhysicalMedia (mais direto)
    try
      WMIQuery := WMI.ExecQuery('SELECT SerialNumber FROM Win32_PhysicalMedia');
      
      if WMIQuery.Count > 0 then
      begin
        for i := 0 to WMIQuery.Count - 1 do
        begin
          DiskSerial := WMIQuery.ItemIndex(i).SerialNumber;
          
          if DiskSerial <> '' then
          begin
            DiskSerial := Trim(DiskSerial);
            Result := Format('disco-serial-%s', [DiskSerial]);
            Exit;
          end;
        end;
      end;
    except
      // Continuar para próxima tentativa
    end;
    
    // Tentativa 2: Win32_DiskDrive com filtro mais amplo
    if Result = 'disco-serial-desconhecido' then
    begin
      WMIQuery := WMI.ExecQuery('SELECT SerialNumber, Model FROM Win32_DiskDrive');
      
      if WMIQuery.Count > 0 then
      begin
        for i := 0 to WMIQuery.Count - 1 do
        begin
          DiskSerial := WMIQuery.ItemIndex(i).SerialNumber;
          DiskModel := WMIQuery.ItemIndex(i).Model;
          
          if DiskSerial <> '' then
          begin
            DiskSerial := Trim(DiskSerial);
            DiskModel := Trim(DiskModel);
            
            if DiskModel <> '' then
              Result := Format('disco-serial-%s-modelo-%s', [DiskSerial, DiskModel])
            else
              Result := Format('disco-serial-%s', [DiskSerial]);
            Exit;
          end;
        end;
      end;
    end;
    
    // Tentativa 3: Win32_LogicalDisk para obter informações do disco
    if Result = 'disco-serial-desconhecido' then
    begin
      WMIQuery := WMI.ExecQuery('SELECT VolumeSerialNumber FROM Win32_LogicalDisk WHERE DriveType = 3');
      
      if WMIQuery.Count > 0 then
      begin
        DiskSerial := WMIQuery.ItemIndex(0).VolumeSerialNumber;
        
        if DiskSerial <> '' then
        begin
          DiskSerial := Trim(DiskSerial);
          Result := Format('disco-serial-%s', [DiskSerial]);
          Exit;
        end;
      end;
    end;
    
    // Tentativa 4: Usar API nativa do Windows para obter serial do volume
    if Result = 'disco-serial-desconhecido' then
    begin
      Result := GetVolumeSerialNumber('C:\');
    end;
  except
    on E: Exception do
    begin
      // Fallback para registry se WMI falhar
      Result := GetDiskSerialFromRegistry;
    end;
  end;
end;

// Função auxiliar para obter serial do disco via registry (fallback)
function GetDiskSerialFromRegistry: string;
var
  Registry: TRegistry;
  DiskSerial: string;
  DiskModel: string;
  i, j: Integer;
  KeyPath: string;
  SubKeys, SubSubKeys: TStringList;
begin
  Result := 'disco-serial-desconhecido';
  Registry := TRegistry.Create;
  SubKeys := TStringList.Create;
  SubSubKeys := TStringList.Create;
  try
    Registry.RootKey := HKEY_LOCAL_MACHINE;
    
    // Tentar caminho para discos SATA/SSD
    if Registry.OpenKeyReadOnly('\SYSTEM\CurrentControlSet\Enum\SCSI') then
    begin
      Registry.GetKeyNames(SubKeys);
      Registry.CloseKey;
      
      for i := 0 to SubKeys.Count - 1 do
      begin
        if Pos('Disk&Ven_', SubKeys[i]) > 0 then
        begin
          KeyPath := '\SYSTEM\CurrentControlSet\Enum\SCSI\' + SubKeys[i];
          if Registry.OpenKeyReadOnly(KeyPath) then
          begin
            Registry.GetKeyNames(SubSubKeys);
            Registry.CloseKey;
            
            for j := 0 to SubSubKeys.Count - 1 do
            begin
              KeyPath := '\SYSTEM\CurrentControlSet\Enum\SCSI\' + SubKeys[i] + '\' + SubSubKeys[j];
              if Registry.OpenKeyReadOnly(KeyPath) then
              begin
                try
                  DiskSerial := Registry.ReadString('SerialNumber');
                  DiskModel := Registry.ReadString('FriendlyName');
                  
                  if DiskSerial <> '' then
                  begin
                    if DiskModel <> '' then
                      Result := Format('disco-serial-%s-modelo-%s', [DiskSerial, DiskModel])
                    else
                      Result := Format('disco-serial-%s', [DiskSerial]);
                    Registry.CloseKey;
                    Exit;
                  end;
                except
                  // Ignorar erro e tentar próxima chave
                end;
                Registry.CloseKey;
              end;
            end;
          end;
        end;
      end;
    end;
  except
    on E: Exception do
      Result := 'disco-serial-erro-coleta';
  end;
  Registry.Free;
  SubKeys.Free;
  SubSubKeys.Free;
end;

