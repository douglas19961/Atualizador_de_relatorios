    Command3 := 'cmd /c ipconfig /all > "' + TempFile3 + '"';
    
    // Executar comandos separadamente
    WinExec(PAnsiChar(AnsiString(Command1)), SW_HIDE);
    Sleep(1000);
    WinExec(PAnsiChar(AnsiString(Command2)), SW_HIDE);
    Sleep(1000);
    WinExec(PAnsiChar(AnsiString(Command3)), SW_HIDE);
    Sleep(2000);
    
    MACAddress := 'mac-desconhecido';
    DiskSerial := 'disco-serial-desconhecido';
    
