// Nova procedure unificada para enviar todas as informações de versão via API
procedure ThreadMonitordeOcorrencia.EnviarVersaoSistemaAPI;
var
  QryPostgres: TUniQuery;
  EmpresaID: Integer;
  VersaoSigilo: string;
  Vencimentos: string;
  VersaoDtcSync: string;
  HttpClient: TNetHTTPClient;
  Response: IHTTPResponse;
  RequestBody: TStringStream;
  EncodedAuth: string;
  JSONPayload: string;
  Texto: string;
  p1, p2: Integer;
begin
  FrmPrincipal.WriteLogFormatted('INFO', '130', 'Iniciando coleta unificada de informações de versão');

  // Validar empresa
  if (FrmPrincipal.EdtEmpresaTodos.Text = '') or (FrmPrincipal.EdtEmpresaTodos.Text = '0') then
  begin
    FrmPrincipal.WriteLogFormatted('ERRO', '130', 'EdtEmpresaTodos está vazio ou inválido');
    Exit;
  end;

  EmpresaID := StrToIntDef(FrmPrincipal.EdtEmpresaTodos.Text, 0);
  if EmpresaID = 0 then
  begin
    FrmPrincipal.WriteLogFormatted('ERRO', '130', 'EmpresaID inválido');
    Exit;
  end;

  // Inicializar variáveis
  VersaoSigilo := '';
  Vencimentos := '';
  VersaoDtcSync := '';

  try
    // 1. Coletar VENCIMENTOS (ConsultaValidade)
    FrmPrincipal.WriteLogFormatted('DEBUG', '130', 'Coletando informações de vencimento...');
    QryPostgres := TUniQuery.Create(nil);
    try
      QryPostgres.Connection := FrmPrincipal.CxClient;
      QryPostgres.SQL.Text :=
        'SELECT a.data_vencimento AS validade ' +
        'FROM autorizacoes a ' +
        'INNER JOIN pessoas p ON a.cod_pessoa = p.cod_pessoa ' +
        'WHERE p.reg_desativado IS FALSE ' +
        'AND a.data_vencimento IS NOT NULL ' +
        'ORDER BY a.data_vencimento DESC ' +
        'LIMIT 1;';
      QryPostgres.Open;
      if not QryPostgres.IsEmpty then
        Vencimentos := QryPostgres.FieldByName('validade').AsString;
    finally
      QryPostgres.Free;
    end;

    // 2. Coletar VERSÃO DTC SYNC (Consultaversao_DTCSync)
    FrmPrincipal.WriteLogFormatted('DEBUG', '130', 'Coletando versão DTC Sync...');
    Texto := FrmPrincipal.LabelVersao.Caption;
  p1 := Pos('monitor', Texto);
  if p1 > 0 then
  begin
      p1 := p1 + Length('monitor');
    p2 := Pos('.txt', Texto);
    if (p2 > p1) then
        VersaoDtcSync := Copy(Texto, p1, p2 - p1);
    end;

    // 3. Coletar VERSÃO SIGILO (Versaosigilo)
    FrmPrincipal.WriteLogFormatted('DEBUG', '130', 'Coletando versão do Sigilo...');
    QryPostgres := TUniQuery.Create(nil);
    try
      QryPostgres.Connection := FrmPrincipal.CxClient;
      QryPostgres.SQL.Text :=
        'SELECT substring(aplicacao from ''\((.*?)\)'') AS extracted_value ' +
        'FROM auditor.transactions_audit ' +
        'WHERE tipo_evento = ''INSERT''' +
        'AND aplicacao LIKE ''Sig%'' and esquema = ''modnfce'' ' +
        'ORDER BY data_hora DESC ' +
        'LIMIT 1;';
      QryPostgres.Open;
      if not QryPostgres.IsEmpty then
        VersaoSigilo := QryPostgres.FieldByName('extracted_value').AsString;
  finally
      QryPostgres.Free;
    end;

    FrmPrincipal.WriteLogFormatted('DEBUG', '130', Format('Dados coletados - Vencimentos: %s, DTC Sync: %s, Sigilo: %s', 
      [Vencimentos, VersaoDtcSync, VersaoSigilo]));

    // 4. Enviar via API
    HttpClient := TNetHTTPClient.Create(nil);
    try
      // Configurar autenticação Basic
      EncodedAuth := TNetEncoding.Base64.Encode(API_USERNAME + ':' + API_PASSWORD);
      HttpClient.CustomHeaders['Authorization'] := 'Basic ' + EncodedAuth;
      HttpClient.CustomHeaders['Content-Type'] := 'application/json';
      
      // Preparar payload JSON
      JSONPayload := Format('{"id_empresa_help":%d,"versao":"%s","vencimentos":"%s","versaodtcsync":"%s"}', 
        [EmpresaID, 
         StringReplace(VersaoSigilo, '"', '\"', [rfReplaceAll]),
         StringReplace(Vencimentos, '"', '\"', [rfReplaceAll]),
         StringReplace(VersaoDtcSync, '"', '\"', [rfReplaceAll])]);
      
      RequestBody := TStringStream.Create(JSONPayload, TEncoding.UTF8);
      
      try
        FrmPrincipal.WriteLogFormatted('INFO', '130', Format('Enviando informações de versão via API para empresa: %d', [EmpresaID]));
        FrmPrincipal.WriteLogFormatted('DEBUG', '130', 'Payload: ' + JSONPayload);
        
        // Fazer requisição POST para a API
  Response := PostApiWithFallback(HttpClient, '/api/versao-sistema', RequestBody);
        
        if Assigned(Response) then
      begin
          if Response.StatusCode = 200 then
          begin
            FrmPrincipal.WriteLogFormatted('INFO', '130', Format('Informações de versão enviadas com sucesso para empresa %d', [EmpresaID]));
            FrmPrincipal.WriteLogFormatted('DEBUG', '130', 'Resposta da API: ' + Response.ContentAsString);
      end
      else
      begin
            FrmPrincipal.WriteLogFormatted('ERRO', '130', Format('Falha ao enviar informações de versão. Status: %d', [Response.StatusCode]));
            FrmPrincipal.WriteLogFormatted('DEBUG', '130', 'Resposta da API: ' + Response.ContentAsString);
          end;
        end
        else
  begin
          FrmPrincipal.WriteLogFormatted('ERRO', '130', 'Resposta da API é nil');
        end;
        
    finally
        RequestBody.Free;
      end;
      
      finally
      HttpClient.Free;
      end;

     except
    on E: Exception do
    begin
      FrmPrincipal.WriteLogFormatted('ERRO', '130', 'Erro ao coletar/enviar informações de versão: ' + E.Message);
    end;
  end;
  
  FrmPrincipal.WriteLogFormatted('INFO', '130', 'Coleta unificada de informações de versão finalizada');
  hardwarclient;
end;
procedure ThreadMonitordeOcorrencia.hardwarclient;
var
  QryMySQL: TUniQuery;
