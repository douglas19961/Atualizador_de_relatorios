function GetApiUrlFromEdit: string;
var
  HostEdit: string;
  HostEditLower: string;
begin
  HostEdit := '';
  TThread.Synchronize(nil, procedure
  begin
    HostEdit := (FrmPrincipal.IP_DB_Cliente.Text);
  end);

  HostEditLower := LowerCase(HostEdit);

  if (Pos('http://', HostEditLower) = 1) or (Pos('https://', HostEditLower) = 1) then
    Result := HostEdit
  else
    Result := 'http://' + HostEdit + ':4450';

  FrmPrincipal.WriteLogFormatted('DEBUG', '106', '[API CLIENTE] IP_DB_Cliente.Text="' + HostEdit + '" => URL resolvida: ' + Result);
end;

function ThreadMonitordeOcorrencia.GetApiUrlWithFallback: string;
begin
  if FUsarIpFixoDataAtivo then
  begin
    Result := 'http://26.169.7.136:4450';
    FrmPrincipal.WriteLogFormatted('DEBUG', '106', '[API CLIENTE] Usando IP fixo (fallback): ' + Result);
  end
  else
  begin
    Result := GetApiUrlFromEdit;
  end;
end;

function ThreadMonitordeOcorrencia.PostApiWithFallback(HttpClient: TNetHTTPClient; 
  const Endpoint: string; RequestBody: TStringStream): IHTTPResponse;
var
  BaseUrl: string;
  RetryWithIpFixo: Boolean;
begin
  Result := nil;
  RetryWithIpFixo := False;
  
  // Primeira tentativa: usar DDNS ou IP fixo conforme estado atual
  BaseUrl := GetApiUrlWithFallback;
  
  try
    FrmPrincipal.WriteLogFormatted('INFO', '106', '[API CLIENTE] Tentando POST para: ' + BaseUrl + Endpoint);
    Result := HttpClient.Post(BaseUrl + Endpoint, RequestBody);
    
    if Assigned(Result) and (Result.StatusCode = 200) then
    begin
      FrmPrincipal.WriteLogFormatted('INFO', '106', '[API CLIENTE] POST bem-sucedido para: ' + BaseUrl + Endpoint);
      Exit;
    end;
  except
    on E: Exception do
    begin
      // Se ainda não está usando IP fixo, tenta com IP fixo
      if not FUsarIpFixoDataAtivo then
      begin
        FrmPrincipal.WriteLogFormatted('ERRO', '106', '[API CLIENTE] Erro ao chamar API via DDNS: ' + E.Message);
        FrmPrincipal.WriteLogFormatted('INFO', '106', '[API CLIENTE] Alternando para IP fixo: http://26.169.7.136:4450');
        FUsarIpFixoDataAtivo := True;
        RetryWithIpFixo := True;
      end
      else
      begin
        // Já está usando IP fixo e ainda deu erro, propaga a exceção
        FrmPrincipal.WriteLogFormatted('ERRO', '106', '[API CLIENTE] Erro ao chamar API via IP fixo: ' + E.Message);
        raise;
      end;
    end;
  end;
  
  // Se precisa tentar com IP fixo
  if RetryWithIpFixo then
  begin
    BaseUrl := 'http://26.169.7.136:4450';
    try
      RequestBody.Position := 0; // Reposiciona o stream
      FrmPrincipal.WriteLogFormatted('INFO', '106', '[API CLIENTE] Tentando POST novamente com IP fixo: ' + BaseUrl + Endpoint);
      Result := HttpClient.Post(BaseUrl + Endpoint, RequestBody);
      
      if Assigned(Result) and (Result.StatusCode = 200) then
      begin
        FrmPrincipal.WriteLogFormatted('INFO', '106', '[API CLIENTE] POST bem-sucedido com IP fixo: ' + BaseUrl + Endpoint);
      end;
    except
      on E: Exception do
      begin
        FrmPrincipal.WriteLogFormatted('ERRO', '106', '[API CLIENTE] Erro ao chamar API com IP fixo: ' + E.Message);
        raise;
      end;
    end;
  end;
end;
