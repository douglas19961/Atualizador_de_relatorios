procedure ThreadMonitordeOcorrencia.atualizar_data_ativo_do_cliente;

var
  IniFile: TIniFile;
  IdClient: string;
  HttpClient: TNetHTTPClient;
  RequestBody: TStringStream;
  Response: IHTTPResponse;
  JSONResponse: TJSONObject;
  ConfigPath: string;
begin
  try
    // Carregar ID_Client do arquivo de configuração
    ConfigPath := ExtractFilePath(ParamStr(0)) + 'ConfigServer.ini';

    if not FileExists(ConfigPath) then
    begin
      FrmPrincipal.WriteLogFormatted('ERRO', '106', '[API CLIENTE] Arquivo de configuração não encontrado: ' + ConfigPath);
      Exit;
    end;

    IniFile := TIniFile.Create(ConfigPath);
    try
      IdClient := IniFile.ReadString('Config', 'ID_Client', '');

      if IdClient = '' then
      begin
        FrmPrincipal.WriteLogFormatted('ERRO', '106', '[API CLIENTE] ID_Client não encontrado no arquivo de configuração');
        Exit;
      end;

      FrmPrincipal.WriteLogFormatted('INFO', '106', '[API CLIENTE] ID_Client carregado: ' + IdClient);

    finally
      IniFile.Free;
    end;

    // Criar cliente HTTP
    HttpClient := TNetHTTPClient.Create(nil);
    try
      // Configurar autenticação Basic
      var AuthString := API_USERNAME + ':' + API_PASSWORD;
      var EncodedAuth := TNetEncoding.Base64.Encode(AuthString);

      // Preparar corpo da requisição
      var JSONBody := '{"id_empresa":' + IdClient + '}';
      RequestBody := TStringStream.Create(JSONBody, TEncoding.UTF8);

      try
        // Configurar headers
        HttpClient.CustomHeaders['Authorization'] := 'Basic ' + EncodedAuth;
        HttpClient.CustomHeaders['Content-Type'] := 'application/json';

        FrmPrincipal.WriteLogFormatted('INFO', '106', '[API CLIENTE] Corpo da requisição: ' + JSONBody);

        // Fazer a requisição POST (com possível fallback para IP fixo)
        Response := PostApiWithFallback(HttpClient, '/api/atualizar-empresa', RequestBody);

        if Assigned(Response) then
        begin
          FrmPrincipal.WriteLogFormatted('INFO', '106', '[API CLIENTE] Resposta recebida. Status: ' + IntToStr(Response.StatusCode));
          FrmPrincipal.WriteLogFormatted('INFO', '106', '[API CLIENTE] Conteúdo da resposta: ' + Response.ContentAsString);

          // Tentar fazer parse da resposta JSON
          try
            JSONResponse := TJSONObject.ParseJSONValue(Response.ContentAsString) as TJSONObject;
            if Assigned(JSONResponse) then
            begin
              var Success: Boolean;
              var Message: string;

              if JSONResponse.TryGetValue<Boolean>('success', Success) then
              begin
                if Success then
                  FrmPrincipal.WriteLogFormatted('INFO', '106', '[API CLIENTE] API executada com sucesso para empresa ID: ' + IdClient)
                else
                  FrmPrincipal.WriteLogFormatted('ERRO', '106', '[API CLIENTE] API retornou erro para empresa ID: ' + IdClient);
              end;

              if JSONResponse.TryGetValue<string>('message', Message) then
                FrmPrincipal.WriteLogFormatted('INFO', '106', '[API CLIENTE] Mensagem: ' + Message);

              JSONResponse.Free;
            end;
          except
            on E: Exception do
              FrmPrincipal.WriteLogFormatted('ERRO', '106', '[API CLIENTE] Erro ao fazer parse da resposta JSON: ' + E.Message);
          end;
        end
        else
        begin
          FrmPrincipal.WriteLogFormatted('ERRO', '106', '[API CLIENTE] Nenhuma resposta recebida do servidor');
        end;

      finally
        RequestBody.Free;
      end;

    finally
      HttpClient.Free;

    end;

  except
    on E: Exception do
    begin
      FrmPrincipal.WriteLogFormatted('ERRO', '106', '[API CLIENTE] Erro ao chamar API: ' + E.Message);
    end;
  end;
   InserirDocFiscalEmAberto;

end;


procedure ThreadMonitordeOcorrencia.InserirDocFiscalEmAberto;
var
  Query, QInsert, QueryApagar: TUniQuery;
  RegistrosProcessados: Integer;
  DataAtual: TDateTime;
  HttpClient: TNetHTTPClient;
  Response: IHTTPResponse;
  RequestBody: TStringStream;
  EncodedAuth: string;
begin
  Query := TUniQuery.Create(nil);
  QInsert := TUniQuery.Create(nil);
  QueryApagar := TUniQuery.Create(nil);
  RegistrosProcessados := 0;
  DataAtual := Now;
  
  try                                               //[VERwIFICAR DOCUMENTOS FISCAIS]
    FrmPrincipal.WriteLogFormatted('INFO', '113', 'Iniciando verificação de documentos fiscais em aberto');
    
    // Verificar se EdtEmpresaTodos tem valor válido
    if (FrmPrincipal.EdtEmpresaTodos.Text = '') or (FrmPrincipal.EdtEmpresaTodos.Text = '0') then
    begin
      FrmPrincipal.WriteLogFormatted('ERRO', '113', 'EdtEmpresaTodos está vazio ou inválido. Valor atual: "' + FrmPrincipal.EdtEmpresaTodos.Text + '"');
      Exit;
    end;

    FrmPrincipal.WriteLogFormatted('DEBUG', '113', 'EdtEmpresaTodos valor: "' + FrmPrincipal.EdtEmpresaTodos.Text + '"');
    // Validar CXClient sem reconectar
    if (not Assigned(FrmPrincipal.cxclient)) or (not FrmPrincipal.cxclient.Connected) then
     begin
      FrmPrincipal.WriteLogFormatted('ERRO', '113', 'CXClient indisponível');
       Exit;
     end;

    // Configurar conexões
    Query.Connection := FrmPrincipal.cxclient;

    // Preparar cliente HTTP para enviar as ocorsrências via API
    HttpClient := TNetHTTPClient.Create(nil);
    try
      EncodedAuth := TNetEncoding.Base64.Encode(API_USERNAME + ':' + API_PASSWORD);
      HttpClient.CustomHeaders['Authorization'] := 'Basic ' + EncodedAuth;
      HttpClient.CustomHeaders['Content-Type'] := 'application/json';
    // Executar consulta para buscar documentos fiscais em aberto
    try
      Query.SQL.Text :=
        'SELECT ' +
        '  CAST(lf.data_movimento AS TEXT) || ' + QuotedStr(';') + ' || ' +
         QuotedStr(';') + ' || ' +
        '  CAST(lf.cod_empresa AS TEXT) || ' + QuotedStr(';') + ' || ' +
        '  ee.nome || ' + QuotedStr(';') + ' || ' +
        '  '''' || ' + QuotedStr(';') + ' || '''' || ' + QuotedStr(';') + ' || ' +
        '  lf.nome_lancamento_padrao || ' + QuotedStr(';') + ' || ' +
        '  CAST(lf.cod_lanc_financeiro AS TEXT) || ' + QuotedStr(';') + ' || ' +
        '  '''' || ' + QuotedStr(';') + ' || '''' || ' + QuotedStr(';') + ' || ' +
         '  '''' || ' + QuotedStr(';') + ' || '''' || ' + QuotedStr(';') + ' || ' +
         QuotedStr(';') + ' || ' +
        '  '''' || ' + QuotedStr(';') + ' || '''' || ' + QuotedStr(';') + ' || ' +
        '  '''' || ' + QuotedStr(';') + ' || '''' || ' + QuotedStr(';') + ' || ' +
        '  '''' || ' + QuotedStr(';') + ' || '''' || ' + QuotedStr(';') + ' || '''' || ' + QuotedStr(';') +
        '  AS Ocorrencia, ' +
        '  CASE ' +
        '    WHEN current_date - lf.data_movimento >= 1 AND current_date - lf.data_movimento <= 2 THEN 1 ' +
        '    WHEN current_date - lf.data_movimento >= 2 AND current_date - lf.data_movimento <= 3 THEN 2 ' +
        '    WHEN current_date - lf.data_movimento >= 3 AND current_date - lf.data_movimento <= 4 THEN 3 ' +
        '    ELSE 4 ' +
        '  END AS prioridade ' +
        'FROM lancamentos_financeiros lf ' +
        'LEFT JOIN caixas cx ON lf.cod_registro_caixa = cx.cod_registro ' +
        'LEFT JOIN usuarios us ON lf.cod_registro_caixa = cx.cod_registro AND us.cod_usuario = cx.cod_usuario ' +
        'LEFT JOIN pessoas p ON us.cod_pessoa = p.cod_pessoa ' +
        'LEFT JOIN pessoas e ON cx.cod_empresa = e.cod_pessoa ' +
        'LEFT JOIN pessoas ee ON lf.cod_empresa = ee.cod_pessoa ' +
        'WHERE lf.cod_modelo_doc IN (''65'',''55'') ' +
        '  AND lf.situacao NOT IN (''2'', ''-3'') ' +
        '  AND lf.data_movimento <= current_date - interval ''1 day'' ' +
        '  AND lf.data_movimento >= current_date - interval ''90 day'' ' +
        'ORDER BY lf.cod_empresa, lf.data_movimento DESC';
      Query.Open;                                            //[VERIFICAR DOCUMENTOS FISCAIS]
      FrmPrincipal.WriteLogFormatted('DEBUG', '113', Format('Consulta executada. Registros encontrados: %d', [Query.RecordCount]));
      
      if not Query.IsEmpty then
      begin
        while not Query.Eof do
        begin
          try
            var IdEmpresaHelp := StrToIntDef(FrmPrincipal.EdtEmpresaTodos.Text, 0);
            var IdModulo := 1;
            var Ocorr := Query.FieldByName('Ocorrencia').AsString;
            var Prior := Query.FieldByName('prioridade').AsInteger;
            var DataStr := FormatDateTime('yyyy-mm-dd', DateOf(DataAtual));
            var HoraStr := FormatDateTime('hh:nn:ss', TimeOf(DataAtual));
            var JSONBody := '{' +
              '"id_empresa_help":' + IntToStr(IdEmpresaHelp) + ',' +
              '"id_modulo_ocorrencia":' + IntToStr(IdModulo) + ',' +
              '"ocorrencia":' + '"' + StringReplace(Ocorr, '"', '\"', [rfReplaceAll]) + '"' + ',' +
              '"dataocorrencia":' + '"' + DataStr + '"' + ',' +
              '"hora":' + '"' + HoraStr + '"' + ',' +
              '"id_prioridade":' + IntToStr(Prior) +
            '}';
            RequestBody := TStringStream.Create(JSONBody, TEncoding.UTF8);
            try
              Response := PostApiWithFallback(HttpClient, '/api/monitor-ocorrencia', RequestBody);
              if Assigned(Response) then
              begin
                FrmPrincipal.WriteLogFormatted('INFO', '113', '[API CLIENTE] Enviado monitor-ocorrencia. Status: ' + IntToStr(Response.StatusCode));
                if Response.StatusCode = 200 then
                  Inc(RegistrosProcessados)
                else
                  FrmPrincipal.WriteLogFormatted('ERRO', '113', '[API CLIENTE] Falha ao enviar ocorrência: ' + Response.ContentAsString);
              end
              else
              begin
                FrmPrincipal.WriteLogFormatted('ERRO', '113', '[API CLIENTE] Resposta nula do servidor ao enviar ocorrência');
              end;
            finally
              RequestBody.Free;
            end;
          except
            on E: Exception do
              FrmPrincipal.WriteLogFormatted('ERRO', '113', 'Erro ao enviar ocorrência para API: ' + E.Message);
          end;
          Query.Next;
        end;
                                                               //[VERIFICAR DOCUMENTOS FISCAIS]
        FrmPrincipal.WriteLogFormatted('INFO', '113', Format('Processamento concluído. %d ocorrências inseridas com sucesso', [RegistrosProcessados]));
      end
      else
      begin                                            //[VERIFICAR DOCUMENTOS FISCAIS]
        FrmPrincipal.WriteLogFormatted('INFO', '113', 'Nenhum documento fiscal em aberto encontrado');
      end;
      
    except
      on E: Exception do
      begin                                                  //[VERIFICAR DOCUMENTOS FISCAIS]
        FrmPrincipal.WriteLogFormatted('ERRO', '113', Format('Erro ao executar consulta: %s', [E.Message]));
      end;
    end;
    


    
  finally

    end;
    
  finally
    FreeAndNil(Query);
    FreeAndNil(QInsert);
    FreeAndNil(QueryApagar);
    Inserir_Replicas_Lojas;
  end;
end;

procedure ThreadMonitordeOcorrencia.Inserir_Replicas_Lojas;
var
  Query,QInsert, QueryApagar: TUniQuery;
  LocalConnection: TUniConnection;
  DataAtual: TDateTime;
  RegistrosProcessados: Integer;
  HttpClient: TNetHTTPClient;
  Response: IHTTPResponse;
  RequestBody: TStringStream;
  EncodedAuth: string;
begin
  LocalConnection := TUniConnection.Create(nil);
  Query := TUniQuery.Create(nil);
  QInsert := TUniQuery.Create(nil);
  QueryApagar := TUniQuery.Create(nil);
  RegistrosProcessados := 0;
  DataAtual := Now;

  try                                               //[VERIFICAR REPLICAS CLIENTES]
    FrmPrincipal.WriteLogFormatted('INFO', '114', 'Iniciando verificação de replicas dos clientes');
    // Verificar se EdtEmpresaTodos tem valor válido
    if (FrmPrincipal.EdtEmpresaTodos.Text = '') or (FrmPrincipal.EdtEmpresaTodos.Text = '0') then
    begin                                             //[VERIFICAR REPLICAS CLIENTES]
      FrmPrincipal.WriteLogFormatted('ERRO', '114', 'EdtEmpresaTodos está vazio ou inválido');
      Exit;
    end;
    
    // Verificar conexões
    if not Assigned(FrmPrincipal.cxclient) or not FrmPrincipal.cxclient.Connected then
    begin                                             //[VERIFICAR REPLICAS CLIENTES]
      FrmPrincipal.WriteLogFormatted('ERRO', '114', 'CXClient não está conectada');
      Exit;
    end;
    

    
    // Configurar conexões
    Query.Connection := FrmPrincipal.cxclient;
    
    // Preparar cliente HTTP para enviar as ocorrências via API
    HttpClient := TNetHTTPClient.Create(nil);
    try
      EncodedAuth := TNetEncoding.Base64.Encode(API_USERNAME + ':' + API_PASSWORD);
      HttpClient.CustomHeaders['Authorization'] := 'Basic ' + EncodedAuth;
      HttpClient.CustomHeaders['Content-Type'] := 'application/json';

    // Executar consulta para buscar replicas com problemas
    try
      Query.SQL.Text :=
        'SELECT ' + QuotedStr(';;;;;;;;;;Nao possui Replica;;;;;;;;;;') + ' AS Ocorrencia ' +
        'FROM (SELECT 1) AS dummy ' +
        'WHERE NOT EXISTS (SELECT 1 FROM sigservers_status) ' +
        'LIMIT 100';
      
      Query.Open;                                             //[VERIFICAR REPLICAS CLIENTES]
      FrmPrincipal.WriteLogFormatted('DEBUG', '114', Format('Consulta executada. Registros encontrados: %d', [Query.RecordCount]));
      
      if not Query.IsEmpty then
      begin
        // Processar cada registro encontrado
        while not Query.Eof do
        begin
          try
            var IdEmpresaHelp := StrToIntDef(FrmPrincipal.EdtEmpresaTodos.Text, 0);
            var IdModulo := 4; // Módulo Replicas
            var Ocorr := Query.FieldByName('Ocorrencia').AsString;
            var Prior := 4;
            var DataStr := FormatDateTime('yyyy-mm-dd', DateOf(DataAtual));
            var HoraStr := FormatDateTime('hh:nn:ss', TimeOf(DataAtual));
            
            var Obj := TJSONObject.Create;
            try
              Obj.AddPair('id_empresa_help', TJSONNumber.Create(IdEmpresaHelp));
              Obj.AddPair('id_modulo_ocorrencia', TJSONNumber.Create(IdModulo));
              Obj.AddPair('ocorrencia', TJSONString.Create(Ocorr));
              Obj.AddPair('dataocorrencia', TJSONString.Create(DataStr));
              Obj.AddPair('hora', TJSONString.Create(HoraStr));
              Obj.AddPair('id_prioridade', TJSONNumber.Create(Prior));
              
              RequestBody := TStringStream.Create(Obj.ToJSON, TEncoding.UTF8);
            finally
              Obj.Free;
            end;
            
            try
  Response := PostApiWithFallback(HttpClient, '/api/monitor-ocorrencia', RequestBody);
              if Assigned(Response) then
              begin
                FrmPrincipal.WriteLogFormatted('INFO', '114', '[API CLIENTE] Enviado monitor-ocorrencia Replicas. Status: ' + IntToStr(Response.StatusCode));
                if Response.StatusCode = 200 then
                  Inc(RegistrosProcessados)
                else
                  FrmPrincipal.WriteLogFormatted('ERRO', '114', '[API CLIENTE] Falha ao enviar ocorrência Replicas: ' + Response.ContentAsString);
              end
              else
              begin
                FrmPrincipal.WriteLogFormatted('ERRO', '114', '[API CLIENTE] Resposta nula do servidor ao enviar ocorrência Replicas');
              end;
            finally
              RequestBody.Free;
            end;
          except
