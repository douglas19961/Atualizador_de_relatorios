          if (Line = '') or (Line = 'SerialNumber') or (Pos('Serial', Line) > 0) or (Pos('Number', Line) > 0) then
            Continue;
            
          if (Length(Line) > 5) then
          begin
            // Preferir serial curto (8 caracteres) sobre serial longo
            if (Length(Line) = 8) then
            begin
              DiskSerial := 'disco-serial-' + Line;
