  HardwareInfo: string;
  ProcessorName: string;
  TotalMemory: string;
  DiskSize: string;
  OSInfo: string;
  ComputerName: string;
  EmpresaExiste: Boolean;
begin
  FrmPrincipal.WriteLogFormatted('INFO', '123', 'Iniciando coleta de especificações de hardware');
  
  // Validar empresa
  if (FrmPrincipal.EdtEmpresaTodos.Text = '') or (FrmPrincipal.EdtEmpresaTodos.Text = '0') then
  begin
    FrmPrincipal.WriteLogFormatted('ERRO', '123', 'EdtEmpresaTodos está vazio ou inválido');
    Exit;
  end;

  EmpresaID := StrToIntDef(FrmPrincipal.EdtEmpresaTodos.Text, 0);
  if EmpresaID = 0 then
  begin
    FrmPrincipal.WriteLogFormatted('ERRO', '123', 'EmpresaID inválido');
    Exit;
  end;

  FrmPrincipal.WriteLogFormatted('DEBUG', '123', Format('Coletando hardware para empresa: %d', [EmpresaID]));

  // Coletar informações de hardware detalhadas
  try
    // Nome do computador
    ComputerName := GetEnvironmentVariable('COMPUTERNAME');
    if ComputerName = '' then
      ComputerName := 'Desconhecido';
    
    // Informações detalhadas do processador
    ProcessorName := GetDetailedProcessorInfo;
    
    // Informações detalhadas do sistema operacional
    OSInfo := GetDetailedOSInfo;
    
    // Memória total detalhada
    TotalMemory := GetDetailedMemoryInfo;
    
    // Informações detalhadas do disco
    DiskSize := GetDetailedDiskInfo;
    
    // Informações da placa mãe
    var Motherboard := GetMotherboardInfo;
    
    // Informações do BIOS
    var BIOSInfo := GetBIOSInfo;
    
    // Detectar se é servidor Dell e usar abordagem específica
    var IsDellServer := (Pos('Dell', Motherboard) > 0) or (Pos('Dell', BIOSInfo) > 0);
    
    var DiskSerial: string;
    var MACAddress: string;
    
    if IsDellServer then
    begin
      FrmPrincipal.WriteLogFormatted('DEBUG', '123', 'Detectado servidor Dell, usando abordagem específica');
      
      // Tentar abordagem específica para Dell
      var DellInfo := GetDellServerInfo;
      
      // Extrair serial e MAC do resultado combinado
      if Pos(';', DellInfo) > 0 then
      begin
        DiskSerial := Copy(DellInfo, 1, Pos(';', DellInfo) - 1);
        MACAddress := Copy(DellInfo, Pos(';', DellInfo) + 1, Length(DellInfo));
      end
      else
      begin
        DiskSerial := DellInfo;
        MACAddress := 'mac-desconhecido';
      end;
      
      FrmPrincipal.WriteLogFormatted('DEBUG', '123', Format('Dell Info: %s', [DellInfo]));
      
      // Se MAC ainda não conseguiu, tentar comando direto
      if (MACAddress = 'mac-desconhecido') then
      begin
        FrmPrincipal.WriteLogFormatted('DEBUG', '123', 'MAC não detectado, tentando comando direto');
        
        // Comando direto para MAC
        var TempFile := 'C:\Windows\Temp\direct_mac.txt';
        var Command := 'cmd /c getmac /fo csv /nh | findstr /v "Transport Name" > "' + TempFile + '"';
        
        if WinExec(PAnsiChar(AnsiString(Command)), SW_HIDE) > 32 then
        begin
          Sleep(2000);
          if FileExists(TempFile) then
          begin
            var Output := TStringList.Create;
            try
              Output.LoadFromFile(TempFile);
              for var j := 0 to Output.Count - 1 do
              begin
                var Line := Trim(Output[j]);
                if (Length(Line) > 20) and (Pos('-', Line) > 0) then
                begin
                  var MACValue := Copy(Line, 1, Pos(',', Line) - 1);
                  MACValue := StringReplace(MACValue, '"', '', [rfReplaceAll]);
                  MACValue := StringReplace(MACValue, '-', ':', [rfReplaceAll]);
                  MACValue := Trim(MACValue);
                  
                  if (Length(MACValue) = 17) and (MACValue <> '00:00:00:00:00:00') and (MACValue <> 'FF:FF:FF:FF:FF:FF') then
                  begin
                    MACAddress := MACValue;
                    Break;
                  end;
                end;
              end;
            finally
              Output.Free;
            end;
            DeleteFile(PWideChar(TempFile));
          end;
        end;
      end;
    end
    else
    begin
      // Usar abordagem normal
      DiskSerial := GetDiskSerialInfo;
      MACAddress := GetMACAddressInfo;
    end;
    
    // Montar string de hardware essencial (sem rótulos e com tamanho do HD)
    HardwareInfo := Format('%s;%s;%s;%s;%s;%s;%s;%s', 
      [ComputerName, ProcessorName, OSInfo, TotalMemory, DiskSize, Motherboard, BIOSInfo, MACAddress]);
    
    FrmPrincipal.WriteLogFormatted('DEBUG', '123', Format('Hardware detalhado coletado: %s', [HardwareInfo]));
    
  except
    on E: Exception do
    begin
      FrmPrincipal.WriteLogFormatted('ERRO', '123', 'Erro ao coletar hardware: ' + E.Message);
      Exit;
    end;
  end;

  // Enviar hardware via API
  var HttpClient := TNetHTTPClient.Create(nil);
  var Response: IHTTPResponse;
  var RequestBody: TStringStream;
  var EncodedAuth: string;
  var JSONPayload: string;
  var MsgFalha: string;
  
  try
    // Configurar autenticação Basic
    EncodedAuth := TNetEncoding.Base64.Encode(API_USERNAME + ':' + API_PASSWORD);
    HttpClient.CustomHeaders['Authorization'] := 'Basic ' + EncodedAuth;
    HttpClient.CustomHeaders['Content-Type'] := 'application/json';
    
    // Preparar payload JSON
    JSONPayload := Format('{"id_empresa":%d,"info_hardware":"%s"}', [EmpresaID, StringReplace(HardwareInfo, '"', '\"', [rfReplaceAll])]);
    RequestBody := TStringStream.Create(JSONPayload, TEncoding.UTF8);
    
    try
      FrmPrincipal.WriteLogFormatted('INFO', '123', Format('Enviando hardware via API para empresa: %d', [EmpresaID]));
      FrmPrincipal.WriteLogFormatted('DEBUG', '123', 'Payload: ' + JSONPayload);
      
      // Fazer requisição POST para a API
  Response := PostApiWithFallback(HttpClient, '/api/hardware-empresa', RequestBody);
      
      if Assigned(Response) then
      begin
        if Response.StatusCode = 200 then
        begin
          FrmPrincipal.WriteLogFormatted('INFO', '123', Format('Hardware enviado com sucesso para empresa %d', [EmpresaID]));
          FrmPrincipal.WriteLogFormatted('DEBUG', '123', 'Resposta da API: ' + Response.ContentAsString);
        end
        else
        begin
          FrmPrincipal.WriteLogFormatted('ERRO', '123', Format('Falha ao enviar hardware. Status: %d', [Response.StatusCode]));
          FrmPrincipal.WriteLogFormatted('DEBUG', '123', 'Resposta da API: ' + Response.ContentAsString);
        end;
      end
      else
      begin
        FrmPrincipal.WriteLogFormatted('ERRO', '123', 'Resposta da API é nil');
      end;
      
    except
      on E: Exception do
      begin
        FrmPrincipal.WriteLogFormatted('ERRO', '123', 'Erro ao enviar hardware via API: ' + E.Message);
      end;
    end;

  finally
    RequestBody.Free;
    HttpClient.Free;
  end;
  
  FrmPrincipal.WriteLogFormatted('INFO', '123', 'Coleta de hardware finalizada');
  consultaNFcECONTIGENCIA;
    
end;

// Função auxiliar para obter memória do sistema
function GetSystemMemory: Int64;
var
  MemoryStatus: TMemoryStatus;
begin
  MemoryStatus.dwLength := SizeOf(TMemoryStatus);
  GlobalMemoryStatus(MemoryStatus);
  Result := MemoryStatus.dwTotalPhys;
end;

// Função auxiliar para obter tamanho do disco
function GetDiskSize(const Drive: string): Int64;
var
  FreeBytesAvailable, TotalNumberOfBytes, TotalNumberOfFreeBytes: Int64;
begin
  Result := 0;
  if GetDiskFreeSpaceEx(PChar(Drive), FreeBytesAvailable, TotalNumberOfBytes, @TotalNumberOfFreeBytes) then
    Result := TotalNumberOfBytes;
end;

// Função para obter informações detalhadas do processador
function GetDetailedProcessorInfo: string;
var
  Registry: TRegistry;
  ProcessorName: string;
  ProcessorSpeed: string;
  ProcessorSpeedInt: Integer;
begin
  Result := 'processador-desconhecido';
  Registry := TRegistry.Create;
  try
    Registry.RootKey := HKEY_LOCAL_MACHINE;
    if Registry.OpenKeyReadOnly('\HARDWARE\DESCRIPTION\System\CentralProcessor\0') then
    begin
      ProcessorName := Registry.ReadString('ProcessorNameString');
      
      // Tentar ler velocidade como inteiro primeiro
      try
        ProcessorSpeedInt := Registry.ReadInteger('~MHz');
        ProcessorSpeed := IntToStr(ProcessorSpeedInt);
      except
        // Se falhar, tentar como string
        try
          ProcessorSpeed := Registry.ReadString('~MHz');
        except
          ProcessorSpeed := '';
        end;
      end;
      
      if ProcessorName <> '' then
      begin
        // Limpar nome do processador
        ProcessorName := StringReplace(ProcessorName, '  ', ' ', [rfReplaceAll]);
        ProcessorName := Trim(ProcessorName);
        
        Result := ProcessorName;
        
        if ProcessorSpeed <> '' then
          Result := Result + Format('-%sMHz', [ProcessorSpeed]);
      end;
      Registry.CloseKey;
    end;
  except
    on E: Exception do
      Result := 'processador-erro-coleta';
  end;
  Registry.Free;
end;

// Função para detectar arquitetura real do sistema operacional
function GetSystemArchitecture: string;
var
  SystemInfo: TSystemInfo;
  IsWow64: BOOL;
begin
  Result := '32bit'; // padrão
  
  try
    // Primeiro, verificar se estamos em um processo 32-bit rodando em SO 64-bit
    if IsWow64Process(GetCurrentProcess, IsWow64) then
    begin
      if IsWow64 then
        Result := '64bit' // processo 32-bit em SO 64-bit
      else
        Result := '32bit'; // processo 32-bit em SO 32-bit
    end
    else
    begin
      // Fallback: usar GetSystemInfo para detectar arquitetura
      Winapi.Windows.GetSystemInfo(SystemInfo);
      // Usar valores numéricos das constantes para evitar problemas de compilação
      case SystemInfo.wProcessorArchitecture of
        9: Result := '64bit';  // PROCESSOR_ARCHITECTURE_AMD64
        6: Result := '64bit';  // PROCESSOR_ARCHITECTURE_IA64
        12: Result := '64bit'; // PROCESSOR_ARCHITECTURE_ARM64
        else Result := '32bit';
      end;
    end;
  except
    on E: Exception do
      Result := '32bit'; // fallback em caso de erro
  end;
end;

// Função para obter informações detalhadas do sistema operacional
function GetDetailedOSInfo: string;
var
  Registry: TRegistry;
  OSName: string;
  OSVersion: string;
  Architecture: string;
begin
  Result := 'so-desconhecido';
  Registry := TRegistry.Create;
  try
    Registry.RootKey := HKEY_LOCAL_MACHINE;
    if Registry.OpenKeyReadOnly('\SOFTWARE\Microsoft\Windows NT\CurrentVersion') then
    begin
      try
        OSName := Registry.ReadString('ProductName');
        OSVersion := Registry.ReadString('DisplayVersion');
        if OSVersion = '' then
          OSVersion := Registry.ReadString('ReleaseId');
      except
        OSName := '';
        OSVersion := '';
      end;
      
      if OSName <> '' then
      begin
        // Determinar arquitetura real do sistema operacional
        Architecture := GetSystemArchitecture;
        
        if OSVersion <> '' then
          Result := Format('%s-%s-%s', [OSName, OSVersion, Architecture])
        else
          Result := Format('%s-%s', [OSName, Architecture]);
      end;
      Registry.CloseKey;
    end;
  except
    on E: Exception do
      Result := 'so-erro-coleta';
  end;
  Registry.Free;
end;

// Função para obter informações detalhadas de memória
function GetDetailedMemoryInfo: string;
var
  MemoryStatus: TMemoryStatusEx;
  TotalGB: Int64;
  AvailableGB: Int64;
begin
  MemoryStatus.dwLength := SizeOf(TMemoryStatusEx);
  
  if GlobalMemoryStatusEx(MemoryStatus) then
  begin
    TotalGB := MemoryStatus.ullTotalPhys div (1024 * 1024 * 1024);
    AvailableGB := MemoryStatus.ullAvailPhys div (1024 * 1024 * 1024);
    
    Result := Format('%dGB-total-%dGB-disponivel', [TotalGB, AvailableGB]);
  end
  else
  begin
    // Fallback para versão antiga se falhar
    var OldMemoryStatus: TMemoryStatus;
    OldMemoryStatus.dwLength := SizeOf(TMemoryStatus);
    GlobalMemoryStatus(OldMemoryStatus);
    
    TotalGB := OldMemoryStatus.dwTotalPhys div (1024 * 1024 * 1024);
    AvailableGB := OldMemoryStatus.dwAvailPhys div (1024 * 1024 * 1024);
    
    Result := Format('%dGB-total-%dGB-disponivel', [TotalGB, AvailableGB]);
  end;
end;

// Função para obter informações detalhadas do disco
function GetDetailedDiskInfo: string;
var
  FreeBytesAvailable, TotalNumberOfBytes, TotalNumberOfFreeBytes: Int64;
  TotalGB, FreeGB: Integer;
  DriveType: string;
begin
  Result := 'hd-desconhecido';
  
  if GetDiskFreeSpaceEx('C:', FreeBytesAvailable, TotalNumberOfBytes, @TotalNumberOfFreeBytes) then
  begin
    TotalGB := TotalNumberOfBytes div (1024 * 1024 * 1024);
    FreeGB := TotalNumberOfFreeBytes div (1024 * 1024 * 1024);
    
    // Verificar tipo de drive
    case GetDriveType('C:') of
      DRIVE_FIXED: DriveType := 'HDD';
      DRIVE_REMOVABLE: DriveType := 'Removivel';
      DRIVE_CDROM: DriveType := 'CDROM';
      DRIVE_RAMDISK: DriveType := 'RAMDISK';
      DRIVE_REMOTE: DriveType := 'Rede';
    else
      DriveType := 'Desconhecido';
    end;
    
    Result := Format('%s-%dGB-total-%dGB-livre', [DriveType, TotalGB, FreeGB]);
  end;
end;

// Função para obter informações da placa de vídeo
function GetVideoCardInfo: string;
var
  Registry: TRegistry;
  VideoCardName: string;
  i: Integer;
  KeyPath: string;
begin
  Result := 'video-desconhecida';
  Registry := TRegistry.Create;
  try
    Registry.RootKey := HKEY_LOCAL_MACHINE;
    
    // Tentar diferentes chaves de vídeo (0000, 0001, etc.)
    for i := 0 to 5 do
    begin
      KeyPath := Format('\SYSTEM\CurrentControlSet\Control\Class\{4d36e968-e325-11ce-bfc1-08002be10318}\%04d', [i]);
      if Registry.OpenKeyReadOnly(KeyPath) then
      begin
        try
          VideoCardName := Registry.ReadString('DriverDesc');
          if VideoCardName <> '' then
          begin
            VideoCardName := StringReplace(VideoCardName, '  ', ' ', [rfReplaceAll]);
            VideoCardName := Trim(VideoCardName);
            Result := Format('video-%s', [VideoCardName]);
            Registry.CloseKey;
            Break;
          end;
        except
          // Ignorar erro e tentar próxima chave
        end;
        Registry.CloseKey;
      end;
    end;
  except
    on E: Exception do
      Result := 'video-erro-coleta';
  end;
  Registry.Free;
end;

// Função para obter informações da placa mãe
function GetMotherboardInfo: string;
var
  Registry: TRegistry;
  MotherboardName: string;
  Manufacturer: string;
begin
  Result := 'placa-mae-desconhecida';
  Registry := TRegistry.Create;
  try
    Registry.RootKey := HKEY_LOCAL_MACHINE;
    if Registry.OpenKeyReadOnly('\HARDWARE\DESCRIPTION\System\BIOS') then
    begin
      try
        Manufacturer := Registry.ReadString('BaseBoardManufacturer');
      except
        Manufacturer := '';
      end;
      
      try
        MotherboardName := Registry.ReadString('BaseBoardProduct');
      except
        MotherboardName := '';
      end;
      
      if (Manufacturer <> '') and (MotherboardName <> '') then
        Result := Format('%s-%s', [Manufacturer, MotherboardName])
