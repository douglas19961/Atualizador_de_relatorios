      end;
      // Removido DELETE direto; limpeza será tratada pela API (regra >30min)

             // Configurar query de seleção
            QSelect.SQL.Text :=
              'SELECT ' +
             ' DISTINCT ON (cod_empresa)'+
              '  TO_CHAR(data_movimento, ''YYYY-MM-DD'') || '';'' || ' +  // data + ;
              '  repeat('';'', 1) || ' +                                 // ; (extra)
              '  cod_empresa || ' +
              '  repeat('';'', 8) || ' +                                // 7 ; após cod_empresa
              '  mensagem || repeat('';'', 7) AS ocorrencias, ' +       // mensagem + 7 ; no final
              '  CASE ' +
              '    WHEN current_date - data_movimento >= 1 AND current_date - data_movimento <= 2 THEN 2 ' +
              '    WHEN current_date - data_movimento >= 2 AND current_date - data_movimento <= 3 THEN 2 ' +
              '    WHEN current_date - data_movimento >= 3 AND current_date - data_movimento <= 4 THEN 2 ' +
              '    ELSE 2 ' +
              '  END AS prioridade ' +
              'FROM pendencias_producao_produtos lf ' +
              'ORDER BY cod_empresa, data_movimento';
                                                     //[INSERIR ERRO PRODUÇÃO]
      FrmPrincipal.WriteLogFormatted('DEBUG', '101', 'Executando consulta de erros de produção');
      QSelect.Open;
      
      // Preparar HttpClient
      HttpClient := TNetHTTPClient.Create(nil);
      EncodedAuth := TNetEncoding.Base64.Encode(API_USERNAME + ':' + API_PASSWORD);
      HttpClient.CustomHeaders['Authorization'] := 'Basic ' + EncodedAuth;
      HttpClient.CustomHeaders['Content-Type'] := 'application/json';
      if not QSelect.IsEmpty then
      begin                                                   //[INSERIR ERRO PRODUÇÃO]
        FrmPrincipal.WriteLogFormatted('DEBUG', '101', Format('Encontrados %d registros de erros de produção', [QSelect.RecordCount]));
                 while not QSelect.Eof do
         begin
           if not QSelect.FieldByName('ocorrencias').IsNull then
           begin
            // Enviar via API
            try
              var IdEmpresaHelp := StrToIntDef(FrmPrincipal.EdtEmpresaTodos.Text, 0);
              var IdModulo := 10;
              var Ocorr := QSelect.FieldByName('ocorrencias').AsString;
              var Prior := QSelect.FieldByName('prioridade').AsInteger;
              var DataStr := FormatDateTime('yyyy-mm-dd', DateOf(DataAtual));
              var HoraStr := FormatDateTime('hh:nn:ss', TimeOf(DataAtual));
              var Obj := TJSONObject.Create;
              try
                Obj.AddPair('id_empresa_help', TJSONNumber.Create(IdEmpresaHelp));
                Obj.AddPair('id_modulo_ocorrencia', TJSONNumber.Create(IdModulo));
                Obj.AddPair('ocorrencia', TJSONString.Create(Ocorr));
                Obj.AddPair('dataocorrencia', TJSONString.Create(DataStr));
                Obj.AddPair('hora', TJSONString.Create(HoraStr));
                Obj.AddPair('id_prioridade', TJSONNumber.Create(Prior));
                RequestBody := TStringStream.Create(Obj.ToJSON, TEncoding.UTF8);
              finally
                Obj.Free;
              end;
              try
  Response := PostApiWithFallback(HttpClient, '/api/monitor-ocorrencia', RequestBody);
                if Assigned(Response) and (Response.StatusCode = 200) then
                begin
                  Inc(RegistrosProcessados);
                  FrmPrincipal.WriteLogFormatted('DEBUG', '101', Format('Ocorrência enviada - Prioridade: %d', [Prior]));
                end
                else
                begin
                  var MsgFalha: string;
                  if Assigned(Response) then
                    MsgFalha := Response.ContentAsString
                  else
                    MsgFalha := 'Sem resposta';
                  FrmPrincipal.WriteLogFormatted('ERRO', '101', '[API CLIENTE] Falha ao enviar ocorrência de produção: ' + MsgFalha);
                end;
              finally
                RequestBody.Free;
              end;
            except
              on E: Exception do
                FrmPrincipal.WriteLogFormatted('ERRO', '101', 'Erro ao enviar ocorrência de produção para API: ' + E.Message);
            end;
           end;
           QSelect.Next;
         end;                                                 //[INSERIR ERRO PRODUÇÃO]
        FrmPrincipal.WriteLogFormatted('DEBUG', '101', Format('Processamento concluído. %d ocorrências inseridas', [RegistrosProcessados]));
      end
      else
      begin                                            //[INSERIR ERRO PRODUÇÃO]
        FrmPrincipal.WriteLogFormatted('INFO', '101', 'Nenhum erro de produção encontrado');
      end;
      except
        on E: Exception do                             //[INSERIR ERRO PRODUÇÃO]
         FrmPrincipal.WriteLogFormatted('ERRO', '101', 'Erro ao executar verificação: ' + E.Message);
      end;
  finally
    QSelect.Free;


     Divergencia_encerrantes_sigilo;
  end;
                                                      //[INSERIR ERRO PRODUÇÃO]
  FrmPrincipal.WriteLogFormatted('INFO', '101', Format('Finalizado com %d ocorrências processadas', [RegistrosProcessados]));
  end;
procedure ThreadMonitordeOcorrencia.Divergencia_encerrantes_sigilo;
var
  QSelect, QSelectEmpresa: TUniQuery;
  HttpClient: TNetHTTPClient;
  Response: IHTTPResponse;
  RequestBody: TStringStream;
  EncodedAuth: string;
  DataAtual: TDateTime;
  RegistrosProcessados: Integer;
  CodEmpresa: Integer;
  TotalRegistros: Integer;
  Divergencia: string;
  TentativasReconexao: Integer;
  ConexaoEstavel: Boolean;
begin                                            //[INSERIR encerrantes sigilo]
  FrmPrincipal.WriteLogFormatted('INFO', '110', 'Iniciando verificação de divergências de encerrantes');
  QSelect := TUniQuery.Create(nil);
  QSelectEmpresa := TUniQuery.Create(nil);
  HttpClient := TNetHTTPClient.Create(nil);
  RegistrosProcessados := 0;
  DataAtual := Now;
  TentativasReconexao := 0;
  ConexaoEstavel := False;
  try
    // Verificar se EdtEmpresaTodos tem valor válido
    if (FrmPrincipal.EdtEmpresaTodos.Text = '') or (FrmPrincipal.EdtEmpresaTodos.Text = '0') then
    begin                                            //[INSERIR encerrantes sigilo]
      FrmPrincipal.WriteLogFormatted('ERRO', '110', 'EdtEmpresaTodos está vazio ou inválido');
      Exit;
    end;
    
    try
      // Configurar conexões
      QSelect.Connection := FrmPrincipal.CXClient;
      QSelectEmpresa.Connection := FrmPrincipal.CXClient;
      
      // Preparar HttpClient
      EncodedAuth := TNetEncoding.Base64.Encode(API_USERNAME + ':' + API_PASSWORD);
      HttpClient.CustomHeaders['Authorization'] := 'Basic ' + EncodedAuth;
      HttpClient.CustomHeaders['Content-Type'] := 'application/json';
      
      // Resetar para CXClient
      TentativasReconexao := 0;
      ConexaoEstavel := False;
      
      if not Assigned(FrmPrincipal.CXClient) then
      begin
        FrmPrincipal.WriteLogFormatted('ERRO', '110', 'CXClient não está atribuída');
        Exit;
      end;
      
      // Estabilizar CXClient
      while not ConexaoEstavel and (TentativasReconexao < 5) do
      begin
        try
          if not FrmPrincipal.CXClient.Connected then
          begin
            FrmPrincipal.WriteLogFormatted('DEBUG', '110', Format('Tentativa %d - Reconectando CXClient...', [TentativasReconexao + 1]));
            FrmPrincipal.CXClient.Connect;
          end;
          
          // Conexão CXClient estabilizada
          
          ConexaoEstavel := True;
          FrmPrincipal.WriteLogFormatted('DEBUG', '110', 'CXClient estabilizada com sucesso');
        except
          on E: Exception do
          begin
            Inc(TentativasReconexao);
            FrmPrincipal.WriteLogFormatted('DEBUG', '110', Format('Tentativa %d - Falha ao estabilizar CXClient: %s', [TentativasReconexao, E.Message]));
            
            if TentativasReconexao >= 5 then
            begin
              FrmPrincipal.WriteLogFormatted('ERRO', '110', 'Máximo de tentativas para CXClient atingido');
              Exit;
            end;
            
            Sleep(2000); // Aguardar 2 segundos antes da próxima tentativa
          end;
        end;
      end;
      // Buscar o cod_empresa do sistema (apenas se houver uma única empresa)
      try
        // Primeiro verificar se existe apenas uma empresa do sistema
        QSelectEmpresa.SQL.Text :=
          'SELECT COUNT(*) as total_empresas ' +
          'FROM PESSOAS ' +
          'WHERE empresa_sistema = true';
        QSelectEmpresa.Open;
        
        if QSelectEmpresa.Active and not QSelectEmpresa.IsEmpty then
        begin
          try
            if QSelectEmpresa.FieldByName('total_empresas').AsInteger > 1 then
            begin
              FrmPrincipal.WriteLogFormatted('DEBUG', '110', 'Mais de uma empresa do sistema encontrada - Abortando verificação');
              Exit;
            end;
            if QSelectEmpresa.FieldByName('total_empresas').AsInteger = 0 then
            begin
              FrmPrincipal.WriteLogFormatted('ERRO', '110', 'Nenhuma empresa do sistema encontrada');
              Exit;
            end;
          except
            on E: Exception do
            begin
              FrmPrincipal.WriteLogFormatted('ERRO', '110', 'Erro ao acessar campo total_empresas: ' + E.Message);
              Exit;
            end;
          end;
        end
        else
        begin
          FrmPrincipal.WriteLogFormatted('ERRO', '110', 'Query de contagem de empresas não retornou dados');
          Exit;
        end;
        
        // Buscar o cod_pessoa da única empresa
        QSelectEmpresa.Close;
        QSelectEmpresa.SQL.Text :=
          'SELECT cod_pessoa ' +
          'FROM PESSOAS ' +
          'WHERE empresa_sistema = true ' +
          'ORDER BY cod_pessoa asc ' +
          'LIMIT 1';
        QSelectEmpresa.Open;
        
        if QSelectEmpresa.Active and not QSelectEmpresa.IsEmpty then
        begin
          try
            CodEmpresa := QSelectEmpresa.FieldByName('cod_pessoa').AsInteger;
            FrmPrincipal.WriteLogFormatted('DEBUG', '110', Format('Empresa única do sistema encontrada: %d', [CodEmpresa]));
          except
            on E: Exception do
            begin
              FrmPrincipal.WriteLogFormatted('ERRO', '110', 'Erro ao acessar campo cod_pessoa: ' + E.Message);
              Exit;
            end;
          end;
        end
        else
        begin
          FrmPrincipal.WriteLogFormatted('ERRO', '110', 'Query de busca da empresa não retornou dados');
          Exit;
        end;
      except
        on E: Exception do
        begin
          FrmPrincipal.WriteLogFormatted('ERRO', '110', 'ERRO AO BUSCAR EMPRESA DO SISTEMA: ' + E.Message);
          Exit;
        end;
      end;

      // Verificar divergências de encerrantes usando o cod_pessoa
      try
        // Verificar se CodEmpresa é válido
        if CodEmpresa <= 0 then
        begin
          FrmPrincipal.WriteLogFormatted('ERRO', '110', 'CodEmpresa inválido: ' + IntToStr(CodEmpresa));
          Exit;
        end;

        // Primeiro, vamos testar se a função retorna dados
        try
          QSelect.SQL.Text :=
            'SELECT COUNT(*) as total_registros ' +
            'FROM calcula_encerrantes_bomba_e_gerencial_por_dia(:pempresa, 0, current_date - 1, current_date - 1) f ' +
            'WHERE f.diferenca_encerrantes > 2';
          QSelect.ParamByName('pempresa').AsInteger := CodEmpresa;
          QSelect.Open;

          if QSelect.Active and not QSelect.IsEmpty then
          begin
            try
              TotalRegistros := QSelect.FieldByName('total_registros').AsInteger;
              FrmPrincipal.WriteLogFormatted('DEBUG', '110', Format('Total de registros com divergência > 2: %d', [TotalRegistros]));
            except
              on E: Exception do
              begin
                FrmPrincipal.WriteLogFormatted('ERRO', '110', 'Erro ao acessar campo total_registros: ' + E.Message);
                Exit;
              end;
            end;
          end
          else
          begin
            FrmPrincipal.WriteLogFormatted('DEBUG', '110', 'Nenhum registro encontrado na consulta de contagem');
          end;
        except
          on E: Exception do
          begin
            FrmPrincipal.WriteLogFormatted('ERRO', '110', 'Erro na consulta de contagem: ' + E.Message);
            Exit;
          end;
        end;

        // Agora vamos buscar a divergência
        try
          QSelect.Close;
          QSelect.SQL.Text :=
            'SELECT ' +
            '  '';;;;;;;;;;Divergência de encerrantes nos bicos;;;;;;;;;'' AS divergencia ' +
            'FROM calcula_encerrantes_bomba_e_gerencial_por_dia(:pempresa, 0, current_date -1, current_date -1) f ' +
            'WHERE f.diferenca_encerrantes > 2 ' +
            'LIMIT 1';
          QSelect.ParamByName('pempresa').AsInteger := CodEmpresa;
          QSelect.Open;
          
          FrmPrincipal.WriteLogFormatted('DEBUG', '110', Format('Executando consulta de divergências de encerrantes para empresa: %d', [CodEmpresa]));
          
          if QSelect.Active then
          begin
            FrmPrincipal.WriteLogFormatted('DEBUG', '110', Format('Registros encontrados na consulta: %d', [QSelect.RecordCount]));
            
            if not QSelect.IsEmpty then
            begin
              FrmPrincipal.WriteLogFormatted('DEBUG', '110', 'Divergência de encerrantes encontrada - Enviando para API');
                   
                   Divergencia := QSelect.FieldByName('divergencia').AsString;
              FrmPrincipal.WriteLogFormatted('DEBUG', '110', Format('Enviando ocorrência para API: %s', [Divergencia]));
              
              // Enviar via API
              try
                var IdEmpresaHelp := StrToIntDef(FrmPrincipal.EdtEmpresaTodos.Text, 0);
                var IdModulo := 11; // Módulo Divergência de encerrantes
                var Ocorr := Divergencia;
                var Prior := 2; // Prioridade média
                var DataStr := FormatDateTime('yyyy-mm-dd', DateOf(DataAtual));
                var HoraStr := FormatDateTime('hh:nn:ss', TimeOf(DataAtual));
                var Obj := TJSONObject.Create;
                try
                  Obj.AddPair('id_empresa_help', TJSONNumber.Create(IdEmpresaHelp));
                  Obj.AddPair('id_modulo_ocorrencia', TJSONNumber.Create(IdModulo));
                  Obj.AddPair('ocorrencia', TJSONString.Create(Ocorr));
                  Obj.AddPair('dataocorrencia', TJSONString.Create(DataStr));
                  Obj.AddPair('hora', TJSONString.Create(HoraStr));
                  Obj.AddPair('id_prioridade', TJSONNumber.Create(Prior));
                  RequestBody := TStringStream.Create(Obj.ToJSON, TEncoding.UTF8);
                finally
                  Obj.Free;
                end;
                try
  Response := PostApiWithFallback(HttpClient, '/api/monitor-ocorrencia', RequestBody);
                  if Assigned(Response) and (Response.StatusCode = 200) then
                       begin
                    Inc(RegistrosProcessados);
                    FrmPrincipal.WriteLogFormatted('INFO', '110', 'Ocorrência de divergência de encerrantes enviada para API com sucesso');
                  end
                  else
                  begin
                    var MsgFalha: string;
                    if Assigned(Response) then
                      MsgFalha := Response.ContentAsString
                    else
                      MsgFalha := 'Sem resposta';
                    FrmPrincipal.WriteLogFormatted('ERRO', '110', '[API CLIENTE] Falha ao enviar divergência de encerrantes: ' + MsgFalha);
                  end;
                finally
                  RequestBody.Free;
                end;
              except
                on E: Exception do
                  FrmPrincipal.WriteLogFormatted('ERRO', '110', 'Erro ao enviar divergência de encerrantes para API: ' + E.Message);
               end;
            end
            else
            begin
              FrmPrincipal.WriteLogFormatted('INFO', '110', 'Nenhuma divergência de encerrantes encontrada');
            end;
          end
          else
          begin
            FrmPrincipal.WriteLogFormatted('ERRO', '110', 'Query não está ativa após execução');
          end;
        except
          on E: Exception do
          begin
            FrmPrincipal.WriteLogFormatted('ERRO', '110', 'Erro na consulta de divergências: ' + E.Message);
            Exit;
          end;
        end;
      except
        on E: Exception do
        begin                                           //[INSERIR encerrantes sigilo]
          FrmPrincipal.WriteLogFormatted('ERRO', '110', 'ERRO AO VERIFICAR DIVERGÊNCIAS DE ENCERRANTES: ' + E.Message);
          Exit;
        end;
      end;
    except
      on E: Exception do                              //[INSERIR encerrantes sigilo]
        FrmPrincipal.WriteLogFormatted('ERRO', '110', 'Erro ao executar verificação: ' + E.Message);
    end;
  finally
    QSelect.Free;
    QSelectEmpresa.Free;

    VerificarCertificadosClientes;
  end;
                                                         //[INSERIR encerrantes sigilo]
  FrmPrincipal.WriteLogFormatted('INFO', '110', Format('[INSERIR encerrantes sigilo] Finalizado com %d ocorrências processadas', [RegistrosProcessados]));
  end;
procedure ThreadMonitordeOcorrencia.VerificarCertificadosClientes;
var
  QSelect: TUniQuery;
  HttpClient: TNetHTTPClient;
  Response: IHTTPResponse;
  RequestBody: TStringStream;
  EncodedAuth: string;
  DataAtual: TDateTime;
  RegistrosProcessados: Integer;
  SerialNumber: string;
  CertInfo: string;
  CertExpired: Boolean;
  ExpirationDate: TDateTime;
  NormalizedSerial: string;
  TempFile: string;
  CmdLine: string;
  ExitCode: Integer;
  AllCerts: TStringList;
  i, j: Integer;
  FoundCert: Boolean;
  LineSerial: string;
begin                                           //[VERIFICAR CERTIFICADOS CLIENTES]
  FrmPrincipal.WriteLogFormatted('INFO', '111', 'Iniciando verificação de certificados dos clientes');
  QSelect := TUniQuery.Create(nil);
  HttpClient := TNetHTTPClient.Create(nil);
  RegistrosProcessados := 0;
  DataAtual := Now;
  try
    // Verificar se EdtEmpresaTodos tem valor válido
    if (FrmPrincipal.EdtEmpresaTodos.Text = '') or (FrmPrincipal.EdtEmpresaTodos.Text = '0') then
    begin
      FrmPrincipal.WriteLogFormatted('ERRO', '111', 'EdtEmpresaTodos está vazio ou inválido');
      Exit;                                          //[VERIFICAR CERTIFICADOS CLIENTES]
    end;
    // Conectar ao banco do cliente
    if not Assigned(FrmPrincipal.CXClient) or not FrmPrincipal.CXClient.Connected then
    begin
      FrmPrincipal.WriteLogFormatted('ERRO', '111', 'CXClient não está conectada');
      Exit;                                          //[VERIFICAR CERTIFICADOS CLIENTES]
    end;
    // Configurar conexões
    QSelect.Connection := FrmPrincipal.CXClient;
    
    // Preparar HttpClient
    EncodedAuth := TNetEncoding.Base64.Encode(API_USERNAME + ':' + API_PASSWORD);
    HttpClient.CustomHeaders['Authorization'] := 'Basic ' + EncodedAuth;
    HttpClient.CustomHeaders['Content-Type'] := 'application/json';
    // Buscar todos os certificados dos clientes
    try
      QSelect.SQL.Text :=
        'SELECT DISTINCT sender_certificate_number, cod_empresa ' +
        'FROM modnfe.nfe_senders_configs ' +
        'WHERE sender_certificate_number IS NOT NULL ' +
        'AND sender_certificate_number <> '''' ' +
        'ORDER BY sender_certificate_number';
      QSelect.Open;                                         //[VERIFICAR CERTIFICADOS CLIENTES]
      FrmPrincipal.WriteLogFormatted('DEBUG', '111', Format('Encontrados %d certificados para verificar', [QSelect.RecordCount]));
      if not QSelect.IsEmpty then
      begin
        // Primeiro, vamos obter a lista de todos os certificados do sistema
        AllCerts := TStringList.Create;
        try
          // Usa certutil para listar todos os certificados
          CmdLine := Format('cmd.exe /c certutil -store MY > "%s"', [ExtractFilePath(ParamStr(0)) + 'all_certs_temp.txt']);
          ExitCode := ShellExecute(0, 'open', 'cmd.exe', PChar('/c ' + CmdLine), nil, SW_HIDE);
          if ExitCode > 32 then
          begin
            Sleep(3000); // Aguarda o comando terminar
            TempFile := ExtractFilePath(ParamStr(0)) + 'all_certs_temp.txt';
            if FileExists(TempFile) then
            begin
              AllCerts.LoadFromFile(TempFile);
              DeleteFile(PChar(TempFile));                         //[VERIFICAR CERTIFICADOS CLIENTES]
              FrmPrincipal.WriteLogFormatted('DEBUG', '111', Format('Lista de certificados do sistema carregada: %d linhas', [AllCerts.Count]));
            end
            else
            begin                                          //[VERIFICAR CERTIFICADOS CLIENTES]
              FrmPrincipal.WriteLogFormatted('ERRO', '111', 'Não foi possível obter a lista de certificados do sistema');
              Exit;
            end;
          end
          else
          begin                                           //[VERIFICAR CERTIFICADOS CLIENTES]
            FrmPrincipal.WriteLogFormatted('ERRO', '111', 'Falha ao executar comando certutil');
            Exit;
          end;
          // Processar cada certificado dos clientes
          while not QSelect.Eof do
          begin
                                   SerialNumber := QSelect.FieldByName('sender_certificate_number').AsString;
                       var CodEmpresaCliente: Integer := QSelect.FieldByName('cod_empresa').AsInteger;
            if Trim(SerialNumber) <> '' then
             begin
              // Normaliza o número de série (remove zeros à esquerda e converte para minúsculas)
              NormalizedSerial := LowerCase(Trim(SerialNumber));
              while (Length(NormalizedSerial) > 1) and (NormalizedSerial[1] = '0') do
                NormalizedSerial := Copy(NormalizedSerial, 2, Length(NormalizedSerial) - 1);
              FrmPrincipal.WriteLogFormatted('DEBUG', '111', Format('Verificando certificado: %s (normalizado: %s)', [SerialNumber, NormalizedSerial]));
              // Verificar se o certificado existe e está vencido
              CertExpired := False;                                //[VERIFICAR CERTIFICADOS CLIENTES]
              ExpirationDate := 0;
              for i := 0 to AllCerts.Count - 1 do
              begin
                // Procura por linhas que contenham "Número de Série" ou "Serial Number"
                if (Pos('número de série', LowerCase(AllCerts[i])) > 0) or
                   (Pos('serial number', LowerCase(AllCerts[i])) > 0) then
                begin
                  // Extrai o número de série da linha
                  LineSerial := LowerCase(AllCerts[i]);
                  // Remove caracteres não hexadecimais
                  LineSerial := StringReplace(LineSerial, ' ', '', [rfReplaceAll]);
                  LineSerial := StringReplace(LineSerial, ':', '', [rfReplaceAll]);
                  LineSerial := StringReplace(LineSerial, '-', '', [rfReplaceAll]);
                  // Procura o número de série na linha
                  if Pos(NormalizedSerial, LineSerial) > 0 then
                  begin
                    // Certificado encontrado, agora verificar data de expiração
                    for j := i + 1 to AllCerts.Count - 1 do
                    begin
                      if Pos('notafter', LowerCase(AllCerts[j])) > 0 then
                      begin
                        // Extrair data de expiração
                        CertInfo := AllCerts[j];
                        // Tentar extrair a data (formato pode variar)
                        if Pos(':', CertInfo) > 0 then
                        begin
                          CertInfo := Copy(CertInfo, Pos(':', CertInfo) + 1, Length(CertInfo));
                          CertInfo := Trim(CertInfo);
                          try
                            ExpirationDate := StrToDateTime(CertInfo);
                            if ExpirationDate < Now then
                            begin
                              CertExpired := True;                                   //[VERIFICAR CERTIFICADOS CLIENTES]
                              FrmPrincipal.WriteLogFormatted('INFO', '111', Format('Certificado %s VENCIDO - Expira em: %s', [SerialNumber, DateTimeToStr(ExpirationDate)]));
                            end
                            else
                            begin                                                     //[VERIFICAR CERTIFICADOS CLIENTES]
                              FrmPrincipal.WriteLogFormatted('DEBUG', '111', Format('Certificado %s VÁLIDO - Expira em: %s', [SerialNumber, DateTimeToStr(ExpirationDate)]));
                            end;
                          except                                                   //[VERIFICAR CERTIFICADOS CLIENTES]
                            FrmPrincipal.WriteLogFormatted('ERRO', '111', Format('Erro ao converter data: %s', [CertInfo]));
                          end;
                        end;
                        Break;
                      end;
                    end;
                    Break;
                  end;
                end;
              end;
                                       // Verificar se o certificado está vencido ou próximo do vencimento
               if ExpirationDate > 0 then
               begin
                 // Calcular dias restantes até o vencimento
                 var DiasRestantes: Integer := Trunc(ExpirationDate - Now);
                 var Prioridade: Integer := 0;
                 var Mensagem: string := '';
                 if DiasRestantes < 0 then
                 begin
                   // Certificado vencido
                   Prioridade := 4;
                   Mensagem := Format(';;%d;;;;;;;;Certificado digital vencido: %s - Expirou em: %s;;;;;;;;;;', [CodEmpresaCliente, SerialNumber, DateTimeToStr(ExpirationDate)]);
                 end
                 else if DiasRestantes <= 3 then
                 begin
                   // Vence em 3 dias ou menos
                   Prioridade := 4;
                   Mensagem := Format(';;%d;;;;;;;;Certificado digital vence em %d dias: %s - Expira em: %s;;;;;;;;;;', [CodEmpresaCliente, DiasRestantes, SerialNumber, DateTimeToStr(ExpirationDate)]);
                 end
                 else if DiasRestantes <= 7 then
                 begin
                   // Vence em 7 dias ou menos
                   Prioridade := 3;
                   Mensagem := Format(';;%d;;;;;;;;Certificado digital vence em %d dias: %s - Expira em: %s;;;;;;;;;;', [CodEmpresaCliente, DiasRestantes, SerialNumber, DateTimeToStr(ExpirationDate)]);
                 end
                 else if DiasRestantes <= 15 then
                 begin
                   // Vence em 15 dias ou menos
                   Prioridade := 2;
                   Mensagem := Format(';;%d;;;;;;;;Certificado digital vence em %d dias: %s - Expira em: %s;;;;;;;;;;', [CodEmpresaCliente, DiasRestantes, SerialNumber, DateTimeToStr(ExpirationDate)]);
                 end
                 else if DiasRestantes <= 30 then
                 begin
                   // Vence em 15 dias ou menos
