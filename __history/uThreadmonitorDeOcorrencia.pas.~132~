      'JOIN lancamentos_financeiros lf2 ' +
      'ON lf2.chave_acesso = mod2.access_key ' +
      'WHERE lf2.data_movimento BETWEEN (CURRENT_DATE - INTERVAL ''2 months'') AND CURRENT_DATE ' +
      'AND ( ' +
      '    mod2.current_status IN (''nis_rejected'',''nis_external_emit'') ' +
      ' OR (mod2.current_status = ''nis_authorized'' AND lf2.situacao <> 2) ' +
      ' OR (mod2.current_status = ''nis_overruled''  AND lf2.situacao <> -3) ' +
