  SubKeys := TStringList.Create;
  try
    Registry.RootKey := HKEY_LOCAL_MACHINE;
    
    // Tentar encontrar placa de rede ativa
    if Registry.OpenKeyReadOnly('\SYSTEM\CurrentControlSet\Control\Class\{4d36e972-e325-11ce-bfc1-08002be10318}') then
    begin
      Registry.GetKeyNames(SubKeys);
      Registry.CloseKey;
      
      for i := 0 to SubKeys.Count - 1 do
      begin
        if (SubKeys[i] <> 'Properties') and (Length(SubKeys[i]) = 4) then
        begin
          KeyPath := '\SYSTEM\CurrentControlSet\Control\Class\{4d36e972-e325-11ce-bfc1-08002be10318}\' + SubKeys[i];
