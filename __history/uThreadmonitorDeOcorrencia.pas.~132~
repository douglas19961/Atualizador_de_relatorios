    FrmPrincipal.WriteLogFormatted('INFO', '114', 'Iniciando verificação de réplicas - verificação de sincronização');

    // Verificar se EdtEmpresaTodos tem valor válido
    if (FrmPrincipal.EdtEmpresaTodos.Text = '') or (FrmPrincipal.EdtEmpresaTodos.Text = '0') then
    begin
      FrmPrincipal.WriteLogFormatted('ERRO', '114', 'EdtEmpresaTodos está vazio ou inválido');
      Exit;
    end;

    // Verificar conexões
    if not Assigned(FrmPrincipal.cxclient) or not FrmPrincipal.cxclient.Connected then
    begin
      FrmPrincipal.WriteLogFormatted('ERRO', '114', 'CXClient não está conectada');
      Exit;
    end;


    // Configurar conexões
    Query.Connection := FrmPrincipal.cxclient;

    // HTTP client
    HttpClient := TNetHTTPClient.Create(nil);
    EncodedAuth := TNetEncoding.Base64.Encode(API_USERNAME + ':' + API_PASSWORD);
    HttpClient.CustomHeaders['Authorization'] := 'Basic ' + EncodedAuth;
    HttpClient.CustomHeaders['Content-Type'] := 'application/json';

    // Executar consulta para buscar réplicas com problemas de sincronização
    try

      Query.SQL.Text :=
        'SELECT ' +
        '  COALESCE(TO_CHAR(s.ultimo_sucesso_sinc, ''YYYY-MM-DD''), '''') || '';'' || ' +
        '  COALESCE(TO_CHAR(s.ultimo_sucesso_sinc, ''HH24:MI:SS''), '''') || '';'' || ' +
        '  '';'' || '';'' || '';'' || '';'' || '';'' || '';'' || ' +
        '  COALESCE(ss.descricao, '''') || '';'' || ' +
        '  COALESCE(NULLIF(s.msg, ''''), ''Não sincronizando'') || '';'' || ' +
        '  '';'' || '';'' || '';'' || '';'' || '';'' || '';'' AS Ocorrencia ' +
        'FROM sigservers_status s ' +
        'INNER JOIN sigservers ss ON ss.mac_addr = s.mac_addr ' +
        'WHERE s.replica = true and ' +
        '(s.ultimo_sucesso_sinc IS NULL OR s.ultimo_sucesso_sinc < (CURRENT_TIMESTAMP - INTERVAL ''2 hour'')) ' +
        'OR ' +
        '(s.msg IS NOT NULL AND s.msg <> '''' AND ' +
        '(s.msg ILIKE ''%erro%'' OR s.msg ILIKE ''%falha%'' OR s.msg ILIKE ''%timeout%''))';


      Query.Open;
      FrmPrincipal.WriteLogFormatted('DEBUG', '114', Format('Consulta de sincronização executada. Registros encontrados: %d', [Query.RecordCount]));

      if not Query.IsEmpty then
      begin
        // Processar cada registro encontrado
        while not Query.Eof do
        begin
          try
            var IdEmpresaHelp := StrToIntDef(FrmPrincipal.EdtEmpresaTodos.Text, 0);
            var IdModulo := 4;
            var Ocorr := Query.FieldByName('Ocorrencia').AsString;
            var Prior := 4;
            var DataStr := FormatDateTime('yyyy-mm-dd', DateOf(DataAtual));
            var HoraStr := FormatDateTime('hh:nn:ss', TimeOf(DataAtual));
            
            var Obj := TJSONObject.Create;
            try
              Obj.AddPair('id_empresa_help', TJSONNumber.Create(IdEmpresaHelp));
              Obj.AddPair('id_modulo_ocorrencia', TJSONNumber.Create(IdModulo));
              Obj.AddPair('ocorrencia', TJSONString.Create(Ocorr));
              Obj.AddPair('dataocorrencia', TJSONString.Create(DataStr));
              Obj.AddPair('hora', TJSONString.Create(HoraStr));
              Obj.AddPair('id_prioridade', TJSONNumber.Create(Prior));
              RequestBody := TStringStream.Create(Obj.ToJSON, TEncoding.UTF8);
            finally
              Obj.Free;
            end;
            try
  Response := PostApiWithFallback(HttpClient, '/api/monitor-ocorrencia', RequestBody);
              if Assigned(Response) then
              begin
                FrmPrincipal.WriteLogFormatted('INFO', '114', '[API CLIENTE] Enviado monitor-ocorrencia Sync. Status: ' + IntToStr(Response.StatusCode));
                if Response.StatusCode = 200 then
                  Inc(RegistrosProcessados)
                else
                  FrmPrincipal.WriteLogFormatted('ERRO', '114', '[API CLIENTE] Falha ao enviar ocorrência Sync: ' + Response.ContentAsString);
              end
              else
                FrmPrincipal.WriteLogFormatted('ERRO', '114', '[API CLIENTE] Resposta nula do servidor ao enviar ocorrência Sync');
            finally
              RequestBody.Free;
            end;
          except
            on E: Exception do
              FrmPrincipal.WriteLogFormatted('ERRO', '114', 'Erro ao enviar ocorrência Sync para API: ' + E.Message);
            end;
          Query.Next;
        end;

        FrmPrincipal.WriteLogFormatted('INFO', '114', Format('Verificação de sincronização concluída. %d ocorrências inseridas', [RegistrosProcessados]));
      end
      else
      begin
        FrmPrincipal.WriteLogFormatted('INFO', '114', 'Nenhuma ocorrência de sincronização de réplica encontrada');
      end;

    except
      on E: Exception do
      begin
        FrmPrincipal.WriteLogFormatted('ERRO', '114', Format('Erro ao executar consulta de sincronização: %s', [E.Message]));
      end;
    end;

  finally
    Query.Free;
    QInsert.Free;
    QueryApagar.Free;
    LocalConnection.Free;
    consultaNFEDivergencia;
  end;

end;

