          Line := Trim(Output[i]);
          // Pular cabeçalhos e linhas vazias
          if (Line = '') or (Line = 'MACAddress') or (Pos('Serial', Line) > 0) or (Pos('Number', Line) > 0) then
            Continue;
            
          // Aceitar MAC com hífens (formato padrão)
