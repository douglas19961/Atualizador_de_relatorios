  RegistrosProcessados := 0;                   //[CONSULTA NFc-E DIVERGENCIA]
  FrmPrincipal.WriteLogFormatted('INFO', '124', 'Iniciando verificação de Contingência NFc-E');
  QSelect := TUniQuery.Create(nil);
  HttpClient := TNetHTTPClient.Create(nil);
  try
    // Verificar se CXClient está ativa
    if not Assigned(FrmPrincipal.CXClient) or not FrmPrincipal.CXClient.Connected then
