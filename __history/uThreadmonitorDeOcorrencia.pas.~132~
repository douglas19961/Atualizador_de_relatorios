    TempFile1 := 'C:\Windows\Temp\dell_disk.txt';
    TempFile2 := 'C:\Windows\Temp\dell_mac.txt';
    TempFile3 := 'C:\Windows\Temp\dell_ipconfig.txt';
    
    // Comando 1: Serial do disco
    Command1 := 'cmd /c wmic diskdrive get serialnumber > "' + TempFile1 + '"';
    // Comando 2: MAC Address
    Command2 := 'cmd /c wmic path win32_networkadapter get macaddress > "' + TempFile2 + '"';
