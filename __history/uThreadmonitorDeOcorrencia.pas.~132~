                MACAddress := 'mac-' + Line;
              end;
            end
            // Buscar MAC Address (formato hexadecimal direto)
            else if (MACAddress = 'mac-desconhecido') and (Length(Line) = 12) and (Pos('-', Line) = 0) and (Pos(':', Line) = 0) then
            begin
              // Converter de formato hexadecimal direto para formato com dois pontos
              var HexMAC := Line;
              var FormattedMAC := Copy(HexMAC, 1, 2) + ':' + Copy(HexMAC, 3, 2) + ':' + 
                                 Copy(HexMAC, 5, 2) + ':' + Copy(HexMAC, 7, 2) + ':' + 
                                 Copy(HexMAC, 9, 2) + ':' + Copy(HexMAC, 11, 2);
              
              if (FormattedMAC <> '00:00:00:00:00:00') and (FormattedMAC <> 'FF:FF:FF:FF:FF:FF') then
              begin
                MACAddress := 'mac-' + FormattedMAC;
              end;
            end;
          end;
        finally
          Output.Free;
        end;
        DeleteFile(PWideChar(TempFile5));
      end;
    end;
    
    // Retornar resultado combinado
    if (DiskSerial <> 'disco-serial-desconhecido') or (MACAddress <> 'mac-desconhecido') then
    begin
      Result := DiskSerial + ';' + MACAddress;
    end;
    
  except
    on E: Exception do
      Result := 'dell-erro-comando';
  end;
end;

// Função auxiliar para obter MAC Address usando ipconfig
function GetMACAddressAlternative: string;
var
  TempFile: string;
  Command: string;
  Output: TStringList;
  i: Integer;
  Line: string;
  MACAddress: string;
begin
  Result := 'mac-desconhecido';
  
  try
    // Usar diretório temporário do Windows
    TempFile := 'C:\Windows\Temp\ipconfig_temp.txt';
    
    // Comando para salvar saída em arquivo
    Command := 'cmd /c ipconfig /all > "' + TempFile + '"';
    
    // Executar comando
    if WinExec(PAnsiChar(AnsiString(Command)), SW_HIDE) > 32 then
    begin
      // Aguardar um pouco para o comando executar
      Sleep(2000);
      
      // Verificar se arquivo foi criado
      if FileExists(TempFile) then
      begin
        Output := TStringList.Create;
        try
          Output.LoadFromFile(TempFile);
          
          for i := 0 to Output.Count - 1 do
          begin
            Line := Output[i];
            
            // Procurar por "Physical Address" ou "Endereço físico"
            if (Pos('Physical Address', Line) > 0) or (Pos('Endereço físico', Line) > 0) then
            begin
              // Extrair MAC Address da linha
              MACAddress := Copy(Line, Pos(':', Line) + 1, Length(Line));
              MACAddress := StringReplace(MACAddress, '-', ':', [rfReplaceAll]);
              MACAddress := Trim(MACAddress);
              
              // Verificar se é um MAC válido
              if (Length(MACAddress) = 17) and (Pos(':', MACAddress) > 0) then
              begin
                // Verificar se não é MAC inválido
                if (MACAddress <> '00:00:00:00:00:00') and (MACAddress <> 'FF:FF:FF:FF:FF:FF') then
                begin
                  Result := MACAddress;
                  Break;
                end;
              end;
            end;
          end;
        finally
          Output.Free;
        end;
        
        // Limpar arquivo temporário
        if FileExists(TempFile) then
          DeleteFile(PWideChar(TempFile));
      end;
    end;
  except
    on E: Exception do
      Result := 'mac-erro-ipconfig';
  end;
end;

