// Função para obter MAC Address da placa de rede principal usando múltiplas abordagens
function GetMACAddressInfo: string;
var
  WMI: Variant;
  WMIQuery: Variant;
  MACAddress: string;
  NetworkName: string;
  i: Integer;
begin
  Result := 'mac-desconhecido';
  
  try
    // Conectar ao WMI
    WMI := CreateOleObject('WbemScripting.SWbemLocator');
    WMI := WMI.ConnectServer('.', 'root\cimv2');
    
    // Tentativa 1: Win32_NetworkAdapterConfiguration (mais confiável)
    try
      WMIQuery := WMI.ExecQuery('SELECT MACAddress FROM Win32_NetworkAdapterConfiguration WHERE IPEnabled = True');
      
      if WMIQuery.Count > 0 then
      begin
        for i := 0 to WMIQuery.Count - 1 do
        begin
          MACAddress := WMIQuery.ItemIndex(i).MACAddress;
          
          if (MACAddress <> '') and (MACAddress <> '00:00:00:00:00:00') and (MACAddress <> 'FF:FF:FF:FF:FF:FF') then
          begin
            Result := MACAddress;
            Exit;
          end;
        end;
      end;
    except
      // Continuar para próxima tentativa
    end;
    
    // Tentativa 2: Win32_NetworkAdapter com filtro físico
    if Result = 'mac-desconhecido' then
    begin
      WMIQuery := WMI.ExecQuery('SELECT MACAddress, Name FROM Win32_NetworkAdapter WHERE PhysicalAdapter = True');
      
      if WMIQuery.Count > 0 then
      begin
        for i := 0 to WMIQuery.Count - 1 do
        begin
          MACAddress := WMIQuery.ItemIndex(i).MACAddress;
          NetworkName := WMIQuery.ItemIndex(i).Name;
          
          if (MACAddress <> '') and (MACAddress <> '00:00:00:00:00:00') and (MACAddress <> 'FF:FF:FF:FF:FF:FF') then
          begin
            // Verificar se não é um adaptador virtual
            if (Pos('Virtual', NetworkName) = 0) and (Pos('VMware', NetworkName) = 0) and 
               (Pos('VirtualBox', NetworkName) = 0) and (Pos('Hyper-V', NetworkName) = 0) and
               (Pos('Loopback', NetworkName) = 0) and (Pos('Teredo', NetworkName) = 0) then
            begin
              Result := MACAddress;
              Exit;
            end;
          end;
        end;
      end;
    end;
    
    // Tentativa 3: Todos os adaptadores (última tentativa)
    if Result = 'mac-desconhecido' then
    begin
      WMIQuery := WMI.ExecQuery('SELECT MACAddress, Name FROM Win32_NetworkAdapter');
      
      if WMIQuery.Count > 0 then
      begin
        for i := 0 to WMIQuery.Count - 1 do
        begin
          MACAddress := WMIQuery.ItemIndex(i).MACAddress;
          NetworkName := WMIQuery.ItemIndex(i).Name;
          
          if (MACAddress <> '') and (MACAddress <> '00:00:00:00:00:00') and (MACAddress <> 'FF:FF:FF:FF:FF:FF') then
          begin
            // Verificar se não é um adaptador virtual ou loopback
            if (Pos('Virtual', NetworkName) = 0) and (Pos('VMware', NetworkName) = 0) and 
               (Pos('VirtualBox', NetworkName) = 0) and (Pos('Hyper-V', NetworkName) = 0) and
               (Pos('Loopback', NetworkName) = 0) and (Pos('Teredo', NetworkName) = 0) and
               (Pos('Microsoft', NetworkName) = 0) and (Pos('ISATAP', NetworkName) = 0) then
            begin
              Result := MACAddress;
              Exit;
            end;
          end;
        end;
      end;
    end;
    
    // Tentativa 4: Usar API nativa do Windows para obter MAC Address
    if Result = 'mac-desconhecido' then
    begin
      Result := GetMACAddressNative;
    end;
    
    // Tentativa 5: Comando ipconfig (para servidores Dell)
    if Result = 'mac-desconhecido' then
    begin
      Result := GetMACAddressAlternative;
    end;
  except
    on E: Exception do
    begin
      // Fallback para registry se WMI falhar
      Result := GetMACFromRegistry;
    end;
  end;
end;

