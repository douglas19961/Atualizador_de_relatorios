                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                   ';' + // campo vazio
                                  QSelect.FieldByName('ocorrencia').AsString + ';' + // descrição da ocorrência
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                  ';'; // campo vazio
            
