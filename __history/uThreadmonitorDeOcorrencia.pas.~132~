      '        WHEN ''nis_authorized''    THEN ''NFC-e Autorizado''' +
      '        WHEN ''nis_rejected''      THEN ''NFC-e Rejeitado''' +
      '        WHEN ''nis_overruled''     THEN ''NFC-e Anulado/Denegado''' +
      '        WHEN ''nis_external_emit'' THEN ''NFC-e Emitida Externamente''' +
      '        ELSE ''NFC-e Status desconhecido''' +
      '    END' +
      ') || ' +
      '( ' +
      '   CASE lf2.situacao ' +
      '       WHEN -3 THEN ''- LancFinanceiro = Cancelado(-3)''' +
      '       WHEN -2 THEN ''- LancFinanceiro = Em cancelamento(-2)''' +
      '       WHEN  0 THEN ''- LancFinanceiro = Aberto(0)''' +
      '       WHEN  1 THEN ''- LancFinanceiro = Em Conclusao(1)''' +
      '       WHEN  2 THEN ''- LancFinanceiro = Concluido(2)''' +
