            begin                                                    //[VERIFICAR REPLICAS CLIENTES]
              FrmPrincipal.WriteLogFormatted('ERRO', '114', 'Erro ao enviar ocorrência Replicas para API: ' + E.Message);
            end;
          end;
          
          Query.Next;
        end;
                                                               //[VERIFICAR REPLICAS CLIENTES]
        FrmPrincipal.WriteLogFormatted('INFO', '114', Format('Processamento concluído. %d ocorrências inseridas com sucesso', [RegistrosProcessados]));
      end
      else
      begin                                              //[VERIFICAR REPLICAS CLIENTES]
        FrmPrincipal.WriteLogFormatted('INFO', '114', 'Nenhuma réplica com problema encontrada');
      end;
      
    except
      on E: Exception do
      begin                                                    //[VERIFICAR REPLICAS CLIENTES]
        FrmPrincipal.WriteLogFormatted('ERRO', '114', Format('Erro ao executar consulta: %s', [E.Message]));
      end;
    end;

  finally



  end;
  finally
    Query.Free;
    QInsert.Free;
    QueryApagar.Free;
    LocalConnection.Free;

    Inserir_Replicas_Lojas_Vazias;
  end;

end;
