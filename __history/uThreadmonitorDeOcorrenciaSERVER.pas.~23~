procedure ThreadMonitordeOcorrenciaServer.InserirOcorrencias;
var
  QSelect, qexclusao, QInsert: TUniQuery;
  CurrentDate: TDateTime;
begin
  FrmPrincipal.WriteLogFormatted('INFO', '115', 'Iniciando inser��o de ocorr�ncias');
  QSelect := TUniQuery.Create(nil);
  QInsert := TUniQuery.Create(nil);
  qexclusao := TUniQuery.Create(nil);
  FrmPrincipal.conexaomodulos;
  try
      try
        QSelect.Connection := FrmPrincipal.ConexaoModulo;
        QInsert.Connection := FrmPrincipal.ConexaoModulo;
        qexclusao.Connection := FrmPrincipal.ConexaoModulo;
        CurrentDate := Now; // Pega a data/hora atuais
        // Primeiro exclui registros antigos
        qexclusao.SQL.Text :=
          'DELETE FROM monitor_ocorrencias WHERE id_modulo_ocorrencia = 5';
        qexclusao.ExecSQL;
        // Depois busca as empresas
        QSelect.SQL.Text :=
          'SELECT id_empresa_help, ' +
          '  TO_CHAR(data_atualizada, ''YYYY-MM-DD'') || ' + QuotedStr(';') + ' || ' +
          '  TO_CHAR(data_atualizada, ''HH24:MI:SS'') || ' + QuotedStr(';') + ' || ' +
//          'data_atualizada, ' +
          'id_empresa_help || '';;;;;;;;N�o sincronizando;;;;;;;;;;'' AS info_concatenada,'+
          'CASE ' +
          '  WHEN EXTRACT(EPOCH FROM (now() - data_atualizada)) / 3600 >= 2 ' +
          '   AND EXTRACT(EPOCH FROM (now() - data_atualizada)) / 3600 <= 5 THEN 1 ' +
          '  WHEN EXTRACT(EPOCH FROM (now() - data_atualizada)) / 3600 >= 5 ' +
          '   AND EXTRACT(EPOCH FROM (now() - data_atualizada)) / 3600 <= 9 THEN 2 ' +
          '  WHEN EXTRACT(EPOCH FROM (now() - data_atualizada)) / 3600 > 9 ' +
          '   AND EXTRACT(EPOCH FROM (now() - data_atualizada)) / 3600 <= 12 THEN 3 ' +
          '  WHEN EXTRACT(EPOCH FROM (now() - data_atualizada)) / 3600 > 12  ' +
          '  THEN 4 else 1 ' +
          'END AS prioridade ' +
          'FROM public.cadastro_empresas ' +
          'WHERE ativo IS TRUE AND ID_TIPO_SISTEMA = 1 ' +
          'AND EXTRACT(EPOCH FROM (now() - data_atualizada)) / 3600 >= 2 ' +
          'ORDER BY data_atualizada DESC';
        QSelect.Open;
        // Agora insere um novo registro para cada empresa
        while not QSelect.Eof do
        begin
          QInsert.SQL.Clear;
          QInsert.SQL.Add('INSERT INTO monitor_ocorrencias ');
          QInsert.SQL.Add('(id_empresa_help, ocorrencia, id_prioridade, id_modulo_ocorrencia, data_ocorrencia, hora)');
          QInsert.SQL.Add('VALUES (:id_empresa_help, :ocorrencia, :id_prioridade, :id_modulo_ocorrencia, :data_ocorrencia, :hora)');
          QInsert.ParamByName('id_empresa_help').AsInteger := QSelect.FieldByName('id_empresa_help').AsInteger;
          QInsert.ParamByName('ocorrencia').AsString := QSelect.FieldByName('info_concatenada').AsString;
          QInsert.ParamByName('id_prioridade').AsInteger := QSelect.FieldByName('prioridade').AsInteger;
          QInsert.ParamByName('id_modulo_ocorrencia').AsInteger := 5;
          QInsert.ParamByName('data_ocorrencia').AsDateTime := DateOf(CurrentDate);
          QInsert.ParamByName('hora').AsTime := TimeOf(CurrentDate);         // S� a hora         // S� a hora
          QInsert.ExecSQL;
          QSelect.Next;
        end;
          FrmPrincipal.WriteLogFormatted('DEBUG', '115', '[DTCSYNC N�O SINCRONIZADOS] inserido dados com sucesso');
    except
      on E: Exception do
      begin
        // S� grava o erro no log, n�o mostra na tela
        FrmPrincipal.WriteLogFormatted('ERRO', '115', '[DTCSYNC N�O SINCRONIZADOS] erro: ' + E.Message);
      end;
    end;
  finally
    QSelect.Free;
    QInsert.Free;
    qexclusao.Free;
  end;
  InserirOcorrenciasDoss;
end;
