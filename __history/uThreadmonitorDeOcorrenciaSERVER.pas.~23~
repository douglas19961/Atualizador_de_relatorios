procedure ThreadMonitordeOcorrenciaServer.InserirOcorrenciaExterna(Empresa: integer; idModulo: Integer; ocorrencia: string; prioridade: integer);
var
  SQLInsert, SQLCheck: string;
  CurrentDate: TDateTime;
  FormattedDate, FormattedTime: string;
  StatusQuery: TUniQuery;
begin
  try
    // Verifica se o m�dulo est� ativo antes de inserir a ocorr�ncia
    SQLCheck := 'SELECT ativo FROM cadastro_modulos_ocorrencias WHERE id_modulo_ocorrencia = :id_modulo_ocorrencia';
    StatusQuery := TUniQuery.Create(nil);
    try
      StatusQuery.Connection := FrmPrincipal.ConexaoModulo;
      StatusQuery.SQL.Text := SQLCheck;
      StatusQuery.ParamByName('id_modulo_ocorrencia').AsInteger := idModulo;
      StatusQuery.Open;
      if StatusQuery.IsEmpty  then
      begin
        // Se o m�dulo estiver inativo ou n�o existir, n�o insere a ocorr�ncia
        Exit;
      end;
    finally
      StatusQuery.Free;
    end;
    // Pega a data e hora atual
    CurrentDate := Now;
    FormattedDate := FormatDateTime('yyyy-mm-dd', CurrentDate);
    FormattedTime := FormatDateTime('hh:nn:ss', CurrentDate);
    // Monta o SQL de inser��o
    SQLInsert := 'INSERT INTO monitor_ocorrencias (id_empresa_help, id_modulo_ocorrencia, ocorrencia, id_prioridade, Data_ocorrencia, Hora) ' +
                 'VALUES (:id_empresa_help, :modulo, :ocorrencia, :id_prioridade, :Data, :Hora)';
    FrmPrincipal.ConexaoModulo.StartTransaction;
    FrmPrincipal.ConexaoModulo.ExecSQL(SQLInsert, [
      Empresa,
      idModulo,
      ocorrencia,
      prioridade,
      FormattedDate,
      FormattedTime
    ]);
    FrmPrincipal.ConexaoModulo.Commit;
  except
    on E: Exception do
    begin
      FrmPrincipal.ConexaoModulo.Rollback;
      FrmPrincipal.WriteLogFormatted('ERRO', '1', 'Ocorr�ncias da empresa ' + inttostr(Empresa) +
        ' [MANDAR OCORRENCIA] Conex�o n�o inicializada. ' + E.Message);
      FrmPrincipal.MemoLogClient.Lines.Add('Ocorr�ncias da empresa ' + inttostr(Empresa) +
        ' [MANDAR OCORRENCIA] Conex�o n�o inicializada. ' + E.Message);
    end;
  end;
end;

