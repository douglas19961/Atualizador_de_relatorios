        on E: Exception do
          FrmPrincipal.WriteLogFormatted('ERRO', '1',
            '[ERRO GERAL] Falha ao processar banco: ' + E.Message);
      end;
      // Desconecta antes de ir pro pr�ximo banco
      FrmPrincipal.CxDTCFrota.Connected := False;
      QueryOrigem.Next;
    end;
  finally
    QueryOrigem.Free;
  end;
  ConsultaValidade;
end;

procedure ThreadMonitordeOcorrenciaServer.ConsultaValidade;
var
  extractedValue: string;
  QryPostgres, QryMySQL: TUniQuery;
  EmpresaExiste: Boolean;
  EmpresaID:integer;
begin
  FrmPrincipal.WriteLogFormatted('INFO', '105', 'Iniciando consulta de validade');
  extractedValue := '';
  // Garantir que a conex�o com PostgreSQL est� ativa
    FrmPrincipal.conexaomodulos;


  if not FrmPrincipal.Cxserver.Connected then
    FrmPrincipal.Cxserver.Connect;



    EmpresaID := StrToIntDef(FrmPrincipal.EdtEmpresaTodosServer.Text, 0);

  // Criar query para PostgreSQL
  QryPostgres := TUniQuery.Create(nil);
  try

    QryPostgres.Connection := FrmPrincipal.Cxserver;

    QryPostgres.SQL.Text :=
    'SELECT a.data_vencimento AS validade ' +
    'FROM autorizacoes a ' +
    'INNER JOIN pessoas p ON a.cod_pessoa = p.cod_pessoa ' +
    'WHERE p.reg_desativado IS FALSE ' +
    'AND a.data_vencimento IS NOT NULL ' +
    'ORDER BY a.data_vencimento DESC ' +
    'LIMIT 1;';
    QryPostgres.Open;
    if not QryPostgres.IsEmpty then
      extractedValue := QryPostgres.FieldByName('validade').AsString;
  finally
    QryPostgres.Free;
  end;
  if extractedValue = '' then
  begin
          FrmPrincipal.WriteLogFormatted('ERRO', '105', '[ATUALIZA VALIDADE] Nenhuma validade encontrada no PostgreSQL.');
    Exit;
  end;
  // Garantir que a conex�o com MySQL est� ativa
  // Verificar se a empresa j� existe na tabela Versao_Sistema
  EmpresaExiste := False;
  QryMySQL := TUniQuery.Create(nil);
  try
    QryMySQL.Connection := FrmPrincipal.ConexaoModulo;
    QryMySQL.SQL.Text := 'SELECT COUNT(*) AS Existe FROM versao_sistema WHERE id_empresa_help = :Empresa';
    QryMySQL.ParamByName('Empresa').Asinteger := EmpresaID;
    QryMySQL.Open;
    EmpresaExiste := QryMySQL.FieldByName('Existe').AsInteger > 0;
  finally
    QryMySQL.Free;
  end;
  // Se a empresa j� existir, atualizar a validade. Sen�o, inserir um novo registro.
  QryMySQL := TUniQuery.Create(nil);
  try
    QryMySQL.Connection := FrmPrincipal.ConexaoModulo;
    if EmpresaExiste then
    begin
      QryMySQL.SQL.Text := 'UPDATE versao_sistema SET vencimentos = :Value WHERE id_empresa_help = :id_empresa_help';
      FrmPrincipal.WriteLogFormatted('INFO', '105', 'validade atualizada para "' + extractedValue + '" na empresa: ' + FrmPrincipal.EdtEmpresaTodosserver.text);
    end
    else
    begin
      QryMySQL.SQL.Text := 'INSERT INTO versao_sistema (vencimentos, id_empresa_help) VALUES (:Value, :id_empresa_help)';
      FrmPrincipal.WriteLogFormatted('INFO', '105', 'validade "' + extractedValue + '" inserida no MySQL para Empresa: ' + FrmPrincipal.EdtEmpresaTodosserver.text);
    end;
    QryMySQL.ParamByName('Value').AsString := extractedValue;
    QryMySQL.ParamByName('id_empresa_help').Asinteger := EmpresaID;
    QryMySQL.ExecSQL;
  finally
    QryMySQL.Free;
   // apagarocorrenciascomdatalimite;
  end;
   apagarocorrenciascomdatalimite;
end;
procedure ThreadMonitordeOcorrenciaServer.apagarocorrenciascomdatalimite;
var
  QSelect, QDelete: TUniQuery;
  IdEmpresaHelp: Integer;
  DataAtualizada: TDateTime;
  RegistrosRemovidos: Integer;
begin
  FrmPrincipal.WriteLogFormatted('INFO', '1', '[LIMPEZA OCORR�NCIAS] Iniciando limpeza de ocorr�ncias antigas por data_atualizada');

  QSelect := TUniQuery.Create(nil);
  QDelete := TUniQuery.Create(nil);
  RegistrosRemovidos := 0;

  try
    // Verificar se ConexaoModulo est� ativa
    if not Assigned(FrmPrincipal.ConexaoModulo) or not FrmPrincipal.ConexaoModulo.Connected then
    begin
      FrmPrincipal.WriteLogFormatted('ERRO', '1', '[LIMPEZA OCORR�NCIAS] ConexaoModulo n�o est� conectada');
      Exit;
    end;

    QSelect.Connection := FrmPrincipal.ConexaoModulo;
    QDelete.Connection := FrmPrincipal.ConexaoModulo;

    // Buscar empresas com data_atualizada e suas ocorr�ncias antigas
    QSelect.SQL.Text :=
      'SELECT DISTINCT ce.id_empresa_help, ce.data_atualizada, mo.ocorrencia ' +
      'FROM cadastro_empresas ce ' +
      'INNER JOIN monitor_ocorrencias mo ON mo.id_empresa_help = ce.id_empresa_help ' +
      'WHERE (mo.data_ocorrencia::timestamp + mo.hora::time) <= (CURRENT_TIMESTAMP - INTERVAL ''7 minutes'')and id_chamado = 0 and id_modulo_ocorrencia <> 6  ' +
      'ORDER BY ce.id_empresa_help';

    QSelect.Open;

    while not QSelect.Eof do
    begin
      IdEmpresaHelp := QSelect.FieldByName('id_empresa_help').AsInteger;
      DataAtualizada := QSelect.FieldByName('data_atualizada').AsDateTime;

      FrmPrincipal.WriteLogFormatted('DEBUG', '1', Format('[LIMPEZA OCORR�NCIAS] Processando empresa %d (data_atualizada: %s)',
        [IdEmpresaHelp, DateTimeToStr(DataAtualizada)]));

      // Remover ocorr�ncias antigas para esta empresa
      QDelete.SQL.Text :=
        'DELETE FROM monitor_ocorrencias ' +
        'WHERE id_empresa_help = :id_empresa_help ' +
        'and id_modulo_ocorrencia <> 6 and id_chamado = 0 AND (data_ocorrencia::timestamp + hora::time) <= (CURRENT_TIMESTAMP - INTERVAL ''7 minutes'')';

      QDelete.ParamByName('id_empresa_help').AsInteger := IdEmpresaHelp;
      QDelete.ExecSQL;

      Inc(RegistrosRemovidos, QDelete.RowsAffected);

      if QDelete.RowsAffected > 0 then
      begin
        FrmPrincipal.WriteLogFormatted('DEBUG', '1', Format('[LIMPEZA OCORR�NCIAS] Removidas %d ocorr�ncias antigas da empresa %d',
          [QDelete.RowsAffected, IdEmpresaHelp]));
      end;

      QSelect.Next;
    end;

    FrmPrincipal.WriteLogFormatted('INFO', '1', Format('[LIMPEZA OCORR�NCIAS] Limpeza conclu�da. Total de registros removidos: %d', [RegistrosRemovidos]));

  except
    on E: Exception do
    begin
      FrmPrincipal.WriteLogFormatted('ERRO', '1', '[LIMPEZA OCORR�NCIAS] Erro durante limpeza: ' + E.Message);
    end;
  end;

  QSelect.Free;
  QDelete.Free;
    OcorrenciaVencimentoSigilo;
end;






procedure ThreadMonitordeOcorrenciaServer.OcorrenciaVencimentoSigilo;
var
  QSelect, qexclusao, QInsert: TUniQuery;
  CurrentDate: TDateTime;
begin
  FrmPrincipal.WriteLogFormatted('INFO', '130', 'Iniciando insersao de ocorrencias SIGILO VENCENDO');
  QSelect := TUniQuery.Create(nil);
  QInsert := TUniQuery.Create(nil);
  qexclusao := TUniQuery.Create(nil);

  try
      try
        QSelect.Connection := FrmPrincipal.ConexaoModulo;
        QInsert.Connection := FrmPrincipal.ConexaoModulo;
        qexclusao.Connection := FrmPrincipal.ConexaoModulo;
        CurrentDate := Now; // Pega a data/hora atuais
        QSelect.SQL.Text :=
        'SELECT'+

          ''';;;;;;;;;; Vence em: ''|| vs.vencimentos || ''Sistema Vencendo;;;;;;;;;;''  as info_concatenada,'+
          'CASE ' +
          '  WHEN EXTRACT(EPOCH FROM (NOW() - TO_TIMESTAMP(vs.vencimentos, ''DD/MM/YYYY''))) / 3600 >= 2 ' +
          '   AND EXTRACT(EPOCH FROM (NOW() - TO_TIMESTAMP(vs.vencimentos, ''DD/MM/YYYY''))) / 3600 <= 5 THEN 1 ' +
          '  WHEN EXTRACT(EPOCH FROM (NOW() - TO_TIMESTAMP(vs.vencimentos, ''DD/MM/YYYY''))) / 3600 >= 5 ' +
          '   AND EXTRACT(EPOCH FROM (NOW() - TO_TIMESTAMP(vs.vencimentos, ''DD/MM/YYYY''))) / 3600 <= 9 THEN 2 ' +
          '  WHEN EXTRACT(EPOCH FROM (NOW() - TO_TIMESTAMP(vs.vencimentos, ''DD/MM/YYYY''))) / 3600 > 9 ' +
          '   AND EXTRACT(EPOCH FROM (NOW() - TO_TIMESTAMP(vs.vencimentos, ''DD/MM/YYYY''))) / 3600 <= 12 THEN 3 ' +
          '  WHEN EXTRACT(EPOCH FROM (NOW() - TO_TIMESTAMP(vs.vencimentos, ''DD/MM/YYYY''))) / 3600 > 16 THEN 4 ' +
          '  ELSE 1 ' +
          'END AS prioridade ' +
          'FROM public.versao_sistema vs ' +
          'JOIN cadastro_empresas ce ON ce.id_empresa_help = vs.id_empresa_help ' +
          'WHERE ce.data_atualizada >= (NOW() - INTERVAL ''30 minutes'') ' +
          '  AND TO_DATE(vs.vencimentos, ''DD/MM/YYYY'') BETWEEN (CURRENT_DATE - INTERVAL ''15 days'') AND CURRENT_DATE ' +
          'ORDER BY vs.id_versao_sist ASC';

        QSelect.Open;
        // Agora insere um novo registro para cada empresa
        while not QSelect.Eof do
        begin
          QInsert.SQL.Clear;
          QInsert.SQL.Add('INSERT INTO monitor_ocorrencias ');
          QInsert.SQL.Add('(id_empresa_help, ocorrencia, id_prioridade, id_modulo_ocorrencia, data_ocorrencia, hora)');
          QInsert.SQL.Add('VALUES (:id_empresa_help, :ocorrencia, :id_prioridade, :id_modulo_ocorrencia, :data_ocorrencia, :hora)');
          QInsert.ParamByName('id_empresa_help').AsInteger := StrToIntDef(FrmPrincipal.EdtEmpresaTodosServer.Text, 0);
          QInsert.ParamByName('ocorrencia').AsString := QSelect.FieldByName('info_concatenada').AsString;
          QInsert.ParamByName('id_prioridade').AsInteger := QSelect.FieldByName('prioridade').AsInteger;
          QInsert.ParamByName('id_modulo_ocorrencia').AsInteger := 14;
          QInsert.ParamByName('data_ocorrencia').AsDateTime := DateOf(CurrentDate);
          QInsert.ParamByName('hora').AsTime := TimeOf(CurrentDate);         // S� a hora         // S� a hora
          QInsert.ExecSQL;
          QSelect.Next;
        end;
          FrmPrincipal.WriteLogFormatted('DEBUG', '130', '[SIGILO VENCENDO] inserido dados com sucesso');
    except
      on E: Exception do
      begin
        // S� grava o erro no log, n�o mostra na tela
        FrmPrincipal.WriteLogFormatted('ERRO', '130', '[SIGILO VENCENDO] erro: ' + E.Message);
      end;
    end;
  finally
    QSelect.Free;
    QInsert.Free;
    qexclusao.Free;
  end;

end;

