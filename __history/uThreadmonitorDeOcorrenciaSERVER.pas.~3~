procedure ThreadMonitordeOcorrenciaServer.AtualizarDataAtivoDTCFrota(Empresa: integer);
var
  Query: TUniQuery;
begin
  try
    Query := TUniQuery.Create(nil);
        try
          Query.Connection := FrmPrincipal.ConexaoModulo;
          // Garante que a conexăo esteja ativa
          Query.SQL.Text := 'UPDATE cadastro_empresas ' +
                            'SET data_atualizada = :data_atualizada ' +
                            'WHERE id_empresa_help = :id_empresa AND ativo is true';

            Query.ParamByName('id_empresa').AsInteger := (Empresa);

          Query.ParamByName('data_atualizada').AsDateTime := Now;
          Query.Execute;
//           ShowMessage('[ATUALIZA DATA EMPRESA] data_atualizada atualizado com sucesso! ');
          except
            on E: Exception do
            begin
//             ShowMessage('[ATUALIZA DATA EMPRESA] Erro ao atualizar data_atualizada: ' + E.Message);
             FrmPrincipal.WriteLogFormatted('ERRO', '117', '[ATUALIZA DATA EMPRESA] Erro ao atualizar data_atualizada: ' + E.Message);
          end;
        end;
  finally
    Query.Free;
  end;
end;
procedure ThreadMonitordeOcorrenciaServer.InserirOcorrenciaExterna(Empresa: integer; idModulo: Integer; ocorrencia: string; prioridade: integer);
var
  SQLInsert, SQLCheck: string;
  CurrentDate: TDateTime;
  FormattedDate, FormattedTime: string;
  StatusQuery: TUniQuery;
begin
  try
    // Verifica se o módulo está ativo antes de inserir a ocorręncia
    SQLCheck := 'SELECT ativo FROM cadastro_modulos_ocorrencias WHERE id_modulo_ocorrencia = :id_modulo_ocorrencia';
    StatusQuery := TUniQuery.Create(nil);
    try
      StatusQuery.Connection := FrmPrincipal.ConexaoModulo;
      StatusQuery.SQL.Text := SQLCheck;
      StatusQuery.ParamByName('id_modulo_ocorrencia').AsInteger := idModulo;
      StatusQuery.Open;
      if StatusQuery.IsEmpty  then
      begin
        // Se o módulo estiver inativo ou năo existir, năo insere a ocorręncia
        Exit;
      end;
    finally
      StatusQuery.Free;
    end;
    // Pega a data e hora atual
    CurrentDate := Now;
    FormattedDate := FormatDateTime('yyyy-mm-dd', CurrentDate);
    FormattedTime := FormatDateTime('hh:nn:ss', CurrentDate);
    // Monta o SQL de inserçăo
    SQLInsert := 'INSERT INTO monitor_ocorrencias (id_empresa_help, id_modulo_ocorrencia, ocorrencia, id_prioridade, Data_ocorrencia, Hora) ' +
                 'VALUES (:id_empresa_help, :modulo, :ocorrencia, :id_prioridade, :Data, :Hora)';
    FrmPrincipal.ConexaoModulo.StartTransaction;
    FrmPrincipal.ConexaoModulo.ExecSQL(SQLInsert, [
      Empresa,
      idModulo,
      ocorrencia,
      prioridade,
      FormattedDate,
      FormattedTime
    ]);
    FrmPrincipal.ConexaoModulo.Commit;
  except
    on E: Exception do
    begin
      FrmPrincipal.ConexaoModulo.Rollback;
      FrmPrincipal.WriteLogFormatted('ERRO', '1', 'Ocorręncias da empresa ' + inttostr(Empresa) +
        ' [MANDAR OCORRENCIA] Conexăo năo inicializada. ' + E.Message);
      FrmPrincipal.MemoLogClient.Lines.Add('Ocorręncias da empresa ' + inttostr(Empresa) +
        ' [MANDAR OCORRENCIA] Conexăo năo inicializada. ' + E.Message);
    end;
  end;
end;
procedure ThreadMonitordeOcorrenciaServer.executarVariosBancos;
var
  QueryOrigem,QueryApagar: TUniQuery;
begin
  QueryOrigem := TUniQuery.Create(nil);
  QueryApagar := TUniQuery.Create(nil);
  try
    QueryOrigem.Connection := FrmPrincipal.ConexaoModulo;
    QueryOrigem.SQL.Text :=
      'SELECT id_empresa_help, host, nome_banco, usuario, senha, porta ' +
      'FROM cadastro_bancos_dtc_frota ' +
      'WHERE ativo IS TRUE';
    QueryOrigem.Open;
       QueryApagar.Connection := FrmPrincipal.ConexaoModulo;  // Aqui cxclient é a conexăo com o banco de dados
    // Prepara a query para excluir os dados da empresa fornecida
    QueryApagar.SQL.Text := 'DELETE FROM monitor_ocorrencias WHERE id_modulo_ocorrencia = :id_modulo_ocorrencia';
    QueryApagar.ParamByName('id_modulo_ocorrencia').AsInteger := 6;  // Converte o valor do Edit para inteiro
    // Executa a exclusăo
    QueryApagar.ExecSQL;
    while not QueryOrigem.Eof do
    begin
      try
        // Configurar conexăo dinâmica
        FrmPrincipal.CxDTCFrota.Connected := False;
        FrmPrincipal.CxDTCFrota.ProviderName := 'Mysql';
        FrmPrincipal.CxDTCFrota.Server := QueryOrigem.FieldByName('host').AsString;
        FrmPrincipal.CxDTCFrota.Database := QueryOrigem.FieldByName('nome_banco').AsString;
        FrmPrincipal.CxDTCFrota.Username := QueryOrigem.FieldByName('usuario').AsString;
        FrmPrincipal.CxDTCFrota.Password := QueryOrigem.FieldByName('senha').AsString;
        FrmPrincipal.CxDTCFrota.Port := QueryOrigem.FieldByName('porta').AsInteger;
        FrmPrincipal.CxDTCFrota.SpecificOptions.Values['UseUnicode'] := 'True';
        FrmPrincipal.CxDTCFrota.LoginPrompt := False;
        try
          FrmPrincipal.CxDTCFrota.Connected := True;
          FrmPrincipal.WriteLogFormatted('DEBUG', '117', Format('[CONECTADO] Banco %s (%s) conectado com sucesso!',
          [FrmPrincipal.CxDTCFrota.Database, FrmPrincipal.CxDTCFrota.Server]));
        // Agora faz tudo neste banco
               // Atribui a conexăo correta para o UniQuery
          var QueryConsulta := TUniQuery.Create(nil);
          try
            QueryConsulta.Connection := FrmPrincipal.CxDTCFrota;
            QueryConsulta.SQL.Text :=
              'SELECT CONCAT(' +
              'data, ' + QuotedStr(';') + ', ' +
              'hora, ' + QuotedStr(';') + ', ' +
              'id_empresa, ' + QuotedStr(';') + ', ' +
              QuotedStr('') + ', ' + QuotedStr(';') + ', ' +
              QuotedStr('') + ', ' + QuotedStr(';') + ', ' +
              QuotedStr('') + ', ' + QuotedStr(';') + ', ' +
              QuotedStr('') + ', ' + QuotedStr(';') + ', ' +
              QuotedStr('') + ', ' + QuotedStr(';') + ', ' +
              QuotedStr('') + ', ' + QuotedStr(';') + ', ' +
              QuotedStr('') + ', ' + QuotedStr(';') + ', ' +
              QuotedStr('Divergencia nos encerrantes') + ', ' + QuotedStr(';') + ', ' +
              QuotedStr('') + ', ' + QuotedStr(';') + ', ' +
              QuotedStr('') + ', ' + QuotedStr(';') + ', ' +
              QuotedStr('') + ', ' + QuotedStr(';') + ', ' +
              QuotedStr('') + ', ' + QuotedStr(';') + ', ' +
              QuotedStr('') + ', ' + QuotedStr(';') + ', ' +
              QuotedStr('') + ', ' + QuotedStr(';') + ', ' +
              QuotedStr('') + ', ' + QuotedStr(';') + ', ' +
              QuotedStr('') + ', ' + QuotedStr(';') + ', ' +
              QuotedStr('') + ', ' + QuotedStr(';') + ', ' +
              QuotedStr('') +
              ') AS Ocorrencia ' +
              'FROM auditoria_encerrantes ' +
              'WHERE status = 0';
            QueryConsulta.Open;
             FrmPrincipal.WriteLogFormatted('DEBUG', '117', 'achou aqui: ' + inttostr(QueryOrigem.FieldByName('id_empresa_help').AsInteger));
            while not QueryConsulta.Eof do
            begin
              try
                FrmPrincipal.InserirOcorrenciaExterna(
                  QueryOrigem.FieldByName('id_empresa_help').AsInteger,
                  6,
                  QueryConsulta.FieldByName('Ocorrencia').AsString,
                  4
                );
              except
                on E: Exception do
                  FrmPrincipal.WriteLogFormatted('ERRO', '117', 'Inserçăo de ocorręncia falhou: ' + E.Message);
              end;
              QueryConsulta.Next;
            end;
          finally
            QueryConsulta.Free;
          end;
        except
          on E: Exception do
            FrmPrincipal.WriteLogFormatted('ERRO', '117', Format('Banco %s: %s',
              [FrmPrincipal.CxDTCFrota.Database, E.Message]));
        end;
      except
        on E: Exception do
          FrmPrincipal.WriteLogFormatted('ERRO', '117', 'Falha ao processar banco: ' + E.Message);
      end;
     FrmPrincipal.AtualizarDataAtivoDTCFrota(QueryOrigem.FieldByName('id_empresa_help').AsInteger);
      // Garante que feche antes de passar para o próximo
      FrmPrincipal.CxDTCFrota.Connected := False;
      QueryOrigem.Next;
    end;
  finally
    QueryOrigem.Free;
  end;
  FrmPrincipal.WriteLogFormatted('INFO', '117', 'Execuçăo de vários bancos DTC Frota concluída');
//  executarVariosBancosAtivoDtcSite;
