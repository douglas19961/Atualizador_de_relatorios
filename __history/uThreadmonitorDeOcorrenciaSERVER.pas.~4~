            '    '''', '';'', ' +
            '    '''', '';'', ' +
            '    '''', '';'', ' +
            '    '''', '';'', ' +
            '    '''', '';'', ' +
            '    '''', '';'', ' +
            '    '''', '';'', ' +
            '    '''', '';'', ' +
            '    '''' ' +
            '  ) AS Ocorrencia ' +
            'FROM posicao_tanque pt ' +
            'JOIN deposito d ' +
            '  ON d.id_deposito = pt.num_tanque ' +
            'JOIN ( ' +
            '  SELECT ' +
            '    CAST(num_tanque AS UNSIGNED) AS num_tanque_sem_zero, ' +
            '    MAX(STR_TO_DATE(CONCAT(data, '' '', hora), ''%Y-%m-%d %H:%i:%s'')) AS ultima_datahora ' +
