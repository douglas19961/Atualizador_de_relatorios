procedure ThreadMonitordeOcorrenciaServer.Versaosigiloatual;
var
  extractedValue: string;
  QryPostgres, QryPostgreSQL: TUniQuery;
  EmpresaExiste: Boolean;
  EmpresaID: Integer;
begin
  FrmPrincipal.WriteLogFormatted('INFO', '1', 'Iniciando atualizaçăo de versăo do sigilo');

      FrmPrincipal.Cxserver.Connect;

  // Buscar versăo no PostgreSQL
  QryPostgres := TUniQuery.Create(nil);
  try

      QryPostgres.Connection := FrmPrincipal.Cxserver;
    QryPostgres.SQL.Text :=
      'SELECT versao ' +
      'FROM informativos_versoes ' +
      'ORDER BY data_liberacao DESC ' +
      'LIMIT 1';
    QryPostgres.Open;
    if not QryPostgres.IsEmpty then
      extractedValue := QryPostgres.FieldByName('versao').AsString;
  finally
    QryPostgres.Free;
  end;
  if extractedValue = '' then
  begin
          FrmPrincipal.WriteLogFormatted('ERRO', '1', '[ATUALIZA VERSĂO] Nenhuma versăo do sigilo encontrada no PostgreSQL.');
    Exit;
  end;
  // Atualizar ou inserir nova versăo
  QryPostgreSQL := TUniQuery.Create(nil);
  try
    QryPostgreSQL.Connection := FrmPrincipal.ConexaoModulo;
   // Verifica se existe
      QryPostgreSQL.SQL.Text := 'UPDATE versao_atual_sigilo SET versao = :Value';
      QryPostgreSQL.ParamByName('Value').AsString := extractedValue;
      QryPostgreSQL.ExecSQL;
      if QryPostgreSQL.RowsAffected = 0 then
      begin
        QryPostgreSQL.SQL.Text := 'INSERT INTO versao_atual_sigilo (versao) VALUES (:Value)';
        QryPostgreSQL.ParamByName('Value').AsString := extractedValue;
        QryPostgreSQL.ExecSQL;
        FrmPrincipal.WriteLogFormatted('INFO', '1', 'Versăo inserida "' + extractedValue + '"');
      end
      else
        FrmPrincipal.WriteLogFormatted('INFO', '1', 'Versăo atualizada para "' + extractedValue + '"');
  finally
    QryPostgreSQL.Free;
    executarVariosBancosmedicaodivergente; // Se quiser habilitar depois
  end;
end;
