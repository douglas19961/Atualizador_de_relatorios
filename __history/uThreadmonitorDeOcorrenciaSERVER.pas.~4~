           QueryConsulta.SQL.Text :=
            'SELECT ' +
            '  CONCAT( ' +
            '    pt.data, '';'', ' +
            '    pt.hora, '';'', ' +
            '    d.id_deposito, '';'', ' +
            '    '''', '';'', ' +
            '    '''', '';'', ' +
            '    '''', '';'', ' +
            '    '''', '';'', ' +
            '    '''', '';'', ' +
            '    '''', '';'', ' +
