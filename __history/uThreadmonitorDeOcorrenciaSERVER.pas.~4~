            '  GROUP BY CAST(num_tanque AS UNSIGNED) ' +
            ') ult ' +
            '  ON CAST(pt.num_tanque AS UNSIGNED) = ult.num_tanque_sem_zero ' +
            '  AND STR_TO_DATE(CONCAT(pt.data, '' '', pt.hora), ''%Y-%m-%d %H:%i:%s'') = ult.ultima_datahora ' +
            'WHERE d.id_deposito IS NOT NULL and d.ativo = 1' +
            '  AND TIMESTAMPDIFF( ' +
            '        MINUTE, ' +
