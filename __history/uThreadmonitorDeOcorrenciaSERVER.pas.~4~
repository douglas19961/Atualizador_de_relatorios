procedure ThreadMonitordeOcorrenciaServer.replicaslocal;
var
  ConexaoMonitor: TUniConnection;
  QSelect: TUniQuery;
  QInsert: TUniQuery;
  QVerificar: TUniQuery;
  data_hora: TDateTime;
  StatusAtual: string;
  OcorrenciaFormatada: string;
  RegistrosProcessados: Integer;
  RegistrosPulados: Integer;
  CodCliente: Integer;
begin
  RegistrosProcessados := 0;
  RegistrosPulados := 0;
  FrmPrincipal.WriteLogFormatted('INFO', '500', '[REPLICAS LOCAL] Iniciando verificaçăo de ocorręncias no banco monitor');

  ConexaoMonitor := TUniConnection.Create(nil);
  QSelect := TUniQuery.Create(nil);
  QInsert := TUniQuery.Create(nil);

  try
    // Configurar conexăo com banco monitor
    ConexaoMonitor.ProviderName := 'MySQL';
    ConexaoMonitor.Server := '192.168.0.240';
    ConexaoMonitor.Port := 3306;
    ConexaoMonitor.Database := 'monitor';
    ConexaoMonitor.Username := 'admin';
    ConexaoMonitor.Password := '9887653321';

    // Conectar ao banco monitor
    try
      ConexaoMonitor.Connect;
      FrmPrincipal.WriteLogFormatted('INFO', '200', '[REPLICAS LOCAL] Conectado ao banco monitor com sucesso');
    except
      on E: Exception do
      begin
        FrmPrincipal.WriteLogFormatted('ERRO', '200', '[REPLICAS LOCAL] Erro ao conectar ao banco monitor: ' + E.Message);
        Exit;
      end;
    end;

    // Verificar se ConexaoModulo está ativa
    if not Assigned(FrmPrincipal.ConexaoModulo) or not FrmPrincipal.ConexaoModulo.Connected then
    begin
      FrmPrincipal.WriteLogFormatted('ERRO', '200', '[REPLICAS LOCAL] ConexaoModulo năo está conectada');
      Exit;
    end;

    // Configurar query de seleçăo
    QSelect.Connection := ConexaoMonitor;

    FrmPrincipal.WriteLogFormatted('INFO', '500', '[REPLICAS LOCAL] Verificando estrutura da tabela backup...');

    // Primeiro testar se a tabela backup existe
    try
      QSelect.SQL.Text := 'SHOW TABLES LIKE ''backup''';
      QSelect.Open;
      if QSelect.IsEmpty then
      begin
        FrmPrincipal.WriteLogFormatted('ERRO', '500', '[REPLICAS LOCAL] Tabela backup năo encontrada no banco monitor');
        Exit;
      end;
      QSelect.Close;
    except
      on E: Exception do
      begin
        FrmPrincipal.WriteLogFormatted('ERRO', '500', '[REPLICAS LOCAL] Erro ao verificar tabela backup: ' + E.Message);
        Exit;
      end;
    end;


    // Agora executar a query principal
    QSelect.SQL.Text := 'SELECT cod_cliente, nome, ilha, end_pasta, ativo, status, mensagem, data_hora ' +
                       'FROM backup ' +
                       'WHERE (status <> :status_ok OR status IS NULL) AND status <> :status_vazio';
    QSelect.ParamByName('status_ok').AsString := 'OK';
    QSelect.ParamByName('status_vazio').AsString := '';

    // Configurar query de inserçăo
    QInsert.Connection := FrmPrincipal.ConexaoModulo;
    QInsert.SQL.Clear;
    QInsert.SQL.Add('INSERT INTO monitor_ocorrencias ');
    QInsert.SQL.Add('(id_empresa_help, ocorrencia, id_prioridade, id_modulo_ocorrencia, data_ocorrencia, hora)');
    QInsert.SQL.Add('VALUES (:id_empresa_help, :ocorrencia, :id_prioridade, :id_modulo_ocorrencia, :data_ocorrencia, :hora)');

    try
      QSelect.Open;
      FrmPrincipal.WriteLogFormatted('INFO', '500', '[REPLICAS LOCAL] Consulta executada. Registros encontrados: ' + IntToStr(QSelect.RecordCount));

      if not QSelect.IsEmpty then
      begin
        QSelect.First;
        while not QSelect.Eof do
        begin
          try
            StatusAtual := QSelect.FieldByName('status').AsString;
            CodCliente := QSelect.FieldByName('cod_cliente').AsInteger;

            // Verificar se o cod_cliente existe na tabela monitor_ocorrencias
            QVerificar := TUniQuery.Create(nil);
            try
              QVerificar.Connection := FrmPrincipal.ConexaoModulo;
              QVerificar.SQL.Text := 'SELECT COUNT(*) as total FROM monitor_ocorrencias WHERE id_empresa_help = :cod_cliente';
              QVerificar.ParamByName('cod_cliente').AsInteger := CodCliente;
              QVerificar.Open;

                             if QVerificar.FieldByName('total').AsInteger = 0 then
               begin
                 Inc(RegistrosPulados);
                 FrmPrincipal.WriteLogFormatted('INFO', '500', Format('[REPLICAS LOCAL] Cliente %d (%s) năo encontrado na tabela monitor_ocorrencias - pulando registro',
                   [CodCliente, QSelect.FieldByName('nome').AsString]));
                 QSelect.Next;
                 Continue;
               end;
              QVerificar.Close;
            finally
              QVerificar.Free;
            end;

            // Converter data_hora string para TDateTime
            try
              data_hora := StrToDateTime(QSelect.FieldByName('data_hora').AsString);
            except
              data_hora := Now; // Se năo conseguir converter, usa data atual
            end;


            // Formatar ocorręncia com campos separados por ponto e vírgula
            OcorrenciaFormatada := FormatDateTime('YYYY-MM-DD', data_hora) + ';' +
                                  FormatDateTime('HH:NN:SS', data_hora) + ';' +
                                  QSelect.FieldByName('cod_cliente').AsString+ ';' +
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                   ';' + // campo vazio
                                    QSelect.FieldByName('mensagem').AsString + ';' +
                                     QSelect.FieldByName('mensagem').AsString + ';' +
                                      QSelect.FieldByName('mensagem').AsString + ';' +
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                  QSelect.FieldByName('mensagem').AsString + ';' +
                                  QSelect.FieldByName('mensagem').AsString + ';' +
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                  ';' + // campo vazio
                                  ';'; // campo vazio

            // Inserir ocorręncia no banco de módulos
            QInsert.ParamByName('id_empresa_help').AsInteger := CodCliente;
            QInsert.ParamByName('ocorrencia').AsString := OcorrenciaFormatada;
            QInsert.ParamByName('id_prioridade').AsInteger := 2;
            QInsert.ParamByName('id_modulo_ocorrencia').AsInteger := 7;
            QInsert.ParamByName('data_ocorrencia').AsDateTime := DateOf(data_hora);
            QInsert.ParamByName('hora').AsTime := TimeOf(data_hora);
            QInsert.ExecSQL;

            Inc(RegistrosProcessados);
            FrmPrincipal.WriteLogFormatted('INFO', '500', Format('[REPLICAS LOCAL] Ocorręncia inserida para cliente %d: %s (Status: %s)',
              [CodCliente,
               QSelect.FieldByName('nome').AsString,
               StatusAtual]));

          except
            on E: Exception do
            begin
              FrmPrincipal.WriteLogFormatted('ERRO', '500', Format('[REPLICAS LOCAL] Erro ao processar registro do cliente %d: %s',
                [QSelect.FieldByName('cod_cliente').AsInteger, E.Message]));
            end;
          end;

          QSelect.Next;
        end;

        FrmPrincipal.WriteLogFormatted('INFO', '500', Format('[REPLICAS LOCAL] Processamento concluído. %d ocorręncias inseridas, %d registros pulados', [RegistrosProcessados, RegistrosPulados]));
      end
      else
      begin
        FrmPrincipal.WriteLogFormatted('INFO', '500', '[REPLICAS LOCAL] Nenhum registro com status diferente de OK encontrado');
      end;
    except
      on E: Exception do
      begin
       FrmPrincipal. WriteLogFormatted('ERRO', '500', '[REPLICAS LOCAL] Erro ao executar consulta: ' + E.Message);
      end;
    end;
  finally
    QSelect.Free;
    QInsert.Free;
    ConexaoMonitor.Free;
    executarVariosBancosCorrigindoEncerrantes;
  end;
end;

